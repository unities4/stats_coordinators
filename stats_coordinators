/* hung-slider-bar replaced by controls-bar */


/* ── TABLE CONTROLS (columns + download) ── */
.tbl-ctrl-group { display:flex; align-items:center; gap:6px; }
.tbl-ctrl-btn { background:none; border:1px solid var(--gray-200); border-radius:6px; cursor:pointer; padding:4px 8px; font-size:11px; font-weight:600; color:var(--gray-500); display:inline-flex; align-items:center; justify-content:center; gap:4px; transition:all 0.15s; white-space:nowrap; line-height:1; }
.tbl-ctrl-btn:hover { border-color:var(--blue); color:var(--blue); background:var(--blue-faint); }
.tbl-ctrl-btn svg { flex-shrink:0; display:block; }
/* Column picker dropdown */
.col-picker-wrap { position:relative; }
.col-picker-dropdown { position:absolute; right:0; top:calc(100% + 6px); background:#fff; border:1px solid var(--gray-200); border-radius:10px; box-shadow:var(--shadow-md); z-index:600; min-width:200px; padding:0; display:none; max-height:calc(100vh - 80px); overflow:hidden; }
.col-picker-dropdown.open { display:block; }
.col-picker-item { display:flex; align-items:center; gap:8px; padding:6px 14px; cursor:pointer; font-size:12px; color:var(--gray-700); transition:background 0.1s; user-select:none; }
.col-picker-item:hover { background:var(--gray-100); }
.col-picker-item input[type=checkbox] { accent-color:var(--blue); width:13px; height:13px; flex-shrink:0; }

/* ── LOAD MODAL ── */
.load-modal-overlay { display:none; position:fixed; inset:0; z-index:2000; align-items:center; justify-content:center; }
.load-modal-overlay.open { display:flex; }
.load-modal-backdrop { position:absolute; inset:0; background:rgba(15,23,42,0.45); backdrop-filter:blur(2px); }
.load-modal-card { position:relative; background:#fff; border-radius:20px; box-shadow:0 24px 64px rgba(0,76,151,0.22); width:440px; max-width:calc(100vw - 32px); padding:32px; animation:loadModalIn 0.2s ease; }
@keyframes loadModalIn { from{opacity:0;transform:translateY(12px) scale(0.98)} to{opacity:1;transform:translateY(0) scale(1)} }
.load-modal-x { position:absolute; top:18px; right:18px; background:none; border:none; cursor:pointer; color:var(--gray-300); padding:4px; border-radius:6px; transition:all 0.15s; }
.load-modal-x:hover { color:var(--gray-600); background:var(--gray-100); }
.load-modal-head { margin-bottom:24px; }
.load-modal-title { font-family:'Montserrat','Segoe UI',Arial,sans-serif; font-size:20px; font-weight:800; color:var(--gray-900); margin-bottom:4px; }
.load-modal-sub { font-size:13px; color:var(--gray-400); }
.load-modal-options { display:flex; flex-direction:column; gap:12px; }
.load-option { display:flex; align-items:center; gap:16px; padding:16px; border:1.5px solid var(--gray-200); border-radius:14px; background:#fff; cursor:pointer; transition:all 0.18s; text-align:left; width:100%; }
.load-option:hover { border-color:var(--blue); background:var(--blue-faint); transform:translateX(2px); }
.load-option-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.load-icon-blue { background:var(--blue-light); }
.load-icon-orange { background:#FFF3E0; }
.load-option-text { flex:1; min-width:0; }
.load-option-title { font-family:'Montserrat','Segoe UI',Arial,sans-serif; font-size:14px; font-weight:700; color:var(--gray-900); margin-bottom:3px; }
.load-option-desc { font-size:12px; color:var(--gray-400); line-height:1.4; }
.load-option-arrow { color:var(--gray-300); flex-shrink:0; transition:all 0.18s; }
.load-option:hover .load-option-arrow { color:var(--blue); transform:translateX(3px); }
</style>
</head>
<body>

