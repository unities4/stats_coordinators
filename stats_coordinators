    const dateApprove = excelSerialToDate(row.getCell(12).value); // L: Дата последнего согласования
    const dateRZ      = excelSerialToDate(row.getCell(13).value); // M: Дата закрытия последнего РЗ
    const dateReg     = excelSerialToDate(row.getCell(14).value); // N: Дата регистрации
