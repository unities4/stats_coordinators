function populatePeriodLists(ab) {
  const mode = ab==='a' ? periodModeA : periodModeB;
  let keys;
  if (mode === 'month') {
    const existing = allData.map(r=>getPeriodKey(r.dateClose,'month')).filter(Boolean).sort();
    if (!existing.length) { keys = []; }
    else {
      const first = existing[0], last = existing[existing.length-1];
      let [cy,cm] = first.split('-').map(Number);
      const [ly,lm] = last.split('-').map(Number);
      keys = [];
      while (cy < ly || (cy===ly && cm<=lm)) {
        keys.push(`${cy}-${String(cm).padStart(2,'0')}`);
        cm++; if (cm>12) { cm=1; cy++; }
      }
    }
  } else {
    keys = [...new Set(allData.map(r=>getPeriodKey(r.dateClose,mode)).filter(Boolean))].sort();
  }
  const listEl = document.getElementById(ab==='a'?'paList':'pbList');
  listEl.innerHTML = keys.map(k=>`<button type="button" class="period-tag" data-val="${escAttr(k)}" onclick="togglePeriodTag(this,'${ab}')">${escHtml(formatPeriodLabel(k,mode))}</button>`).join('');
  if (typeof updatePeriodTagsAvailability === 'function') updatePeriodTagsAvailability();
}
