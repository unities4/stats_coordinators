// ====== COMPARISON ======
function getCmpFilteredBase() {
  // Comparison table uses its own period selector — ignore YEAR/MONTH global filters
  // Only apply KE/SL/BD structural filters
  const keSet=msSelected['KE'], slSet=msSelected['SL'], bdSet=msSelected['BD'];
  if (!keSet.size && !slSet.size && !bdSet.size) return allData;
  return allData.filter(r => {
    if (keSet.size && !keSet.has(r.ke)) return false;
    if (slSet.size && !slSet.has(r.serviceLine)) return false;
    if (bdSet.size && !bdSet.has(r.businessDir)) return false;
    return true;
  });
}
function getDataForSelectedPeriods(ab, base) {
  const mode=ab==='a'?periodModeA:periodModeB;
  const selected=getSelectedPeriods(ab);
  if(!selected.length) return null;
  return base.filter(r=>{ const k=getPeriodKey(r.dateClose,mode); return selected.includes(k); });
}

function renderComparison() {
  const base=getCmpFilteredBase();
  const dataA=getDataForSelectedPeriods('a',base);
  const dataB=getDataForSelectedPeriods('b',base);
  const resultsEl=document.getElementById('comparisonResults');
  const emptyEl=document.getElementById('cmpEmpty');
  if(!dataA||!dataB){resultsEl.style.display='none';emptyEl.style.display='block';return;}

  const selA=getSelectedPeriods('a');
  const selB=getSelectedPeriods('b');
  const labelA=formatPeriodRangeLabel(selA, periodModeA);
  const labelB=formatPeriodRangeLabel(selB, periodModeB);

  const totalA=dataA.length,totalB=dataB.length;
  const overdueA=dataA.filter(r=>r.days!==null&&r.days>params.days).length;
  const overdueB=dataB.filter(r=>r.days!==null&&r.days>params.days).length;
  const pctA=totalA>0?(overdueA/totalA*100):0;
  const pctB=totalB>0?(overdueB/totalB*100):0;

  function dcls(a,b,lb=true){const d=b-a;if(Math.abs(d)<0.01)return'neutral';return(lb?d<0:d>0)?'better':'worse';}
  function dlbl(a,b,pct=false){const d=b-a;return(d>0?'+':'')+d.toFixed(1)+(pct?'%':'');}

  document.getElementById('cmpCards').innerHTML=[
    {title:'Всего ЗИ',valA:totalA,valB:totalB,delta:dlbl(totalA,totalB),cls:dcls(totalA,totalB,false)},
    {title:'Просроченных ЗИ',valA:overdueA,valB:overdueB,delta:dlbl(overdueA,overdueB),cls:dcls(overdueA,overdueB,true)},
    {title:'Доля просрочки',valA:pctA.toFixed(1)+'%',valB:pctB.toFixed(1)+'%',delta:dlbl(pctA,pctB,true),cls:dcls(pctA,pctB,true)}
  ].map(c=>{
    const dColor = c.cls==='better'?'var(--green)':c.cls==='worse'?'var(--red)':'var(--gray-600)';
    return `<div class="cmp-card"><div class="cmp-card-title">${c.title}</div><div class="cmp-values">
      <div class="cmp-val"><div class="cmp-val-num" style="color:var(--blue)">${c.valA}</div><div class="cmp-val-label"><span class="period-badge-a">Период A</span></div></div>
      <div class="cmp-separator"></div>
      <div class="cmp-val"><div class="cmp-val-num" style="color:var(--green)">${c.valB}</div><div class="cmp-val-label"><span class="period-badge-a">Период B</span></div></div>
      <div class="cmp-separator"></div>
      <div class="cmp-val"><div class="cmp-val-num" style="color:${dColor}">${c.delta}</div><div class="cmp-val-label"><span class="cmp-delta ${c.cls}" style="margin-top:0">Динамика</span></div></div>
    </div></div>`;
  }).join('');

  const statsA=computeStats(dataA);
  const statsB=computeStats(dataB);
  const names=new Set([...statsA.map(s=>s.name),...statsB.map(s=>s.name)]);
  const mapA=Object.fromEntries(statsA.map(s=>[s.name,s]));
  const mapB=Object.fromEntries(statsB.map(s=>[s.name,s]));
  cmpRowsCache=[...names].map(name=>{
    const a=mapA[name],b=mapB[name];
    const pA=a?a.pct:null, pB=b?b.pct:null;
    const oA=a?a.overdue:null, oB=b?b.overdue:null;
    const tA=a?a.total:null, tB=b?b.total:null;
    const deltaPct=(pA!==null&&pB!==null)?pB-pA:null;
    const deltaOverdue=(oA!==null&&oB!==null)?oB-oA:null;
    return{name,
      totalA:tA, totalB:tB,
      overdueA:oA, overdueB:oB,
      pctA:pA, pctB:pB,
      deltaPct, deltaOverdue};
  });
  // Attach labels for header
  cmpRowsCache._labelA = labelA;
  cmpRowsCache._labelB = labelB;
  // Default sort: deltaPct descending (biggest positive first)
  cmpSortCol = 'deltaPct';
  cmpSortDir = -1;
  renderCmpTable();
  // Store for chart
  cmpChartDataA = dataA; cmpChartDataB = dataB;
  cmpChartLabelA = labelA; cmpChartLabelB = labelB;
  renderCmpChart();
  resultsEl.style.display='block';emptyEl.style.display='none';
}

function cmpPctCell(pct, overdue, total) {
  if (pct === null) return '<span style="color:#d1d5db">—</span>';
  const cls = pct >= params.threshold ? 'cmp-pct-red' : pct >= params.threshold/2 ? 'cmp-pct-orange' : 'cmp-pct-green';
  const sub = (overdue !== null && total !== null) ? `<div class="cmp-pct-sub">${overdue}/${total}</div>` : '';
  return `<div><span class="cmp-pct-val ${cls}">${pct.toFixed(1)}%</span>${sub}</div>`;
}

function cmpDeltaCell(dA, dB) {
  if (dA === null || dB === null) return '<span style="color:#9ca3af">—</span>';
  const d = dB - dA;
  const abs = Math.abs(d).toFixed(1);
  if (Math.abs(d) < 0.05) return '<span class="cmp-delta-cell cmp-delta-zero">→ 0%</span>';
  const arrow = d > 0 ? '↑' : '↓';
  const cls = d > 0 ? 'cmp-delta-up' : 'cmp-delta-down';
  return `<span class="cmp-delta-cell ${cls}">${arrow} ${abs}%</span>`;
}

function cmpTh(col, label, alignLeft) {
  const active = cmpSortCol === col;
  const arrow = active ? (cmpSortDir < 0 ? '↓' : '↑') : '<span style="opacity:0.3;font-size:9px">⇅</span>';
  const activeCls = active ? ' sort-active' : '';
  const align = alignLeft ? 'text-align:left;' : '';
  return `<th class="cmp-th${activeCls}" style="${align}cursor:pointer" onclick="setCmpSort('${col}')">${label} <span class="sort-arrow">${arrow}</span></th>`;
}

function setCmpSort(col) {
  if (cmpSortCol === col) cmpSortDir *= -1;
  else { cmpSortCol = col; cmpSortDir = -1; }
  renderCmpTable();
}

function renderCmpTable() {
  const wrap = document.getElementById('cmpTableWrap');
  if (!wrap || !cmpRowsCache.length) return;

  const hideSame = document.getElementById('chkHideSame')?.checked;
  let rows = hideSame ? cmpRowsCache.filter(r => r.deltaPct !== null) : [...cmpRowsCache];

  // Sort
  rows.sort((a, b) => {
    const av = a[cmpSortCol] ?? -999, bv = b[cmpSortCol] ?? -999;
    if (typeof av === 'string') return cmpSortDir * av.localeCompare(bv, 'ru');
    return cmpSortDir * (bv - av);
  });

  const lA = cmpRowsCache._labelA || 'A';
  const lB = cmpRowsCache._labelB || 'B';

  const rowCls = r => '';

  const thead = `<thead><tr>
    ${cmpTh('name','Координатор',true)}
    ${cmpTh('overdueA',`ПР ЗИ<br><span style="font-weight:400;opacity:.75">(${escHtml(lA)})</span>`,false)}
    ${cmpTh('overdueB',`ПР ЗИ<br><span style="font-weight:400;opacity:.75">(${escHtml(lB)})</span>`,false)}
    ${cmpTh('deltaOverdue','Δ ПР ЗИ',false)}
    ${cmpTh('pctA',`Доля ПР<br><span style="font-weight:400;opacity:.75">(${escHtml(lA)})</span>`,false)}
    ${cmpTh('pctB',`Доля ПР<br><span style="font-weight:400;opacity:.75">(${escHtml(lB)})</span>`,false)}
    ${cmpTh('deltaPct','Δ Доля ПР',false)}
  </tr></thead>`;

  const tbody = rows.map(r => `
    <tr class="${rowCls(r)}">
      <td style="font-weight:400">${escHtml(r.name)}</td>
      <td>${r.overdueA !== null ? `<div><span class="cmp-num-val">${r.overdueA}</span><div class="cmp-pct-sub">${r.overdueA}/${r.totalA}</div></div>` : '—'}</td>
      <td>${r.overdueB !== null ? `<div><span class="cmp-num-val">${r.overdueB}</span><div class="cmp-pct-sub">${r.overdueB}/${r.totalB}</div></div>` : '—'}</td>
      <td>${cmpDeltaCell(r.overdueA, r.overdueB)}</td>
      <td>${cmpPctCell(r.pctA, r.overdueA, r.totalA)}</td>
      <td>${cmpPctCell(r.pctB, r.overdueB, r.totalB)}</td>
      <td>${cmpDeltaCell(r.pctA, r.pctB)}</td>
    </tr>`).join('');

  wrap.innerHTML = `<table class="cmp-tbl"><colgroup>
    <col style="width:22%"><col style="width:11%"><col style="width:11%"><col style="width:9%">
    <col style="width:13%"><col style="width:13%"><col style="width:9%">
  </colgroup>${thead}<tbody>${tbody}</tbody></table>`;
}

