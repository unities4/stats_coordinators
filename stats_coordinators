}

// ====== COMPUTE ======
function computeStats(data) {
  data = data || filteredData;
  const map = {};
  for (const r of data) {
    if (!map[r.coordinator]) map[r.coordinator]={total:0,overdue:0,daysArr:[],coordStatus:r.coordStatus||'',coordManager:r.coordManager||''};
    map[r.coordinator].total++;
    if (r.days!==null&&r.days>params.days) map[r.coordinator].overdue++;
    if (r.days!==null) map[r.coordinator].daysArr.push(r.days);
  }
  return Object.entries(map).map(([name,d])=>{
    const pct=d.total>0?(d.overdue/d.total)*100:0;
    const mean=d.daysArr.length>0?d.daysArr.reduce((a,b)=>a+b,0)/d.daysArr.length:0;
    const sorted=[...d.daysArr].sort((a,b)=>a-b);
    const mid=Math.floor(sorted.length/2);
    const median=sorted.length===0?0:sorted.length%2!==0?sorted[mid]:(sorted[mid-1]+sorted[mid])/2;
    let status='excluded';
    if (d.total>=params.minZI) {
      if (pct>=params.threshold) status='critical';
      else if (pct>=params.threshold/2) status='risk';
      else status='ok';
    }
    return {name,total:d.total,overdue:d.overdue,pct,mean,median,daysVal:useMedian?median:mean,status,coordStatus:d.coordStatus,coordManager:d.coordManager};
  });
}

function computeBreakdown(groupKey, data) {
  data=data||filteredData;
  const map={};
  for (const r of data) {
    const key=r[groupKey]||'(не указано)';
    if (!map[key]) map[key]={total:0,overdue:0,daysArr:[]};
    map[key].total++;
    if (r.days!==null&&r.days>params.days) map[key].overdue++;
    if (r.days!==null) map[key].daysArr.push(r.days);
  }
  return Object.entries(map).map(([name,d])=>{
    const pct=d.total>0?(d.overdue/d.total)*100:0;
    const mean=d.daysArr.length>0?d.daysArr.reduce((a,b)=>a+b,0)/d.daysArr.length:0;
    const sorted=[...d.daysArr].sort((a,b)=>a-b);
    const mid=Math.floor(sorted.length/2);
    const median=sorted.length===0?0:sorted.length%2!==0?sorted[mid]:(sorted[mid-1]+sorted[mid])/2;
    return {name,total:d.total,overdue:d.overdue,pct,mean,median};
  }).sort((a,b)=>b.pct-a.pct);
}

function getOverdueDaysMetrics(data) {
  data=data||filteredData;
  const od=data.filter(r=>r.days!==null&&r.days>params.days).map(r=>r.days).sort((a,b)=>a-b);
  if (!od.length) return {count:0,mean:0,median:0,max:0};
  const mean=od.reduce((s,d)=>s+d,0)/od.length;
  const median=od.length%2?od[Math.floor(od.length/2)]:(od[od.length/2-1]+od[od.length/2])/2;
  const max = od.length ? od[od.length-1] : 0;
  return {count:od.length,mean,median,max};
}

