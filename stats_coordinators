<div class="notification" id="notification">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
    <polyline points="22 4 12 14.01 9 11.01"/>
  </svg>
  <span id="notifText"></span>
</div>

<script>
// ========== STATE ==========
let allData = [];
let currentFilter = 'all';
let sortField = 'pct';
let sortDir = 'desc';
let useMedian = false;
let params = { minZI: 10, threshold: 10, days: 1 };

// ========== FILE HANDLING ==========
const fileInput = document.getElementById('fileInput');
const uploadZone = document.getElementById('uploadZone');
const reportComment = document.getElementById('reportComment');

function insertPlainTextIntoEditable(text) {
  const selection = window.getSelection();
  if (!selection || !selection.rangeCount) {
    reportComment.textContent += text;
    return;
  }
  const range = selection.getRangeAt(0);
  range.deleteContents();
  range.insertNode(document.createTextNode(text));
  range.collapse(false);
  selection.removeAllRanges();
  selection.addRange(range);
}

reportComment.addEventListener('paste', e => {
  e.preventDefault();
  insertPlainTextIntoEditable(e.clipboardData.getData('text/plain'));
});
reportComment.addEventListener('drop', e => {
  e.preventDefault();
  insertPlainTextIntoEditable(e.dataTransfer.getData('text/plain'));
});
reportComment.addEventListener('input', () => {
  if (reportComment.children.length) {
    reportComment.textContent = reportComment.textContent;
  }
});

uploadZone.addEventListener('click', () => fileInput.click());
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault(); uploadZone.classList.remove('drag-over');
  if (e.dataTransfer.files[0]) processFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => { if (fileInput.files[0]) processFile(fileInput.files[0]); });

async function processFile(file) {
  showNotif('Обработка файла...', false, true);
  try {
    if (!window.ExcelJS) {
      throw new Error('Локальная библиотека exceljs.min.js не загружена. Проверьте, что файл exceljs.min.js находится рядом с HTML.');
    }
    const buf = await file.arrayBuffer();
    const wb = new ExcelJS.Workbook();
    await wb.xlsx.load(buf);

    const ws = wb.getWorksheet('Изменение');
    if (!ws) { showNotif('Лист «Изменение» не найден!', true); return; }

    const rows = [];
    ws.eachRow((row, ri) => {
      if (ri === 1) return;
      const coordinator = row.getCell(3).value;
      if (!coordinator) return;
      const daysRaw = row.getCell(6).value;
      const days = (daysRaw !== null && daysRaw !== undefined && !isNaN(parseFloat(daysRaw)))
        ? parseFloat(daysRaw) : null;
      rows.push({
        num: row.getCell(1).value,
        ke: row.getCell(2).value,
        coordinator: String(coordinator).trim(),
        dateApprove: row.getCell(4).value,
        dateClose: row.getCell(5).value,
        days: days
      });
    });

    if (!rows.length) { showNotif('Данные не найдены на листе «Изменение»', true); return; }

    allData = rows;
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileMeta').textContent =
      `Записей: ${rows.length} · Загружено: ${new Date().toLocaleString('ru')}`;
    document.getElementById('reportDate').textContent =
      `Отчёт от ${new Date().toLocaleDateString('ru',{day:'numeric',month:'long',year:'numeric'})}`;

    uploadZone.style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
    document.getElementById('btnExport').style.display = 'inline-flex';
    showNotif(`Загружено ${rows.length} записей`);
    renderAll();
  } catch(e) {
    showNotif('Ошибка чтения файла: ' + e.message, true);
    console.error(e);
  }
}

// ========== SLIDERS ==========
document.getElementById('sliderMinZI').addEventListener('input', function() {
  params.minZI = +this.value;
  document.getElementById('valMinZI').textContent = params.minZI;
  renderAll();
});
document.getElementById('sliderThreshold').addEventListener('input', function() {
  params.threshold = +this.value;
  document.getElementById('valThreshold').textContent = params.threshold + '%';
  renderAll();
});
document.getElementById('sliderDays').addEventListener('input', function() {
  params.days = +this.value;
  document.getElementById('valDays').textContent = params.days;
  renderAll();
});

function setMode(m) {
  useMedian = (m === 'median');
  document.getElementById('btnMean').classList.toggle('active', !useMedian);
  document.getElementById('btnMedian').classList.toggle('active', useMedian);
  // Update header label
  document.getElementById('th-days').childNodes[0].textContent =
    (useMedian ? 'Медиана дней ' : 'Среднее дней ');
  renderAll();
}

// ========== COMPUTE ==========
// «Просроченное» ЗИ: значение в столбце 6 (кол-во раб. дней) > params.days
// Доля просроченных = кол-во просроченных ЗИ / общее кол-во ЗИ координатора * 100%
function computeStats() {
  const map = {};
  for (const r of allData) {
    if (!map[r.coordinator]) map[r.coordinator] = { total: 0, overdue: 0, daysArr: [] };
    map[r.coordinator].total++;
    // Считаем просроченным если days > params.days
    if (r.days !== null && r.days > params.days) map[r.coordinator].overdue++;
    if (r.days !== null) map[r.coordinator].daysArr.push(r.days);
  }

  return Object.entries(map).map(([name, d]) => {
    const pct = d.total > 0 ? (d.overdue / d.total) * 100 : 0;
    const mean = d.daysArr.length > 0 ? d.daysArr.reduce((a,b)=>a+b,0)/d.daysArr.length : 0;
    const sorted = [...d.daysArr].sort((a,b)=>a-b);
    const mid = Math.floor(sorted.length/2);
    const median = sorted.length === 0 ? 0
      : sorted.length % 2 !== 0 ? sorted[mid]
      : (sorted[mid-1]+sorted[mid])/2;

    // Статус: только если total >= minZI
    // Категории относительно порога threshold:
    //   < threshold/2  => ok
    //   >= threshold/2 && < threshold => risk
    //   >= threshold   => critical
    let status = 'excluded';
    if (d.total >= params.minZI) {
      if (pct >= params.threshold) status = 'critical';
      else if (pct >= params.threshold / 2) status = 'risk';
      else status = 'ok';
    }

    return { name, total: d.total, overdue: d.overdue, pct, mean, median,
      daysVal: useMedian ? median : mean, status };
  });
}

// ========== RENDER ALL ==========
function updatePrintParams() {
  const pp = document.getElementById('printParams');
  if (!pp) return;
  document.getElementById('ppMinZI').textContent = params.minZI;
  document.getElementById('ppThreshold').textContent = params.threshold + '%';
  document.getElementById('ppDays').textContent = params.days + ' дн.';
  const btnMean = document.getElementById('ppBtnMean');
  const btnMedian = document.getElementById('ppBtnMedian');
  if (btnMean && btnMedian) {
    btnMean.className = 'print-param-toggle-btn' + (useMedian ? '' : ' pptb-active');
    btnMedian.className = 'print-param-toggle-btn' + (useMedian ? ' pptb-active' : '');
  }
}

function renderAll() {
  const stats = computeStats();
  renderCards(stats);
  renderTable(stats);
  renderCharts(stats);
  renderTop5(stats);
  updatePrintParams();
}

// ========== CARDS ==========
function getTableStats(stats) {
  return currentFilter === 'all'
    ? stats.filter(r => r.status !== 'excluded')
    : stats.filter(r => r.status === currentFilter);
}

function getOverdueDaysMetrics(stats) {
  const tableStats = getTableStats(stats);
  const visibleCoordinators = new Set(tableStats.map(r => r.name));
  const overdueDays = allData
    .filter(r => visibleCoordinators.has(r.coordinator) && r.days !== null && r.days > params.days)
    .map(r => r.days)
    .sort((a, b) => a - b);

  if (!overdueDays.length) {
    return { count: 0, mean: 0, median: 0 };
  }

  const mean = overdueDays.reduce((sum, days) => sum + days, 0) / overdueDays.length;
  const median = overdueDays.length % 2
    ? overdueDays[Math.floor(overdueDays.length / 2)]
    : (overdueDays[overdueDays.length / 2 - 1] + overdueDays[overdueDays.length / 2]) / 2;

  return { count: overdueDays.length, mean, median };
}

function renderCards(stats) {
  const totalZI = allData.length;
  const overdueZI = allData.filter(r => r.days !== null && r.days > params.days).length;
  const overduePct = totalZI > 0 ? ((overdueZI / totalZI) * 100).toFixed(1) : '0.0';
  const overdueDays = getOverdueDaysMetrics(stats);
  const critical = stats.filter(s => s.status === 'critical').length;
  const risk = stats.filter(s => s.status === 'risk').length;
  const coordTotal = stats.length;

  // Рассчитываем пороги для карточки "зона риска"
  const riskLow = (params.threshold / 2).toFixed(0);
  const riskHigh = (params.threshold - 1);

  const grid = document.getElementById('cardsGrid');
  grid.innerHTML = '';

  const cards = [
    {
      cls: '', metrics: [
        { val: totalZI, label: 'Всего ЗИ', badge: `${coordTotal} чел.`, badgeCls: 'badge-blue' },
        { val: `${overduePct}%`, label: 'С просрочкой', badge: `${overdueZI} ЗИ`, badgeCls: 'badge-red' }
      ],
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2">
        <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`
    },
    {
      cls: 'card-red', metrics: [
        { val: `${overdueDays.mean.toFixed(1)} дн.`, label: 'Среднее дней', badge: `${overdueDays.count} ЗИ`, badgeCls: 'badge-red' },
        { val: `${overdueDays.median.toFixed(1)} дн.`, label: 'Медиана дней', badge: 'по просрочке', badgeCls: 'badge-orange' }
      ],
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
    },
    {
      cls: 'card-red', val: critical, label: 'Критичные координаторы',
      badge: `≥ ${params.threshold}% просрочка`, badgeCls: 'badge-red',
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2">
        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`
    },
    {
      cls: 'card-orange', val: risk, label: 'В зоне риска',
      badge: `от ${riskLow}% до ${riskHigh}% просрочка`, badgeCls: 'badge-orange',
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E07B00" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
    }
  ];

  cards.forEach((c, i) => {
    const div = document.createElement('div');
    div.className = `card ${c.cls} animate-in`;
    div.style.animationDelay = (i * 0.07) + 's';
    const metrics = c.metrics || [{ val: c.val, label: c.label, badge: c.badge, badgeCls: c.badgeCls }];
    const metricsClass = metrics.length === 1 ? 'card-metrics single-metric' : 'card-metrics';
    div.innerHTML = `
      <div class="card-icon">${c.icon}</div>
      <div class="${metricsClass}">
        ${metrics.map(m => `<div class="card-metric">
          <div class="card-value">${m.val}</div>
          <div class="card-label">${m.label}</div>
          <div class="card-badge ${m.badgeCls}">${m.badge}</div>
        </div>`).join('')}
      </div>`;
    grid.appendChild(div);
  });
}

// ========== TABLE ==========
function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderAll();
}

function sortTable(field) {
  if (sortField === field) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
  else { sortField = field; sortDir = 'desc'; }
  document.querySelectorAll('thead th').forEach(th => {
    const si = th.querySelector('.sort-icon');
    if (si) si.className = 'sort-icon';
    th.classList.remove('sorted');
  });
  const th = document.getElementById('th-' + field);
  if (th) {
    th.classList.add('sorted');
    const si = th.querySelector('.sort-icon');
    if (si) si.className = 'sort-icon ' + sortDir;
  }
  renderAll();
}

function renderTable(stats) {
  // Применяем фильтр по статусу (currentFilter)
  let data = getTableStats(stats);

  // Сортировка
  data.sort((a,b) => {
    let va = sortField === 'days' ? a.daysVal : a[sortField];
    let vb = sortField === 'days' ? b.daysVal : b[sortField];
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    if (va < vb) return sortDir === 'asc' ? -1 : 1;
    if (va > vb) return sortDir === 'asc' ? 1 : -1;
    return 0;
  });

  document.getElementById('tableCount').textContent = `${data.length} из ${stats.length}`;

  const tbody = document.getElementById('tableBody');
  if (!data.length) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 16px;display:block;opacity:.4">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <div class="empty-title">Нет данных</div>
      <div>Попробуйте изменить фильтры или пороги слайдеров</div>
    </div></td></tr>`;
    return;
  }

  const maxPct = Math.max(...data.map(d => d.pct), 0.1);
  const statusMap = {
    critical: { cls: 'status-critical', label: 'Критичные просрочки' },
    risk:     { cls: 'status-risk',     label: 'Зона риска' },
    ok:       { cls: 'status-ok',       label: 'Соблюдает сроки' },
    excluded: { cls: 'status-excluded', label: `< ${params.minZI} ЗИ (исключён)` }
  };

  tbody.innerHTML = data.map(r => {
    const s = statusMap[r.status];
    const fillColor = r.status === 'critical' ? 'var(--red)'
      : r.status === 'risk' ? 'var(--orange)'
      : r.status === 'ok' ? 'var(--green)' : 'var(--gray-400)';
    const barW = ((r.pct / maxPct) * 100).toFixed(1);
    return `<tr>
      <td class="name-cell">${escHtml(r.name)}</td>
      <td class="num-cell">${r.total}</td>
      <td class="num-cell">${r.overdue}</td>
      <td>
        <div class="progress-wrap">
          <div class="progress-bar">
            <div class="progress-fill" style="width:${barW}%;background:${fillColor}"></div>
          </div>
          <span class="progress-pct" style="color:${fillColor}">${r.pct.toFixed(1)}%</span>
        </div>
      </td>
      <td class="num-cell">${r.daysVal.toFixed(1)}</td>
      <td><span class="status-badge ${s.cls}">${s.label}</span></td>
    </tr>`;
  }).join('');
}

// ========== DONUT CHART ==========
function renderCharts(stats) {
  const critical = stats.filter(s => s.status === 'critical').length;
  const risk     = stats.filter(s => s.status === 'risk').length;
  const ok       = stats.filter(s => s.status === 'ok').length;
  const excl     = stats.filter(s => s.status === 'excluded').length;
  drawDonut(
    [critical, risk, ok, excl],
    ['#C0392B','#E07B00','#1A7A4A','#94A3B8'],
    ['Критичные','Зона риска','Соблюдают','Исключены']
  );
}

function drawDonut(values, colors, labels) {
  const canvas = document.getElementById('chartDonut');
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth || 330;
  canvas.width = W; canvas.height = 220;
  ctx.clearRect(0, 0, W, 220);
  const total = values.reduce((a,b)=>a+b,0);
  if (!total) return;
  const cx = W/2, cy = 105, r = 80, ri = 52;
  let angle = -Math.PI/2;
  values.forEach((v, i) => {
    if (!v) return;
    const slice = (v/total)*2*Math.PI;
    ctx.beginPath(); ctx.moveTo(cx,cy);
    ctx.arc(cx,cy,r,angle,angle+slice); ctx.closePath();
    ctx.fillStyle = colors[i]; ctx.fill();
    angle += slice;
  });
  ctx.beginPath(); ctx.arc(cx,cy,ri,0,2*Math.PI);
  ctx.fillStyle='#fff'; ctx.fill();
  ctx.fillStyle='#0F172A';
  ctx.font='bold 26px Montserrat,Segoe UI,Arial,sans-serif';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(total, cx, cy-8);
  ctx.font='12px PT Sans,Segoe UI,Arial,sans-serif';
  ctx.fillStyle='#94A3B8';
  ctx.fillText('координаторов', cx, cy+14);
  document.getElementById('chartLegend').innerHTML =
    values.map((v,i) => `<div class="legend-item">
      <div class="legend-dot" style="background:${colors[i]}"></div>
      ${labels[i]}: <strong>${v}</strong>
    </div>`).join('');
}

// ========== TOP-5 ==========
function renderTop5(stats) {
  const top5 = [...stats].filter(s=>s.status!=='excluded')
    .sort((a,b)=>b.pct-a.pct).slice(0,5);
  const el = document.getElementById('top5List');
  if (!top5.length) { el.innerHTML=''; return; }
  const maxPct = top5[0].pct || 1;
  el.innerHTML = top5.map((r,i) => {
    const color = r.status==='critical' ? 'var(--red)' : r.status==='risk' ? 'var(--orange)' : 'var(--green)';
    return `<div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <span style="font-size:12px;font-weight:600;color:var(--gray-900);max-width:200px;
          overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${i+1}. ${escHtml(r.name)}</span>
        <span style="font-family:'Montserrat','Segoe UI',Arial,sans-serif;font-size:12px;font-weight:700;color:${color}">${r.pct.toFixed(1)}%</span>
      </div>
      <div class="progress-bar" style="height:8px">
        <div class="progress-fill" style="width:${(r.pct/maxPct*100).toFixed(1)}%;background:${color}"></div>
      </div>
    </div>`;
  }).join('');
}

// ========== PDF ==========
function exportPDF() {
  window.print();
}

// ========== HELPERS ==========
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function showNotif(msg, isError=false, loading=false) {
  const n = document.getElementById('notification');
  document.getElementById('notifText').textContent = msg;
  n.className = 'notification' + (isError ? ' error' : '');
  n.classList.add('show');
  if (!loading) setTimeout(()=>n.classList.remove('show'), 3000);
}

window.addEventListener('resize', () => {
  if (allData.length > 0) renderCharts(computeStats());
});
</script>
