function colPickerClearAll(tableId) {
  const cols = TABLE_COLS[tableId] || [];
  // Keep at least one column visible (the last one)
  cols.forEach((c, i) => { c.v = (i === cols.length - 1); });
  const picker = document.getElementById('colPicker_' + tableId);
  if (picker) picker.querySelectorAll('input[type=checkbox]').forEach((cb, i) => cb.checked = (i === cols.length - 1));
  applyColVisibility(tableId);
  if (tableId === 'docTableBody') renderDocPage();
}

function onColToggle(tableId, idx, checked) {
  if (TABLE_COLS[tableId]) TABLE_COLS[tableId][idx].v = checked;
