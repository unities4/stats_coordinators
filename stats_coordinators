function docRowMatchesFilters(r) {
  if (msSelected['KE'].size    && !msSelected['KE'].has(r.ke))            return false;
  if (msSelected['SL'].size    && !msSelected['SL'].has(r.sl))            return false;
  if (msSelected['BD'].size    && !msSelected['BD'].has(r.bd))            return false;
  if (msSelected['COORD'].size && !msSelected['COORD'].has(r.coordinator)) return false;
  if (msSelected['STATUS'].size && !msSelected['STATUS'].has(r.coordStatus)) return false;
  if (msSelected['CAT'].size   && !msSelected['CAT'].has(r.category))     return false;
  if (msSelected['KIND'].size  && !msSelected['KIND'].has(r.kind))        return false;
  if (msSelected['REGYEAR'].size || msSelected['REGMONTH'].size) {
    if (!r.dateReg || !(r.dateReg instanceof Date) || isNaN(r.dateReg))   return false;
    if (msSelected['REGYEAR'].size  && !msSelected['REGYEAR'].has(String(r.dateReg.getFullYear()))) return false;
    if (msSelected['REGMONTH'].size && !msSelected['REGMONTH'].has(`${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`)) return false;
  }
  return true;
}

function renderDocPage() {
  if (!hungData.length) return;

  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const thresholdDays = parseInt(document.getElementById('sliderDocThreshold').value) || 5;

  // Deadline = today + thresholdDays working days
  const deadlineDate = addWorkDays(today, thresholdDays);

  // Helper: parse colR to a numeric "days" value (calendar days, not working)
  // colR can be a number (already days) or a Date
  function parseColR(r) {
    const v = r.colR;
    if (v === null || v === undefined || v === '') return null;
    if (typeof v === 'number') return v;
    if (v instanceof Date && !isNaN(v)) {
      // If it's a date, treat as Excel serial → use as-is numeric days since epoch not useful
      // Actually colR is expected to be a plain number of days. If it came as Date, convert back.
      return Math.round((v - new Date(1899, 11, 30)) / 86400000);
    }
    const n = parseFloat(v);
    return isNaN(n) ? null : n;
  }

  // Helper: compute daysLeft for a row
  // If colQ is present: working days from today to colQ (negative = overdue)
  // If colQ is empty: use colR date + 1 working day as start of overdue
  function computeDaysLeft(r) {
    const hasQ = r.colQ && r.colQ instanceof Date && !isNaN(r.colQ);
    if (hasQ) {
      const q = new Date(r.colQ); q.setHours(0,0,0,0);
      return q >= today ? countWorkDays(today, q) : -countWorkDays(q, today);
    }
    // colQ empty: overdue starts at colR + 1 working day
    if (!r.dateApprove || !(r.dateApprove instanceof Date) || isNaN(r.dateApprove)) return null;
    const overdueStart = addWorkDays(r.dateApprove, thresholdDays + 1);
    if (!overdueStart) return null;
    overdueStart.setHours(0,0,0,0);
    // Only overdue if today > overdueStart
    if (today <= overdueStart) return null; // not overdue yet — exclude
    return -countWorkDays(overdueStart, today);
  }

  // Filter: status = 'Документирование', passes shared filters
  // Include if: colQ < deadlineDate  OR  (colQ empty AND colR present AND overdue)
  const docRows = hungData
    .filter(r => {
      if (r.status !== 'Документирование') return false;
      if (!docRowMatchesFilters(r)) return false;
      const hasQ = r.colQ && r.colQ instanceof Date && !isNaN(r.colQ);
      if (hasQ) {
        const q = new Date(r.colQ); q.setHours(0,0,0,0);
        return q < deadlineDate;
      }
      // colQ empty: include only if computed daysLeft is not null (i.e. overdue)
      const dl = computeDaysLeft(r);
      return dl !== null && dl < 0;
    })
    .map(r => {
      const dl = computeDaysLeft(r);
      return { ...r, daysLeft: dl !== null ? dl : 0 };
    });

  _docFiltered = docRows;

  // ── CARDS ──
  const total = docRows.length;
  const totalAll = hungData.filter(r => r.status === 'Документирование' && docRowMatchesFilters(r)).length;
  const docNontypical = docRows.filter(r => r.kind === 'Нетиповой').length;
  const docTypical    = docRows.filter(r => r.kind === 'Типовой').length;

  // Card 2: stats from colR (calendar days, not working days)
  // colR is a raw cell value — number of days
  const colRArr = docRows.map(r => parseColR(r)).filter(v => v !== null && !isNaN(v));
  colRArr.sort((a,b) => a-b);
  const colRMean   = colRArr.length ? colRArr.reduce((s,v)=>s+v,0)/colRArr.length : 0;
  const colRMid    = Math.floor(colRArr.length/2);
  const colRMedian = colRArr.length === 0 ? 0 : colRArr.length % 2 !== 0 ? colRArr[colRMid] : (colRArr[colRMid-1]+colRArr[colRMid])/2;
  const colRMetricVal = docUseMedian ? colRMedian : colRMean;
  const colRMetricLabel = docUseMedian ? 'медианное' : 'среднее';
  // >6 months = >180 days, >1 year = >365 days (calendar)
  const over6m  = colRArr.filter(v => v > 180).length;
  const over1y  = colRArr.filter(v => v > 365).length;
  const pct6m   = total ? Math.round(over6m/total*100) : 0;
  const pct1y   = total ? Math.round(over1y/total*100) : 0;
  const colRColor = colRMetricVal > 365 ? '#dc2626' : colRMetricVal > 180 ? '#d97706' : '#16a34a';

  document.getElementById('docCardsGrid').innerHTML = `
    <div class="card card-info animate-in" style="grid-column:span 2">
      <div class="distrib-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2" style="flex-shrink:0">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
