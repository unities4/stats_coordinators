.settings-body { flex:1; overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:24px; }
.settings-section-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--gray-400); margin-bottom:12px; }
.settings-control { display:flex; flex-direction:column; gap:8px; }
.settings-control label { font-size:13px; color:var(--gray-600); display:flex; justify-content:space-between; }
.settings-control label span { font-weight:700; color:var(--blue); }
.settings-control input[type=range] { width:100%; accent-color:var(--blue); }

/* ── START SCREEN ── */
.start-screen { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:calc(100vh - 80px); padding:40px 24px; }
.start-screen-title { font-family:'Montserrat','Segoe UI',Arial,sans-serif; font-size:24px; font-weight:800; color:var(--gray-900); text-align:center; margin-bottom:8px; }
.start-screen-sub { font-size:14px; color:var(--gray-400); text-align:center; margin-bottom:40px; }
.module-cards { display:flex; gap:24px; flex-wrap:wrap; justify-content:center; max-width:900px; }
.module-card { background:#fff; border-radius:16px; box-shadow:var(--shadow-md); padding:32px 28px; width:260px; display:flex; flex-direction:column; align-items:center; gap:16px; cursor:pointer; border:2px solid transparent; transition:all 0.2s; text-align:center; }
.module-card:hover { border-color:var(--blue); transform:translateY(-4px); box-shadow:var(--shadow-lg); }
.module-card.locked { opacity:.55; cursor:default; }
.module-card.locked:hover { transform:none; border-color:transparent; box-shadow:var(--shadow-md); }
.module-icon { width:56px; height:56px; border-radius:14px; display:flex; align-items:center; justify-content:center; }
.module-icon-blue { background:var(--blue-light); }
.module-icon-orange { background:#FFF3E0; }
.module-icon-green { background:var(--green-light); }
.module-card-title { font-family:'Montserrat','Segoe UI',Arial,sans-serif; font-size:15px; font-weight:700; color:var(--gray-900); line-height:1.3; }
.module-card-desc { font-size:12px; color:var(--gray-400); line-height:1.5; }
.module-card-badge { font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; }
.badge-need-file { background:#FFF3E0; color:#d97706; }
.badge-ready { background:var(--green-light); color:var(--green); }
.module-upload-input { display:none; }

