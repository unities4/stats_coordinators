function applyFilters() {
  const savedScrollY = window.scrollY;

  const keSet      = msSelected['KE'];
  const slSet      = msSelected['SL'];
  const bdSet      = msSelected['BD'];
  const coordSet   = msSelected['COORD'];
  const yearSet    = msSelected['YEAR'];
  const monthSet   = msSelected['MONTH'];
  const catSet     = msSelected['CAT'];
  const kindSet    = msSelected['KIND'];
  const regYearSet  = msSelected['REGYEAR'];
  const regMonthSet = msSelected['REGMONTH'];
  const statusSet   = msSelected['STATUS'];

  filteredData = allData.filter(r => {
    if (keSet.size    && !keSet.has(r.ke))            return false;
    if (slSet.size    && !slSet.has(r.serviceLine))    return false;
    if (bdSet.size    && !bdSet.has(r.businessDir))    return false;
    if (coordSet.size && !coordSet.has(r.coordinator)) return false;
    if (statusSet.size && !statusSet.has(r.coordStatus)) return false;
    if (catSet.size   && !catSet.has(r.category))      return false;
    if (kindSet.size  && !kindSet.has(r.kind))         return false;
    if (yearSet.size || monthSet.size) {
      if (!r.dateClose || !(r.dateClose instanceof Date) || isNaN(r.dateClose)) return false;
      if (yearSet.size  && !yearSet.has(String(r.dateClose.getFullYear()))) return false;
      if (monthSet.size && !monthSet.has(`${r.dateClose.getFullYear()}-${String(r.dateClose.getMonth()+1).padStart(2,'0')}`)) return false;
    }
    if (regYearSet.size || regMonthSet.size) {
      if (!r.dateReg || !(r.dateReg instanceof Date) || isNaN(r.dateReg)) return false;
      if (regYearSet.size  && !regYearSet.has(String(r.dateReg.getFullYear()))) return false;
      if (regMonthSet.size && !regMonthSet.has(`${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`)) return false;
    }
    return true;
  });

  // Active chips
  // activeFiltersWrap removed

  document.getElementById('filtersCount').textContent = `Показано ${filteredData.length} из ${allData.length} записей`;
  renderAll();
  updateDependentFilters();
