function tableToSheetData(tableId, sheetName) {
  const cols = TABLE_COLS[tableId];
  if (!cols) return null;
  const visibleCols = cols.filter(c=>c.v);
  if (!visibleCols.length) return null;
  const bodyEl = document.getElementById(tableId);
  if (!bodyEl) return null;
  let tbl;
  if (bodyEl.tagName === 'TBODY') tbl = bodyEl.closest('table');
  else tbl = bodyEl.querySelector('table') || bodyEl.closest('table');
  if (!tbl) return null;
  const rows = [visibleCols.map(c=>c.label)];
  tbl.querySelectorAll('tbody tr').forEach(tr => {
    const tds = [...tr.querySelectorAll('td')];
    const row = [];
    cols.forEach((col,i) => {
      if (!col.v) return;
      const td = tds[i];
      let text = td ? (td.innerText||td.textContent||'').replace(/\s+/g,' ').trim() : '';
      row.push(text);
    });
    if (row.some(v=>v!=='')) rows.push(row);
  });
  return { name: sheetName, data: rows };
}

async function buildAndDownloadExcel(sheets, filename) {
  const filtered = sheets.filter(Boolean);
  if (!filtered.length) return;
  const wb = new ExcelJS.Workbook();
  filtered.forEach(s => {
    const ws = wb.addWorksheet(s.name.slice(0,31));
    // Заголовок
    const headerRow = ws.addRow(s.data[0]);
    headerRow.eachCell(cell => {
      cell.font = { bold: true };
      cell.fill = { type:'pattern', pattern:'solid', fgColor:{argb:'FFEEF2F7'} };
      cell.alignment = { horizontal:'center', vertical:'middle' };
      cell.border = { bottom:{style:'thin', color:{argb:'FFCBD5E1'}} };
    });
    // Данные
    for (let i=1; i<s.data.length; i++) ws.addRow(s.data[i]);
    // Ширина столбцов
    (s.data[0]||[]).forEach((_,ci) => {
      const maxLen = Math.max(...s.data.map(r => String(r[ci]==null?'':r[ci]).length));
      ws.getColumn(ci+1).width = Math.min(50, Math.max(10, maxLen + 2));
    });
  });
  const buf = await wb.xlsx.writeBuffer();
  const blob = new Blob([buf], {type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename + '.xlsx';
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
}

function downloadTableExcel(tableId, sheetName, filename) {
