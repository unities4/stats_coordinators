          <div class="info-val">${docNontypical}</div>
          <div class="info-label">Нетиповых ЗИ</div>
          <div class="card-badge badge-orange">${total ? Math.round(docNontypical/total*100) : 0}%</div>
        </div>
        <div class="info-sep"></div>
        <div class="info-metric">
          <div class="info-val">${docTypical}</div>
          <div class="info-label">Типовых ЗИ</div>
          <div class="card-badge badge-green">${total ? Math.round(docTypical/total*100) : 0}%</div>
        </div>
      </div>
    </div>
    <div class="card card-distrib animate-in" style="grid-column:span 2">
      <div class="distrib-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2" style="flex-shrink:0">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <div class="distrib-title">Срок документирования (кал. дни)</div>
      </div>
      <div class="distrib-segments">
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:${colRColor}">${colRMetricVal.toFixed(0)}</div>
          <div class="distrib-seg2-label">дней (${colRMetricLabel})</div>
          <div class="card-badge badge-blue">${docUseMedian ? 'медиана' : 'среднее'}</div>
        </div>
        <div class="distrib-sep"></div>
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:#d97706">${over6m}</div>
          <div class="distrib-seg2-label">ЗИ свыше 6 мес.</div>
          <div class="card-badge badge-orange">${pct6m}% от общего</div>
        </div>
        <div class="distrib-sep"></div>
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:#dc2626">${over1y}</div>
          <div class="distrib-seg2-label">ЗИ свыше 1 года</div>
          <div class="card-badge badge-red">${pct1y}% от общего</div>
        </div>
      </div>
    </div>`;

  // ── SORT + TABLE ──
  updateDocSortIndicator();
  const s = docSortState;
  const sorted = [...docRows].sort((a, b) => {
    let av = a[s.field], bv = b[s.field];
    if (av instanceof Date && bv instanceof Date) return s.dir === 'asc' ? av - bv : bv - av;
    if (typeof av === 'number') return s.dir === 'asc' ? av - bv : bv - av;
    if (typeof av === 'string') return s.dir === 'asc' ? av.localeCompare(bv, 'ru') : bv.localeCompare(av, 'ru');
    return 0;
  });

  const fmt = d => d ? d.toLocaleDateString('ru-RU') : '—';
  const dayColor = d => d < 0 ? '#dc2626' : d <= 2 ? '#d97706' : '#16a34a';

  const colsCfg = TABLE_COLS['docTableBody'] || [];
  const body = document.getElementById('docTableBody');
  if (!sorted.length) {
    body.innerHTML = `<tr><td colspan="10" style="text-align:center;padding:24px;color:var(--gray-400)">Нет ЗИ, удовлетворяющих условиям фильтра</td></tr>`;
  } else {
    body.innerHTML = sorted.map(r => {
      const dc = dayColor(r.daysLeft);
      const dayLabel = `${r.daysLeft} раб. дней`;
      const firedBadge = r.coordStatus === 'уволен' ? '<span class="badge-fired">Уволен</span>' : '';
      const showDateApprove = colsCfg.find(c=>c.id==='dateApprove')?.v !== false;
      const showColQ = colsCfg.find(c=>c.id==='colQ')?.v !== false;
      return `<tr>
        <td style="font-weight:600;white-space:nowrap">${escHtml(r.num)}</td>
        <td>${escHtml(r.ke)}</td>
        <td>${escHtml(r.coordinator)}${firedBadge}</td>
        <td>${escHtml(r.sl)}</td>
        <td>${escHtml(r.bd)}</td>
        <td>${escHtml(r.category || '')}</td>
        <td>${escHtml(r.kind || '')}</td>
        <td style="white-space:nowrap;display:${showDateApprove?'':'none'}">${fmt(r.dateApprove)}</td>
        <td style="white-space:nowrap;display:${showColQ?'':'none'}">${fmt(r.colQ)}</td>
        <td class="num-cell" style="color:${dc}">${dayLabel}</td>
      </tr>`;
    }).join('');
  }

  document.getElementById('docTableCount').textContent = `${sorted.length} из ${totalAll}`;

  // Apply column visibility
  applyColVisibility('docTableBody');

  // ── BREAKDOWN ──
  renderDocRegDistrib();
  renderDocTopBreakdown();
}

function renderDocRegDistrib() {
  const el = document.getElementById('docRegDistrib');
  if (!el) return;
  const buckets = new Map();
  let noDate = 0;
  _docFiltered.forEach(r => {
    const k = regPeriodKey(r.dateReg, docRegMode);
    if (k === '(не указано)') { noDate++; return; }
    buckets.set(k, (buckets.get(k) || 0) + 1);
  });
  let keys;
  if (docRegMode === 'month' && msSelected['REGMONTH'].size === 0) {
    const dates = _docFiltered.map(r => r.dateReg).filter(d => d instanceof Date && !isNaN(d));
    if (dates.length) {
      let minD = dates.reduce((a,b) => a < b ? a : b);
      let maxD = dates.reduce((a,b) => a > b ? a : b);
      keys = [];
      let y = minD.getFullYear(), m = minD.getMonth() + 1;
      const ey = maxD.getFullYear(), em = maxD.getMonth() + 1;
      while (y < ey || (y === ey && m <= em)) {
        keys.push(`${y}-${String(m).padStart(2,'0')}`);
        m++; if (m > 12) { m = 1; y++; }
      }
    } else keys = [];
  } else {
    keys = [...buckets.keys()].sort((a,b) => a.localeCompare(b));
  }
  if (!keys.length) {
    el.innerHTML = `<div class="hung-empty">Нет данных о дате регистрации${noDate ? ` (${noDate} ЗИ без даты)` : ''}</div>`;
    syncDocChartHeight();
    return;
  }
  const rows = keys.map(k => [k, buckets.get(k) || 0]);
  const maxV = Math.max(...rows.map(r => r[1]), 1);
  const bars = rows.map(([k,v]) => {
    const h = v > 0 ? Math.max(8, Math.round((v/maxV)*100)) : 0;
    const barStyle = v > 0 ? `height:${h}%` : `height:3px;background:var(--gray-200)`;
    const valLabel = v > 0 ? `<div class="rd-bar-val">${v}</div>` : `<div class="rd-bar-val" style="color:var(--gray-400)">0</div>`;
    return `<div class="rd-bar-wrap" title="${escAttr(regPeriodLabel(k,docRegMode))}: ${v}">
      ${valLabel}
      <div class="rd-bar" style="${barStyle}"></div>
      <div class="rd-bar-lbl">${escHtml(regPeriodLabel(k,docRegMode))}</div>
    </div>`;
  }).join('');
  const note = noDate ? `<div class="rd-note">Без даты регистрации: ${noDate}</div>` : '';
  el.innerHTML = `<div class="rd-chart">${bars}</div>${note}`;
  syncDocChartHeight();
}

function renderDocTopBreakdown() {
  const el = document.getElementById('docTopBreakdown');
  if (!el) return;
  const field = docTopDim;
  const buckets = new Map();
  _docFiltered.forEach(r => {
    const k = (r[field] || '').trim() || '(не указано)';
    buckets.set(k, (buckets.get(k) || 0) + 1);
  });
  const rows = [...buckets.entries()].sort((a,b) => b[1]-a[1]).slice(0,10);
  if (!rows.length) { el.innerHTML = `<div class="hung-empty">Нет данных</div>`; syncDocChartHeight(); return; }
  const maxV = rows[0][1];
  el.innerHTML = rows.map(([k,v]) => {
    const w = Math.max(2, Math.round(v/maxV*100));
    return `<div class="tb-row">
      <div class="tb-name" title="${escAttr(k)}">${escHtml(k)}</div>
      <div class="tb-bar-track"><div class="tb-bar-fill" style="width:${w}%"></div></div>
      <div class="tb-val">${v}</div>
    </div>`;
  }).join('');
  syncDocChartHeight();
}

// ── Синхронизация высоты rd-chart для вкладки «Документирование» ──
let _docChartResizeObserver = null;

function syncDocChartHeight() {
  requestAnimationFrame(() => {
    const topEl  = document.getElementById('docTopBreakdown');
    const distEl = document.getElementById('docRegDistrib');
    if (!topEl || !distEl) return;
    const chart = distEl.querySelector('.rd-chart');
    if (!chart) return;
    const targetH = topEl.scrollHeight;
    if (targetH > 0) chart.style.height = targetH + 'px';
  });
}

(function initDocChartSync() {
  function attach() {
    const topEl = document.getElementById('docTopBreakdown');
    if (!topEl) return;
    if (_docChartResizeObserver) _docChartResizeObserver.disconnect();
    _docChartResizeObserver = new ResizeObserver(() => syncDocChartHeight());
    _docChartResizeObserver.observe(topEl);
  }
  document.addEventListener('DOMContentLoaded', attach);
  setTimeout(attach, 800);
})();

</script>

