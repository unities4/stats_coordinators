<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Статистика координаторов ЗИ</title>
<script src="./exceljs.min.js"></script>
<meta http-equiv="Content-Security-Policy" content="default-src 'none'; script-src 'self' file: 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; connect-src 'none'; worker-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'">
<style>

  :root {
    --blue: #004C97;
    --blue-dark: #003570;
    --blue-mid: #005FB5;
    --blue-light: #E8F0FA;
    --blue-faint: #F0F5FC;
    --white: #FFFFFF;
    --gray-100: #F4F6FA;
    --gray-200: #E2E8F0;
    --gray-400: #94A3B8;
    --gray-600: #475569;
    --gray-900: #0F172A;
    --red: #C0392B;
    --red-light: #FDECEA;
    --orange: #E07B00;
    --orange-light: #FFF3E0;
    --green: #1A7A4A;
    --green-light: #E8F5EE;
    --shadow-sm: 0 1px 3px rgba(0,76,151,0.08);
    --shadow-md: 0 4px 16px rgba(0,76,151,0.12);
    --shadow-lg: 0 8px 32px rgba(0,76,151,0.16);
    --radius: 12px;
    --radius-lg: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'PT Sans', 'Segoe UI', Arial, sans-serif;
    background: var(--gray-100);
    color: var(--gray-900);
    min-height: 100vh;
  }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 60%, var(--blue-mid) 100%);
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 280px; height: 280px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
  }
  .header::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 200px;
    width: 180px; height: 180px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }
  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .header-left { display: flex; align-items: center; gap: 16px; }
  .header-logo {
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.15);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.2);
  }
  .header-title {
    font-family: 'Montserrat', 'Segoe UI', Arial, sans-serif;
    font-size: 20px; font-weight: 700;
    color: #fff; letter-spacing: -0.3px;
  }
  .header-subtitle { font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 2px; }
  .header-comment {
    font-size: 12px; color: rgba(255,255,255,0.55);
    margin-top: 4px; min-width: 200px; max-width: 500px;
    outline: none; cursor: text;
    border-bottom: 1px dashed rgba(255,255,255,0.25);
    padding-bottom: 2px; transition: border-color 0.2s;
    white-space: pre-wrap; word-break: break-word;
  }
  .header-comment:empty::before {
    content: 'Добавить примечание к отчёту...';
    color: rgba(255,255,255,0.28);
    pointer-events: none;
  }
  .header-comment:focus {
    border-bottom-color: rgba(255,255,255,0.6);
    color: rgba(255,255,255,0.8);
  }
  @media print {
    .header-comment { color: rgba(255,255,255,0.75) !important; border-bottom: none !important; }
    .header-comment:empty { display: none !important; }
  }
  .header-actions { display: flex; gap: 10px; align-items: center; }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 8px;
    font-family: 'Montserrat', 'Segoe UI', Arial, sans-serif;
    font-size: 13px; font-weight: 600;
    cursor: pointer; border: none; transition: all 0.2s;
  }
  .btn-primary { background: var(--white); color: var(--blue); }
  .btn-primary:hover { background: #E8F0FA; transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .btn-outline { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.3); }
  .btn-outline:hover { background: rgba(255,255,255,0.2); }
  .btn-blue { background: var(--blue); color: #fff; }
  .btn-blue:hover { background: var(--blue-dark); transform: translateY(-1px); box-shadow: var(--shadow-md); }

  .main { max-width: 1400px; margin: 0 auto; padding: 28px 32px 48px; }

  /* UPLOAD ZONE */
  .upload-zone {
    background: var(--white); border: 2px dashed var(--gray-200);
    border-radius: var(--radius-lg); padding: 56px 32px;
    text-align: center; transition: all 0.25s; cursor: pointer;
  }
  .upload-zone.drag-over { border-color: var(--blue); background: var(--blue-faint); }
  .upload-icon {
    width: 64px; height: 64px; background: var(--blue-faint);
    border-radius: 16px; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
  }
  .upload-title { font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 18px; font-weight: 700; color: var(--gray-900); margin-bottom: 8px; }
  .upload-desc { font-size: 14px; color: var(--gray-400); margin-bottom: 20px; }
  .upload-input { display: none; }

  /* CONTROLS */
  .controls-bar {
    background: var(--white); border-radius: var(--radius-lg);
    padding: 20px 24px; margin-bottom: 24px;
    box-shadow: var(--shadow-sm);
    display: flex; gap: 32px; align-items: flex-end; flex-wrap: wrap;
  }
  .control-group { flex: 1; min-width: 200px; }
  .control-label {
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.8px;
    color: var(--gray-400); margin-bottom: 10px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .control-label span {
    font-size: 13px; font-weight: 700; color: var(--blue);
    letter-spacing: 0; text-transform: none;
    background: var(--blue-faint); padding: 2px 8px; border-radius: 20px;
  }
  input[type=range] {
    -webkit-appearance: none; width: 100%; height: 4px;
    background: var(--gray-200); border-radius: 4px; outline: none;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none; width: 18px; height: 18px;
    border-radius: 50%; background: var(--blue); cursor: pointer;
    box-shadow: 0 0 0 3px rgba(0,76,151,0.15); transition: box-shadow 0.2s;
  }
  input[type=range]::-webkit-slider-thumb:hover { box-shadow: 0 0 0 5px rgba(0,76,151,0.2); }
  .toggle-group {
    display: flex; background: var(--gray-100);
    border-radius: 8px; padding: 3px; gap: 2px;
  }
  .toggle-btn {
    flex: 1; padding: 7px 14px; border: none; border-radius: 6px;
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer; background: transparent; color: var(--gray-400); transition: all 0.2s;
  }
  .toggle-btn.active { background: var(--white); color: var(--blue); box-shadow: var(--shadow-sm); }

  /* CARDS */
  .cards-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-bottom: 24px;
  }
  .card {
    background: var(--white); border-radius: var(--radius);
    padding: 20px 22px; box-shadow: var(--shadow-sm);
    position: relative; overflow: hidden;
    border: 1px solid var(--gray-200);
  }
  .card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 3px; background: var(--blue);
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .card.card-red::before { background: var(--red); }
  .card.card-orange::before { background: var(--orange); }
  .card.card-green::before { background: var(--green); }
  .card-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px; background: var(--blue-faint);
  }
  .card-red .card-icon { background: var(--red-light); }
  .card-orange .card-icon { background: var(--orange-light); }
  .card-green .card-icon { background: var(--green-light); }
  .card-value {
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 28px; font-weight: 800; color: var(--gray-900);
    line-height: 1; margin-bottom: 6px;
  }
  .card-metrics {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px; align-items: start;
  }
  .card-metrics.single-metric {
    grid-template-columns: 1fr;
  }
  .card-metric { min-width: 0; }
  .card-metric .card-label { margin-bottom: 0; }
  .card-label { font-size: 13px; color: var(--gray-400); line-height: 1.4; }
  .card-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 8px; border-radius: 20px;
    font-size: 11px; font-weight: 700; margin-top: 8px;
  }
  .badge-red { background: var(--red-light); color: var(--red); }
  .badge-orange { background: var(--orange-light); color: var(--orange); }
  .badge-green { background: var(--green-light); color: var(--green); }
  .badge-blue { background: var(--blue-faint); color: var(--blue); }

  /* CONTENT GRID */
  .content-grid { display: grid; grid-template-columns: 1fr 380px; gap: 20px; margin-bottom: 24px; }

  /* SECTION */
  .section { background: var(--white); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; border: 1px solid var(--gray-200); }
  .section-header {
    padding: 18px 24px; border-bottom: 1px solid var(--gray-200);
    display: flex; align-items: center; justify-content: space-between;
  }
  .section-title {
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 15px; font-weight: 700; color: var(--gray-900);
    display: flex; align-items: center; gap: 8px;
  }
  .section-meta { font-size: 13px; color: var(--gray-400); }

  .filter-tabs {
    display: flex; gap: 6px; padding: 12px 24px;
    border-bottom: 1px solid var(--gray-200); background: var(--gray-100);
  }
  .filter-tab {
    padding: 5px 12px; border-radius: 20px;
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer; border: none; background: transparent;
    color: var(--gray-400); transition: all 0.2s;
    display: flex; align-items: center; gap: 5px;
  }
  .filter-tab.active { background: var(--white); color: var(--blue); box-shadow: var(--shadow-sm); }
  .filter-tab .dot { width: 7px; height: 7px; border-radius: 50%; }

  table { width: 100%; border-collapse: collapse; }
  thead th {
    padding: 11px 16px; text-align: center;
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.6px;
    color: var(--gray-400); background: var(--gray-100);
    border-bottom: 1px solid var(--gray-200);
    white-space: nowrap; cursor: pointer; user-select: none;
  }
  thead th:hover { color: var(--blue); }
  thead th.sorted { color: var(--blue); }
  tbody tr { transition: background 0.15s; }
  tbody tr:hover { background: var(--blue-faint); }
  tbody tr:not(:last-child) td { border-bottom: 1px solid var(--gray-200); }
  td { padding: 12px 16px; font-size: 14px; color: var(--gray-900); vertical-align: middle; text-align: center; }
  td.name-cell {
    font-weight: 600; font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 13px; max-width: 200px; text-align: left;
  }
  td.num-cell { text-align: center; font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-weight: 600; font-size: 14px; }

  .status-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 20px;
    font-family: 'Montserrat','Segoe UI',Arial,sans-serif;
    font-size: 11px; font-weight: 700; white-space: nowrap;
  }
  .status-critical { background: var(--red-light); color: var(--red); }
  .status-risk { background: var(--orange-light); color: var(--orange); }
  .status-ok { background: var(--green-light); color: var(--green); }
  .status-excluded { background: var(--gray-200); color: var(--gray-400); }

  .progress-wrap { display: flex; align-items: center; gap: 8px; }
  .progress-bar { flex: 1; height: 6px; background: var(--gray-200); border-radius: 4px; overflow: hidden; min-width: 60px; }
  .progress-fill { height: 100%; border-radius: 4px; transition: width 0.4s ease; }
  .progress-pct { font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 12px; font-weight: 700; min-width: 36px; text-align: center; }

  .chart-wrap { padding: 20px 24px; }
  .legend { display: flex; gap: 16px; padding: 0 24px 16px; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--gray-600); }
  .legend-dot { width: 10px; height: 10px; border-radius: 3px; }

  .empty-state { text-align: center; padding: 60px 24px; color: var(--gray-400); }
  .empty-title { font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 16px; font-weight: 700; color: var(--gray-600); margin-bottom: 8px; }

  .file-info {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; background: var(--blue-faint);
    border-radius: 8px; margin-bottom: 20px;
    border: 1px solid var(--blue-light);
  }
  .file-info-name { font-family: 'Montserrat','Segoe UI',Arial,sans-serif; font-size: 13px; font-weight: 700; color: var(--blue); }
  .file-info-meta { font-size: 12px; color: var(--gray-400); }

  .notification {
    position: fixed; top: 20px; right: 20px;
    background: var(--white); border-radius: var(--radius);
    padding: 14px 18px; box-shadow: var(--shadow-lg);
    border-left: 4px solid var(--green);
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 600; color: var(--gray-900);
    transform: translateX(120%);
    transition: transform 0.35s cubic-bezier(.2,.8,.3,1);
    z-index: 9999; max-width: 340px;
  }
  .notification.show { transform: translateX(0); }
  .notification.error { border-color: var(--red); }

  /* Print-only params summary */
  .print-params { display: none; }
  @media print {
    .print-params {
      display: block !important;
      margin-bottom: 16px;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .print-params-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
    .print-param-item {
      background: #f4f7fc;
      border: 1px solid #c8d6e8;
      border-left: 3px solid #004C97;
      border-radius: 8px;
      padding: 10px 14px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .print-param-label {
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #6b7a99;
    }
    .print-param-val {
      font-family: 'Montserrat', 'Segoe UI', Arial, sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: #004C97;
      line-height: 1;
    }
    .print-param-toggle {
      display: flex;
      gap: 4px;
      margin-top: 1px;
    }
    .print-param-toggle-btn {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 4px;
      background: #e2e8f0;
      color: #94a3b8;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .print-param-toggle-btn.pptb-active {
      background: #004C97;
      color: #fff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }

  .sort-icon { font-size: 10px; margin-left: 4px; opacity: 0.4; }
  .sort-icon.asc::after { content: '▲'; }
  .sort-icon.desc::after { content: '▼'; }

  /* ===================== PRINT STYLES ===================== */
  @media print {
    @page { size: A4 landscape; margin: 0; }

    /* Hide interactive elements */
    .header-actions,
    .upload-zone,
    .controls-bar,
    .filter-tabs,
    .no-print,
    .notification,
    #uploadZone,
    .file-info { display: none !important; }

    /* Скрываем браузерные колонтитулы (дата и URL) через size */
    html { margin: 0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    body {
      margin: 0 !important;
      background: white !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    * {
      -webkit-user-select: text !important;
      user-select: text !important;
    }
    .main { padding: 12mm 15mm 8mm 15mm !important; }

    /* Header visible in print */
    .header {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      margin-bottom: 16px;
    }

    /* Cards on first page — visible with borders, 4 per row */
    .cards-grid {
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 12px !important;
      break-after: avoid;
      margin-bottom: 16px !important;
    }
    .card {
      border: 1.5px solid #b0bec5 !important;
      box-shadow: none !important;
      break-inside: avoid;
      background: white !important;
      padding: 14px 16px !important;
    }
    .card-value { font-size: 22px !important; }
    .card::before { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .card-icon { -webkit-print-color-adjust: exact; print-color-adjust: exact; margin-bottom: 8px !important; }

    /* Controls bar values — show in print as summary */
    .controls-bar { display: none !important; }

    /* Table starts on new page with padding */
    .content-grid {
      break-before: page;
      display: block !important;
      padding-top: 14px !important;
      padding-bottom: 14px !important;
    }
    .section { box-shadow: none !important; border: 1px solid var(--gray-200) !important; margin-bottom: 16px; }

    /* Right panel (chart) hidden in print, table takes full width */
    .content-grid > .section:last-child { display: none !important; }
    .content-grid > .section:first-child { width: 100% !important; }

    table { page-break-inside: auto; }
    tr { break-inside: avoid; }
    thead { display: table-header-group; }

    /* Progress fills in print */
    .progress-fill { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .status-badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .badge-red, .badge-orange, .badge-green, .badge-blue { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }

  @keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .animate-in { animation: fadeInUp 0.4s ease forwards; opacity: 0; }
  .animate-in:nth-child(1) { animation-delay: 0.05s; }
  .animate-in:nth-child(2) { animation-delay: 0.10s; }
  .animate-in:nth-child(3) { animation-delay: 0.15s; }
  .animate-in:nth-child(4) { animation-delay: 0.20s; }

  @media (max-width: 1100px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
    .content-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .header-inner { padding: 16px; }
    .main { padding: 16px; }
    .cards-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <div class="header-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="7" height="7" rx="1.5" fill="white" opacity="0.9"/>
          <rect x="14" y="3" width="7" height="7" rx="1.5" fill="white" opacity="0.6"/>
          <rect x="3" y="14" width="7" height="7" rx="1.5" fill="white" opacity="0.6"/>
          <rect x="14" y="14" width="7" height="7" rx="1.5" fill="white" opacity="0.9"/>
        </svg>
      </div>
      <div>
        <div class="header-title">Статистика координаторов ЗИ</div>
        <div class="header-subtitle" id="reportDate">Загрузите файл для анализа</div>
        <div class="header-comment" id="reportComment" contenteditable="plaintext-only" spellcheck="false"></div>
      </div>
    </div>
    <div class="header-actions">
      <button class="btn btn-outline no-print" onclick="document.getElementById('fileInput').click()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
        </svg>
        Загрузить файл
      </button>
      <button class="btn btn-primary no-print" onclick="exportPDF()" id="btnExport" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Скачать PDF
      </button>
    </div>
  </div>
</header>

<input type="file" id="fileInput" class="upload-input" accept=".xlsx,.xls">

<main class="main">

  <div class="upload-zone" id="uploadZone">
    <div class="upload-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2">
