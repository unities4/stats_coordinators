// ====== DEPENDENT FILTER GREYING ======
function updateDependentFilters() {
  if (!allData.length && !hungData.length) return;

  // All filter keys and how to extract their value from a record
  const keys = ['KE','SL','BD','COORD','YEAR','MONTH','CAT','KIND','REGYEAR','REGMONTH','STATUS'];
  function getVal(r, k) {
    if (k==='KE')    return r.ke;
    if (k==='SL')    return r.serviceLine;
    if (k==='BD')    return r.businessDir;
    if (k==='COORD') return r.coordinator;
    if (k==='CAT')   return r.category;
    if (k==='KIND')  return r.kind;
    if (k==='YEAR') {
      if (!r.dateClose||!(r.dateClose instanceof Date)||isNaN(r.dateClose)) return null;
      return String(r.dateClose.getFullYear());
    }
    if (k==='MONTH') {
      if (!r.dateClose||!(r.dateClose instanceof Date)||isNaN(r.dateClose)) return null;
      return `${r.dateClose.getFullYear()}-${String(r.dateClose.getMonth()+1).padStart(2,'0')}`;
    }
    if (k==='REGYEAR') {
      if (!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
      return String(r.dateReg.getFullYear());
    }
    if (k==='REGMONTH') {
      if (!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
      return `${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`;
    }
    if (k==='STATUS') return r.coordStatus || null;
  }

  // Объединяем allData и hungData для корректного отображения доступных опций
  function getHungVal(r, k) {
    if (k==='KE')    return r.ke;
    if (k==='SL')    return r.sl;
    if (k==='BD')    return r.bd;
    if (k==='COORD') return r.coordinator;
    if (k==='CAT')   return r.category;
    if (k==='KIND')  return r.kind;
    if (k==='YEAR'||k==='MONTH') return null; // нет дат закрытия в подвисших
    if (k==='REGYEAR') {
      if (!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
      return String(r.dateReg.getFullYear());
    }
    if (k==='REGMONTH') {
      if (!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
      return `${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`;
    }
    if (k==='STATUS') return r.coordStatus || null;
    return null;
  }

  keys.forEach(targetKey => {
    const available = new Set();
    // Из allData
    allData.forEach(r => {
      for (const k of keys) {
        if (k === targetKey) continue;
        if (msSelected[k].size) {
          const v = getVal(r, k);
          if (!v || !msSelected[k].has(v)) return;
        }
      }
      const v = getVal(r, targetKey);
      if (v) available.add(v);
    });
    // Из hungData
    hungData.forEach(r => {
      for (const k of keys) {
        if (k === targetKey) continue;
        if (msSelected[k].size) {
          const v = getHungVal(r, k);
          if (!v || !msSelected[k].has(v)) return;
        }
      }
      const v = getHungVal(r, targetKey);
      if (v) available.add(v);
    });

    const container = document.getElementById('msOptions'+targetKey);
    if (!container) return;
    container.querySelectorAll('.ms-option').forEach(optEl => {
      const cb = optEl.querySelector('input[type=checkbox]');
      if (!cb) return;
      const val = cb.dataset.val;
      const isAvail = available.has(val);
      const isSelected = msSelected[targetKey] && msSelected[targetKey].has(val);
      // Выбранные опции никогда не блокируем — иначе снять галочку невозможно
      const canInteract = isAvail || isSelected;
      cb.disabled = !canInteract;
      optEl.style.opacity = canInteract ? '' : '0.35';
      optEl.style.pointerEvents = canInteract ? '' : 'none';
    });
    // Re-sort: available on top
    const opts = [...container.querySelectorAll('.ms-option')];
    opts.sort((a,b)=>(available.has(a.querySelector('input').dataset.val)?0:1)-(available.has(b.querySelector('input').dataset.val)?0:1));
    opts.forEach(o => container.appendChild(o));
  });
}
function renderCharts(stats) {
  const critical=stats.filter(s=>s.status==='critical').length;
  const risk=stats.filter(s=>s.status==='risk').length;
  const ok=stats.filter(s=>s.status==='ok').length;
