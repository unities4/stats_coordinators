// ── Синхронизация высоты rd-chart по высоте контента топ-блока ──
let _rdChartResizeObserver = null;

function syncRdChartHeight() {
  // Откладываем на следующий кадр, чтобы DOM успел отрисоваться
  requestAnimationFrame(() => {
    const topEl  = document.getElementById('hungTopBreakdown');
    const distEl = document.getElementById('hungRegDistrib');
    if (!topEl || !distEl) return;

    const chart = distEl.querySelector('.rd-chart');
    if (!chart) return;

    // Высота контента топ-блока (все tb-row + возможный hung-empty)
    const targetH = topEl.scrollHeight;
    if (targetH > 0) {
      chart.style.height = targetH + 'px';
    }
  });
}

// ResizeObserver: следим за топ-блоком и при любом изменении его высоты
// пересчитываем rd-chart (сворачивание секций, изменение окна и т.д.)
(function initRdChartSync() {
  function attach() {
    const topEl = document.getElementById('hungTopBreakdown');
    if (!topEl) return;
    if (_rdChartResizeObserver) _rdChartResizeObserver.disconnect();
    _rdChartResizeObserver = new ResizeObserver(() => syncRdChartHeight());
    _rdChartResizeObserver.observe(topEl);
  }
  // Вызываем при загрузке и после возможной динамической перерисовки
  document.addEventListener('DOMContentLoaded', attach);
  setTimeout(attach, 600);
})();

function renderHungPage() {
  const today = new Date();
  today.setHours(0,0,0,0);

  const hungDays = params.days; // Единый регламентный срок из настроек/controls-bar
  const rejDays  = parseInt(document.getElementById('sliderHungRej').value) || 5;

  // Apply shared filters (KE, SL, BD, COORD, CAT, KIND, REGYEAR, REGMONTH)
  function rowMatchesFilters(r) {
    if (msSelected['KE'].size    && !msSelected['KE'].has(r.ke))            return false;
    if (msSelected['SL'].size    && !msSelected['SL'].has(r.sl))            return false;
    if (msSelected['BD'].size    && !msSelected['BD'].has(r.bd))            return false;
    if (msSelected['COORD'].size && !msSelected['COORD'].has(r.coordinator)) return false;
    if (msSelected['STATUS'].size && !msSelected['STATUS'].has(r.coordStatus)) return false;
    if (msSelected['CAT'].size   && !msSelected['CAT'].has(r.category))     return false;
    if (msSelected['KIND'].size  && !msSelected['KIND'].has(r.kind))        return false;
    if (msSelected['REGYEAR'].size || msSelected['REGMONTH'].size) {
      if (!r.dateReg || !(r.dateReg instanceof Date) || isNaN(r.dateReg))   return false;
      if (msSelected['REGYEAR'].size  && !msSelected['REGYEAR'].has(String(r.dateReg.getFullYear())))                                                                           return false;
      if (msSelected['REGMONTH'].size && !msSelected['REGMONTH'].has(`${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`))                           return false;
    }
    return true;
  }

  // Block 1: Утверждено + max(dateApprove, dateRZ) + N раб. дней < сегодня
  // Просрочка начинается со следующего рабочего дня ПОСЛЕ дедлайна (> , не >=)
  const approved = hungData
    .filter(r => r.status === 'Утверждение документации' && r.approval === 'Утверждено' && rowMatchesFilters(r))
    .map(r => {
      // Берём наибольшую из дат: Дата последнего согласования (L) и Дата закрытия РЗ (M)
      let base = r.dateApprove;
      if (r.dateRZ && r.dateApprove) {
        base = r.dateRZ > r.dateApprove ? r.dateRZ : r.dateApprove;
      } else if (r.dateRZ) {
        base = r.dateRZ;
      }
      const deadline = addWorkDays(base, hungDays);
      // ЗИ просрочено только если сегодня > дедлайна (в день дедлайна ещё не просрочено)
      const overdue = (deadline && today > deadline) ? countWorkDays(deadline, today) : 0;
      return { ...r, base, deadline, overdueDays: overdue };
    })
    .filter(r => r.overdueDays > 0);

  // Block 2: Запрошено + срок выполнения согласования < сегодня
  const requested = hungData
    .filter(r => r.status === 'Утверждение документации' && r.approval === 'Запрошено' && rowMatchesFilters(r))
    .filter(r => {
      if (!r.deadline) return false;
      const dl = new Date(r.deadline); dl.setHours(0,0,0,0);
      return dl < today;
    })
    .map(r => {
      const dl = new Date(r.deadline); dl.setHours(0,0,0,0);
      const overdueDays = countWorkDays(dl, today);
      return { ...r, overdueDays };
    });

  // Block 3: Отклонено + дата посл. согласования + N раб. дней < сегодня
  const rejected = hungData
    .filter(r => r.status === 'Утверждение документации' && r.approval === 'Отклонено' && rowMatchesFilters(r))
    .map(r => {
      const limitDate = addWorkDays(r.dateApprove, rejDays);
      // daysSince = рабочие дни от даты отклонения (L) до сегодня (без слайдера)
      const daysSince = r.dateApprove ? countWorkDays(r.dateApprove, today) : 0;
      return { ...r, limitDate, daysSince };
    })
    .filter(r => {
      // В таблицу попадает только если прошло больше rejDays рабочих дней
      if (!r.limitDate) return false;
      return today > r.limitDate;
    });

  // Cards
  const cntAppr   = approved.length;
  const cntReq    = requested.length;
  const cntRej    = rejected.length;
  const totalHung = cntAppr + cntReq + cntRej;

  // Для карточки 1
  const hungFiltered = [...approved, ...requested, ...rejected];
  const hungNontypical = hungFiltered.filter(r => r.kind === 'Нетиповой').length;
  const hungTypical    = hungFiltered.filter(r => r.kind === 'Типовой').length;

  // Для карточки 2: макс и среднее дней просрочки по каждому блоку
  function calcStats(rows, field) {
    const vals = rows.map(r => r[field] || 0).filter(v => v > 0).sort((a,b)=>a-b);
    if (!vals.length) return { max: 0, avg: 0, med: 0 };
    const max = Math.max(...vals);
    const avg = Math.round(vals.reduce((s,v)=>s+v,0)/vals.length);
    const mid = Math.floor(vals.length/2);
    const med = vals.length%2 ? vals[mid] : Math.round((vals[mid-1]+vals[mid])/2);
    return { max, avg, med };
  }
  const apprStats = calcStats(approved,  'overdueDays');
  const reqStats  = calcStats(requested, 'overdueDays');
  const rejStats  = calcStats(rejected,  'daysSince');
  const apprVal = hungUseMedian ? apprStats.med : apprStats.avg;
  const reqVal  = hungUseMedian ? reqStats.med  : reqStats.avg;
  const rejVal  = hungUseMedian ? rejStats.med  : rejStats.avg;
  const hungDayLabel = hungUseMedian ? 'мед.' : 'ср.';

  document.getElementById('hungCardsGrid').innerHTML = `
    <div class="card card-info animate-in" style="grid-column:span 2">
      <div class="distrib-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2" style="flex-shrink:0">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
          <rect x="9" y="3" width="6" height="4" rx="1"/>
          <line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
        </svg>
        <div class="distrib-title">Общая информация</div>
      </div>
      <div class="info-metrics">
        <div class="info-metric">
          <div class="info-val">${totalHung}</div>
          <div class="info-label">Всего ЗИ</div>
          <div class="card-badge badge-blue">${new Set(hungFiltered.map(r=>r.ke).filter(Boolean)).size} ИТ-систем</div>
        </div>
        <div class="info-sep"></div>
        <div class="info-metric">
          <div class="info-val">${new Set(hungFiltered.map(r=>r.coordinator).filter(Boolean)).size}</div>
          <div class="info-label">Координаторов</div>
          <div class="card-badge badge-blue">затронуто</div>
        </div>
        <div class="info-sep"></div>
        <div class="info-metric">
          <div class="info-val">${hungNontypical}</div>
          <div class="info-label">Нетиповых ЗИ</div>
          <div class="card-badge badge-orange">${totalHung ? Math.round(hungNontypical/totalHung*100) : 0}%</div>
        </div>
        <div class="info-sep"></div>
        <div class="info-metric">
          <div class="info-val">${hungTypical}</div>
          <div class="info-label">Типовых ЗИ</div>
          <div class="card-badge badge-green">${totalHung ? Math.round(hungTypical/totalHung*100) : 0}%</div>
        </div>
      </div>
    </div>
    <div class="card card-distrib animate-in" style="grid-column:span 2">
      <div class="distrib-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2" style="flex-shrink:0">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <div class="distrib-title">Распределение по статусу утверждения</div>
      </div>
      <div class="distrib-segments">
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:#dc2626">${approved.length}</div>
          <div class="distrib-seg2-label">Утверждено</div>
          <div class="card-badge badge-red">${hungDayLabel} ${apprVal} раб. дн.</div>
        </div>
        <div class="distrib-sep"></div>
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:#d97706">${requested.length}</div>
          <div class="distrib-seg2-label">Запрошено</div>
          <div class="card-badge badge-orange">${hungDayLabel} ${reqVal} раб. дн.</div>
        </div>
        <div class="distrib-sep"></div>
        <div class="distrib-seg2">
          <div class="distrib-seg2-val" style="color:#6d28d9">${rejected.length}</div>
          <div class="distrib-seg2-label">Отклонено</div>
          <div class="card-badge" style="background:#ede9fe;color:#6d28d9">${hungDayLabel} ${rejVal} раб. дн.</div>
        </div>
      </div>
    </div>`;

  // m = всего ЗИ с соответствующим статусом утверждения (с учётом фильтров)
  const totApprStatus = hungData.filter(r => r.status === 'Утверждение документации' && r.approval === 'Утверждено' && rowMatchesFilters(r)).length;
  const totReqStatus  = hungData.filter(r => r.status === 'Утверждение документации' && r.approval === 'Запрошено'  && rowMatchesFilters(r)).length;
  const totRejStatus  = hungData.filter(r => r.status === 'Утверждение документации' && r.approval === 'Отклонено'  && rowMatchesFilters(r)).length;
  document.getElementById('hungApprovedCount').textContent  = `${approved.length} из ${totApprStatus}`;
  document.getElementById('hungRequestedCount').textContent = `${requested.length} из ${totReqStatus}`;
  document.getElementById('hungRejectedCount').textContent  = `${rejected.length} из ${totRejStatus}`;

  renderHungTable('approved',  approved,  'hungApprovedBody');
  renderHungTable('requested', requested, 'hungRequestedBody');
  renderHungTable('rejected',  rejected,  'hungRejectedBody');

  // Карточки распределения и топ-разбивки строятся по тому же отфильтрованному набору
  _hungFiltered = hungFiltered;
  renderHungRegDistrib();
  renderHungTopBreakdown();
}

function renderHungTable(block, rows, bodyId) {
  const s = hungSortState[block];
  updateHungSortIndicator(block);
  const sorted = [...rows].sort((a,b) => {
    let av = a[s.field], bv = b[s.field];
    if (av instanceof Date && bv instanceof Date) return s.dir==='asc' ? av-bv : bv-av;
    if (typeof av === 'number') return s.dir==='asc' ? av-bv : bv-av;
    if (typeof av === 'string') return s.dir==='asc' ? av.localeCompare(bv,'ru') : bv.localeCompare(av,'ru');
    return 0;
  });

  const fmt = d => d ? d.toLocaleDateString('ru-RU') : '—';

  const makeRow = r => {
    const dayColor = d => d > 10 ? '#dc2626' : d > 3 ? '#d97706' : '#16a34a';
    const firedBadge = r.coordStatus === 'уволен' ? '<span class="badge-fired">Уволен</span>' : '';
    const colsCfg = TABLE_COLS[bodyId] || [];
    const showManager = colsCfg.find(c=>c.id==='manager')?.v;
    const managerTd = `<td style="display:${showManager?'':'none'}">${escHtml(r.coordManager||'—')}</td>`;
    let specific = '';
    if (block === 'approved') {
      const d = r.overdueDays;
      specific = `<td class="num-cell" style="color:${dayColor(d)}">${d} раб. дн.</td>`;
    } else if (block === 'requested') {
      const dReq = r.overdueDays || 0;
      specific = `<td style="white-space:nowrap">${fmt(r.deadline)}</td><td class="num-cell" style="color:${dayColor(dReq)}">${dReq} раб. дн.</td>`;
    } else {
      const d = r.daysSince;
      specific = `<td class="num-cell" style="color:${dayColor(d)}">${d} раб. дн.</td>`;
    }
    return `<tr>
      <td style="font-weight:600;white-space:nowrap">${escHtml(r.num)}</td>
      <td>${escHtml(r.ke)}</td>
      <td>${escHtml(r.coordinator)}${firedBadge}</td>
      <td>${escHtml(r.sl)}</td>
      <td>${escHtml(r.bd)}</td>
      <td>${escHtml(r.category||'')}</td>
      <td>${escHtml(r.kind||'')}</td>
      <td style="white-space:nowrap">${fmt(r.dateApprove)}</td>
      ${specific}${managerTd}
    </tr>`;
  };

  const body = document.getElementById(bodyId);
  if (!sorted.length) {
    body.innerHTML = `<tr><td colspan="10" style="text-align:center;padding:24px;color:var(--gray-400)">Нет данных по заданным условиям</td></tr>`;
  } else {
    body.innerHTML = sorted.map(makeRow).join('');
  }
}

function sortHung(block, field) {
  const s = hungSortState[block];
  if (s.field === field) s.dir = s.dir === 'asc' ? 'desc' : 'asc';
  else { s.field = field; s.dir = 'desc'; }
  renderHungPage();
}

function updateHungSortIndicator(block) {
  const s = hungSortState[block];
  // Найти все th этого блока по id-префиксу
  document.querySelectorAll(`th[id^="hungth-${block}-"]`).forEach(th=>{
    const si=th.querySelector('.sort-icon'); if(si)si.className='sort-icon'; th.classList.remove('sorted');
  });
  const activeTh = document.getElementById(`hungth-${block}-${s.field}`);
  if(activeTh){ activeTh.classList.add('sorted'); const si=activeTh.querySelector('.sort-icon'); if(si)si.className='sort-icon '+s.dir; }
}

