    buckets.set(k, (buckets.get(k) || 0) + 1);
  });
  const rows = [...buckets.entries()].sort((a,b) => b[1] - a[1]).slice(0, 10);
  if (!rows.length) { el.innerHTML = `<div class="hung-empty">Нет данных</div>`; syncRdChartHeight(); return; }
  const maxV = rows[0][1];
  el.innerHTML = rows.map(([k,v]) => {
