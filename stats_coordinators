function toggleColPicker(tableId, btn) {
  document.querySelectorAll('.col-picker-dropdown.open').forEach(d => {
    if (d.dataset.tblid !== tableId) d.classList.remove('open');
  });
  const pickerId = 'colPicker_' + tableId;
  let picker = document.getElementById(pickerId);
  if (!picker) {
    picker = buildColPicker(tableId);
    // Append to body so fixed positioning works correctly
    document.body.appendChild(picker);
  }
  picker.classList.toggle('open');
  // Smart positioning: fixed relative to button; flip upward if near bottom
  if (picker.classList.contains('open')) {
    const r = btn.getBoundingClientRect();
    picker.style.position = 'fixed';
    picker.style.left = 'auto';
    picker.style.right = (window.innerWidth - r.right) + 'px';
    picker.style.zIndex = '4000';
    picker.style.bottom = 'auto';
    picker.style.top = 'auto';
    // Temporarily place below to measure height
    picker.style.top = (r.bottom + 6) + 'px';
    // After paint, check if dropdown fits below; if not, flip above
    requestAnimationFrame(() => {
      const ph = picker.offsetHeight || 200;
      const spaceBelow = window.innerHeight - r.bottom - 10;
      const spaceAbove = r.top - 10;
      if (ph > spaceBelow && spaceAbove > spaceBelow) {
        // Flip: show above the button
        picker.style.top = Math.max(8, r.top - ph - 6) + 'px';
      } else {
        picker.style.top = (r.bottom + 6) + 'px';
      }
    });
  }
}

function buildColPicker(tableId) {
  const cols = TABLE_COLS[tableId] || [];
  const div = document.createElement('div');
  div.className = 'col-picker-dropdown';
  div.id = 'colPicker_' + tableId;
  div.dataset.tblid = tableId;
  // Actions bar (select all / deselect all)
  const actBar = `<div style="padding:6px 10px 4px;border-bottom:1px solid var(--gray-200);display:flex;gap:6px;background:var(--white);border-radius:10px 10px 0 0">
    <button class="ms-act-btn" onclick="colPickerSelectAll('${tableId}')">Все</button>
    <button class="ms-act-btn" onclick="colPickerClearAll('${tableId}')">Снять все</button>
  </div>`;
  const items = cols.map((c,i) => `
    <label class="col-picker-item">
      <input type="checkbox" ${c.v?'checked':''} onchange="onColToggle('${tableId}',${i},this.checked)">
      ${c.label}
    </label>`).join('');
  div.innerHTML = actBar + `<div style="max-height:280px;overflow-y:auto;">${items}</div>`;
  return div;
}

function colPickerSelectAll(tableId) {
  const cols = TABLE_COLS[tableId] || [];
