const RU_MONTHS_SHORT = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];

function regPeriodKey(d, mode) {
  if (!d || !(d instanceof Date) || isNaN(d)) return '(не указано)';
  const y = d.getFullYear(), m = d.getMonth();
  if (mode === 'year')    return String(y);
  if (mode === 'quarter') return `${y}-Q${Math.floor(m/3)+1}`;
  return `${y}-${String(m+1).padStart(2,'0')}`;
}
function regPeriodLabel(key, mode) {
  if (mode === 'year') return key;
  if (mode === 'quarter') { const [y,q] = key.split('-Q'); return `${q} кв. ${y}`; }
  const [y,mm] = key.split('-'); return `${RU_MONTHS_SHORT[parseInt(mm,10)-1]} ${y}`;
}

