      </button>
      <button class="btn btn-outline no-print" onclick="downloadPageExcel()" id="btnExportExcel" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Скачать Excel
      </button>
      <button class="btn btn-primary no-print" onclick="window.print()" id="btnExport" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Скачать PDF
      </button>
    </div>
  </div>
</header>

<input type="file" id="fileInput"  accept=".xlsx" style="display:none">
<input type="file" id="fileInput2" accept=".xlsx" style="display:none">

<!-- SETTINGS PANEL -->
<div class="settings-overlay no-print" id="settingsOverlay">
  <div class="settings-backdrop" onclick="toggleSettings()"></div>
  <div class="settings-panel">
    <div class="settings-header">
      <div class="settings-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:6px"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Настройки
      </div>
      <button class="settings-close" onclick="toggleSettings()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="settings-body">
      <div>
        <div class="settings-section-label">Регламентный срок</div>
        <div class="settings-control">
          <label>Регламентный срок закрытия (раб. дн.) <span id="valDays">1</span></label>
          <input type="range" id="sliderDays" min="1" max="30" value="1" step="1">
        </div>
      </div>
      <div>
        <div class="settings-section-label">Праздничные и нерабочие дни</div>
        <div style="font-size:12px;color:var(--gray-400);margin-bottom:10px;line-height:1.5">
          Даты встроены в систему и применяются при расчёте рабочих дней во всех модулях.
        </div>
        <button class="btn btn-outline" style="color:var(--blue);border-color:var(--blue);width:100%;justify-content:center;font-size:12px" onclick="toggleHolidayList()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Просмотреть даты
        </button>
        <div id="holidayListWrap" style="display:none;margin-top:12px;max-height:320px;overflow-y:auto;border:1px solid var(--gray-200);border-radius:8px">
          <table style="width:100%;border-collapse:collapse;font-size:12px">
            <thead><tr style="background:var(--gray-100);position:sticky;top:0">
              <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--gray-600);border-bottom:1px solid var(--gray-200)">Дата</th>
              <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--gray-600);border-bottom:1px solid var(--gray-200)">День недели</th>
            </tr></thead>
            <tbody id="holidayListBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<nav class="tabs-bar" id="tabsBar" style="display:none">
  <div class="tabs-inner">
    <!-- Группа: первые две вкладки объединены горизонтальной чертой сверху -->
