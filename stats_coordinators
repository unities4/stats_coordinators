}
function drawDonut(values,colors,labels) {
  const canvas=document.getElementById('chartDonut');
  if (!canvas) return;
  const ctx=canvas.getContext('2d');
  const W=canvas.offsetWidth||300;
  canvas.width=W;canvas.height=220;
  ctx.clearRect(0,0,W,220);
  const total=values.reduce((a,b)=>a+b,0);
  if(!total)return;
  const cx=W/2,cy=105,r=80,ri=52;
  let angle=-Math.PI/2;
  values.forEach((v,i)=>{if(!v)return;const slice=(v/total)*2*Math.PI;ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,angle,angle+slice);ctx.closePath();ctx.fillStyle=colors[i];ctx.fill();angle+=slice;});
  ctx.beginPath();ctx.arc(cx,cy,ri,0,2*Math.PI);ctx.fillStyle='#fff';ctx.fill();
  ctx.fillStyle='#0F172A';ctx.font='bold 26px Montserrat,Segoe UI,Arial,sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(total,cx,cy-8);
  ctx.font='12px PT Sans,Segoe UI,Arial,sans-serif';ctx.fillStyle='#94A3B8';ctx.fillText('координаторов',cx,cy+14);
  document.getElementById('chartLegend').innerHTML=values.map((v,i)=>`<div class="legend-item"><div class="legend-dot" style="background:${colors[i]}"></div>${labels[i]}: <strong>${v}</strong></div>`).join('');
}

