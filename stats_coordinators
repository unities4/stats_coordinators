<main class="main">
  <!-- START SCREEN -->
  <div id="startScreen" class="start-screen">
    <div class="start-screen-title">Выберите модуль для работы</div>
    <div class="start-screen-sub">Загрузите файл данных для нужного модуля. Доступны все модули одновременно.</div>
    <div class="module-cards" id="moduleCards">

      <div class="module-card" id="moduleStats" onclick="document.getElementById('fileInput').click()">
        <div class="module-icon module-icon-blue">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
        </div>
        <div class="module-card-title">Статистика по закрытию ЗИ</div>
        <div class="module-card-desc">Анализ просроченных ЗИ, динамика, сравнение периодов</div>
        <span class="module-card-badge badge-need-file" id="badgeStats">Нужен файл</span>
      </div>

      <div class="module-card" id="moduleHung" onclick="document.getElementById('fileInput2').click()">
        <div class="module-icon module-icon-orange">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div class="module-card-title">Подвисшие ЗИ</div>
        <div class="module-card-desc">Утверждённые, запрошенные и отклонённые незакрытые ЗИ</div>
        <span class="module-card-badge badge-need-file" id="badgeHung">Нужен файл</span>
      </div>

    </div>
  </div>

  <!-- UPLOAD ZONE (legacy, hidden) -->
  <div class="upload-zone" id="uploadZone" style="display:none">
    <div class="upload-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#004C97" stroke-width="2">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
    </div>
    <div class="upload-title">Загрузите Excel-файл со статистикой</div>
    <div class="upload-desc">Формат .xlsx · Лист «Изменение»</div>
    <button class="btn btn-blue" id="btnUploadZone">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      Выбрать файл
    </button>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" style="display:none">


      <!-- FILTERS -->
      <div class="filters-bar no-print" id="filtersBar">
        <!-- Ряд 1: КЕ | Сервисная линия | Бизнес-направление -->
        <div class="filters-row">
          <div class="filter-group fg-wide">
            <div class="filter-label">КЕ</div>
            <div class="ms-wrap" id="msWrapKE">
              <button class="ms-trigger" id="msTriggerKE" onclick="toggleMs('KE')">
                <span class="ms-trigger-text" id="msTriggerTextKE">Все КЕ</span>
                <span class="ms-trigger-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>
              </button>
              <div class="ms-dropdown" id="msDropKE">
                <div class="ms-search"><input type="text" placeholder="Поиск..." oninput="filterMsOptions('KE',this.value)"></div><div id="msOptionsKE"></div>
                <div class="ms-actions"><button class="ms-act-btn" onclick="selectAllMs('KE')">Все</button><button class="ms-act-btn" onclick="clearMs('KE')">Сбросить</button></div>
              </div>
            </div>
          </div>
          <div class="filter-group fg-wide">
            <div class="filter-label">Сервисная линия</div>
            <div class="ms-wrap" id="msWrapSL">
              <button class="ms-trigger" id="msTriggerSL" onclick="toggleMs('SL')">
                <span class="ms-trigger-text" id="msTriggerTextSL">Все линии</span>
                <span class="ms-trigger-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>
              </button>
              <div class="ms-dropdown" id="msDropSL">
                <div class="ms-search"><input type="text" placeholder="Поиск..." oninput="filterMsOptions('SL',this.value)"></div><div id="msOptionsSL"></div>
                <div class="ms-actions"><button class="ms-act-btn" onclick="selectAllMs('SL')">Все</button><button class="ms-act-btn" onclick="clearMs('SL')">Сбросить</button></div>
              </div>
            </div>
          </div>
          <div class="filter-group fg-wide">
            <div class="filter-label">Бизнес-направление</div>
            <div class="ms-wrap" id="msWrapBD">
              <button class="ms-trigger" id="msTriggerBD" onclick="toggleMs('BD')">
                <span class="ms-trigger-text" id="msTriggerTextBD">Все направления</span>
                <span class="ms-trigger-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>
              </button>
              <div class="ms-dropdown" id="msDropBD">
                <div class="ms-search"><input type="text" placeholder="Поиск..." oninput="filterMsOptions('BD',this.value)"></div><div id="msOptionsBD"></div>
                <div class="ms-actions"><button class="ms-act-btn" onclick="selectAllMs('BD')">Все</button><button class="ms-act-btn" onclick="clearMs('BD')">Сбросить</button></div>
              </div>
            </div>
          </div>
          <!-- Сбросить всё — в первой строке, высота как у фильтров -->
          <div class="filter-group" style="align-self:flex-end;flex:0 0 auto">
            <button class="btn-reset" onclick="resetFilters()" style="min-height:38px;align-self:flex-start;white-space:nowrap">Сбросить всё</button>
          </div>
        </div>
        <!-- Ряд 2: Координатор | Категория | Вид ЗИ | Год закрытия | Месяц закрытия | Год регистрации | Месяц регистрации | Состояние -->
        <div class="filters-row" style="margin-top:10px">
          <div class="filter-group fg-cat">
            <div class="filter-label">Координатор ЗИ</div>
            <div class="ms-wrap" id="msWrapCOORD">
              <button class="ms-trigger" id="msTriggerCOORD" onclick="toggleMs('COORD')">
                <span class="ms-trigger-text" id="msTriggerTextCOORD">Все координаторы</span>
                <span class="ms-trigger-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>
              </button>
              <div class="ms-dropdown" id="msDropCOORD">
                <div class="ms-search"><input type="text" placeholder="Поиск..." oninput="filterMsOptions('COORD',this.value)"></div><div id="msOptionsCOORD"></div>
                <div class="ms-actions"><button class="ms-act-btn" onclick="selectAllMs('COORD')">Все</button><button class="ms-act-btn" onclick="clearMs('COORD')">Сбросить</button></div>
              </div>
            </div>
          </div>
          <div class="filter-group fg-kind">
            <div class="filter-label">Категория изменения</div>
            <div class="ms-wrap" id="msWrapCAT">
              <button class="ms-trigger" id="msTriggerCAT" onclick="toggleMs('CAT')">
                <span class="ms-trigger-text" id="msTriggerTextCAT">Все категории</span>
                <span class="ms-trigger-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>
              </button>
              <div class="ms-dropdown" id="msDropCAT">
                <div id="msOptionsCAT"></div>
                <div class="ms-actions"><button class="ms-act-btn" onclick="selectAllMs('CAT')">Все</button><button class="ms-act-btn" onclick="clearMs('CAT')">Сбросить</button></div>
              </div>
            </div>
          </div>
          <div class="filter-group fg-kind">
            <div class="filter-label">Вид ЗИ</div>
            <div class="ms-wrap" id="msWrapKIND">
              <button class="ms-trigger" id="msTriggerKIND" onclick="toggleMs('KIND')">
                <span class="ms-trigger-text" id="msTriggerTextKIND">Все виды</span>
