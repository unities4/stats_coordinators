// ====== PERIOD SELECT ======
function getPeriodKey(date, mode) {
  if (!date||!(date instanceof Date)||isNaN(date)) return null;
  if (mode==='month') return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}`;
  return String(date.getFullYear());
}

function formatPeriodRangeLabel(keys, mode) {
  if (!keys.length) return '—';
  const sorted = [...keys].sort();
  if (mode === 'year') return sorted.join(', ');
  if (sorted.length === 1) return formatPeriodLabel(sorted[0], mode);
  // Check if consecutive
  let consecutive = true;
  for (let i=1; i<sorted.length; i++) {
    const [py,pm] = sorted[i-1].split('-').map(Number);
    const [cy,cm] = sorted[i].split('-').map(Number);
    const prevNext = pm === 12 ? (cy===py+1 && cm===1) : (cy===py && cm===pm+1);
    if (!prevNext) { consecutive = false; break; }
  }
  if (consecutive) {
    const first = formatPeriodLabel(sorted[0], mode);
    const last = formatPeriodLabel(sorted[sorted.length-1], mode);
    return `${first}–${last} (${sorted.length} мес.)`;
  }
  return sorted.map(k=>formatPeriodLabel(k,mode)).join(', ');
}

function formatPeriodLabel(key, mode) {
  if (!key) return key;
  if (mode==='year') return key;
  const [y,m] = key.split('-');
  const names=['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
  return names[parseInt(m)-1]+'.'+String(y).slice(2);
}

