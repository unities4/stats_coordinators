      document.getElementById('comparisonResults').style.display !== 'none') {
    renderComparison();
  }
  // Обновляем подвисшие всегда когда данные загружены (фильтры общие)
  if (hungData.length) renderHungPage();
  if (hungData.length && currentTab === 'doc') renderDocPage();
  requestAnimationFrame(() => window.scrollTo({ top: savedScrollY, behavior: 'instant' }));
}

