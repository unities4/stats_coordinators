    const dates = filteredData.map(r => r.dateReg).filter(d => d instanceof Date && !isNaN(d));
    if (dates.length) {
      let minD = dates.reduce((a,b) => a < b ? a : b);
      let maxD = dates.reduce((a,b) => a > b ? a : b);
      keys = [];
      let y = minD.getFullYear(), m = minD.getMonth() + 1;
      const ey = maxD.getFullYear(), em = maxD.getMonth() + 1;
      while (y < ey || (y === ey && m <= em)) {
        keys.push(`${y}-${String(m).padStart(2,'0')}`);
        m++; if (m > 12) { m = 1; y++; }
      }
    } else {
      keys = [];
    }
  } else {
    keys = [...buckets.keys()].sort((a,b) => a.localeCompare(b));
  }

  if (!keys.length) {
    el.innerHTML = `<div class="hung-empty">Нет данных о дате регистрации${noDate ? ` (${noDate} ЗИ без даты)` : ''}</div>`;
    return;
  }
  const rows = keys.map(k => [k, buckets.get(k) || 0]);
  const maxV = Math.max(...rows.map(r => r[1]), 1);
  const bars = rows.map(([k,v]) => {
    const h = v > 0 ? Math.max(8, Math.round((v/maxV)*100)) : 0;
    const barStyle = v > 0
      ? `height:${h}%;background:linear-gradient(180deg,#2563eb,#60a5fa)`
      : `height:3px;background:var(--gray-200)`;
    const valLabel = v > 0 ? `<div class="rd-bar-val">${v}</div>` : `<div class="rd-bar-val" style="color:var(--gray-400)">0</div>`;
    return `<div class="rd-bar-wrap" title="${escAttr(regPeriodLabel(k,statsRegMode))}: ${v}">
      ${valLabel}
      <div class="rd-bar" style="${barStyle}"></div>
      <div class="rd-bar-lbl">${escHtml(regPeriodLabel(k,statsRegMode))}</div>
    </div>`;
  }).join('');
  el.innerHTML = `<div class="rd-chart">${bars}</div>`;
}
