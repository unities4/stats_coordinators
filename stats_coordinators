// ====== XLSX VALIDATION ======
// ExcelJS читает только OOXML .xlsx (zip). При попытке открыть старый .xls,
// защищённый паролем или повреждённый файл библиотека падает с невнятным
// "Cannot read properties of undefined (reading 'sheets')". Поэтому проверяем
// сигнатуру файла заранее и даём понятное сообщение.
async function readXlsxWorkbook(file) {
  if (!window.ExcelJS) throw new Error('Библиотека ExcelJS не загружена. Убедитесь, что exceljs.min.js находится рядом с файлом.');
  const buf = await file.arrayBuffer();
  const sig = new Uint8Array(buf.slice(0, 4));
  const isZip = sig[0] === 0x50 && sig[1] === 0x4B && sig[2] === 0x03 && sig[3] === 0x04; // 'PK\x03\x04' — zip/xlsx
  const isOle = sig[0] === 0xD0 && sig[1] === 0xCF && sig[2] === 0x11 && sig[3] === 0xE0; // старый .xls / зашифрованный (OLE/CFB)
  if (!isZip) {
    if (isOle) throw new Error('Это старый формат .xls или файл, защищённый паролем. Откройте его в Excel и сохраните как «Книга Excel (.xlsx)».');
    throw new Error('Файл не является корректным .xlsx (возможно, повреждён или это .csv/.xls). Пересохраните его в Excel как .xlsx.');
  }
  const wb = new ExcelJS.Workbook();
  await wb.xlsx.load(buf);
  return wb;
}

// ====== PROCESS FILE ======
async function processFile(file) {
  showNotif('Обработка файла...', false, true);
  try {
    const wb = await readXlsxWorkbook(file);
    const ws = wb.getWorksheet('Изменение');
    if (!ws) { showNotif('Лист «Изменение» не найден!', true); return; }

    const rows = [];
    // Helper: parse date cell → numeric serial (for comparison) or Date
    function parseDateCell(v) {
      if (v instanceof Date) return v;
      if (v && typeof v==='object' && v.result) v = v.result;
      if (typeof v === 'number') {
        // Excel serial date → JS Date (Excel epoch 1899-12-30)
        return new Date((v - 25569) * 86400 * 1000);
      }
      if (typeof v === 'string') { const p = Date.parse(v); return isNaN(p) ? null : new Date(p); }
      return null;
    }
    function getNumeric(v) {
      if (typeof v === 'number') return v;
      if (v instanceof Date) return v.getTime();
      const d = parseDateCell(v);
      return d ? d.getTime() : null;
    }

    // Рабочие дни между двумя датами — только BUILT_IN_HOLIDAYS (системные праздники)
    function calcStatDays(dateStart, dateEnd) {
      if (!dateStart || !dateEnd) return null;
      if (!(dateStart instanceof Date) || isNaN(dateStart)) return null;
      if (!(dateEnd   instanceof Date) || isNaN(dateEnd))   return null;
      const s = new Date(dateStart); s.setHours(0,0,0,0);
      const e = new Date(dateEnd);   e.setHours(0,0,0,0);
      if (e <= s) return 0;
      let count = 0, d = new Date(s);
      while (d < e) {
        const dow = d.getDay();
        if (dow !== 0 && dow !== 6 && !BUILT_IN_HOLIDAYS.has(dateToYMD(d))) count++;
        d.setDate(d.getDate() + 1);
      }
      return count;
    }

    ws.eachRow((row, ri) => {
      if (ri === 1) return;
      const coordinator = row.getCell(3).value;
      if (!coordinator) return;

      // Dates
      const dateApproveRaw = row.getCell(4).value;  // D — дата последнего согласования
      const dateRZRaw      = row.getCell(8).value;  // H — дата закрытия РЗ

      const numD = getNumeric(dateApproveRaw);
      const numH = getNumeric(dateRZRaw);

      // dateClose — col E (5)
      let dateClose = row.getCell(5).value;
      dateClose = parseDateCell(dateClose);
      if (dateClose && !(dateClose instanceof Date)) dateClose = null;

      // Вычисляем рабочие дни самостоятельно (K и L больше не читаются из Excel)
      const dateApprove = parseDateCell(dateApproveRaw);
      const dateRZ      = parseDateCell(dateRZRaw);
      const daysK = calcStatDays(dateApprove, dateClose); // D→E: согласование → закрытие ЗИ
      const daysL = calcStatDays(dateRZ,      dateClose); // H→E: закрытие РЗ → закрытие ЗИ

      // Выбор: используем тот путь, который завершился последним
      const dEmpty = numD === null;
      const hEmpty = numH === null;
      let days;
      if      (dEmpty)       days = daysL; // D пуст → РЗ→закрытие (L)
      else if (hEmpty)       days = daysK; // H пуст → согласование→закрытие (K)
      else if (numH > numD)  days = daysL; // РЗ позже согласования → L
      else                   days = daysK; // согласование позже или одновременно → K

      rows.push({
        num:          row.getCell(1).value,
        ke:           String(row.getCell(2).value  || '').trim(),
        coordinator:  String(coordinator).trim(),
        dateApprove:  dateApprove,
        dateClose:    dateClose,
        days:         days,
        serviceLine:  String(row.getCell(6).value  || '').trim() || '(не указано)',  // F
        businessDir:  String(row.getCell(7).value  || '').trim() || '(не указано)',  // G
        dateRZ:       dateRZ,                                      // H
        category:     String(row.getCell(9).value  || '').trim(),  // I — Категория изменения
        kind:         String(row.getCell(10).value || '').trim(),  // J — Вид
        dateReg:      parseDateCell(row.getCell(11).value),        // K — Дата регистрации (бывший M)
        coordStatus:  String(row.getCell(12).value||'').trim().toLowerCase(), // L — Состояние координатора
        coordManager: String(row.getCell(13).value||'').trim(),              // M — Лин. рук. координатора
      });
    });
    if (!rows.length) { showNotif('Данные не найдены на листе «Изменение»', true); return; }
    allData = rows;
    filteredData = [...allData];
    const rd = document.getElementById('reportDate');
    if (rd) rd.textContent = `Отчёт от ${new Date().toLocaleDateString('ru',{day:'numeric',month:'long',year:'numeric'})}`;
    loadedStats = true;
    document.getElementById('startScreen').style.display = 'none';
    uploadZone.style.display='none';
    document.getElementById('dashboard').style.display='block';
    document.getElementById('tabsBar').style.display='block';
    document.getElementById('btnExport').style.display='inline-flex';
    document.getElementById('btnExportExcel').style.display='inline-flex';
    document.getElementById('btnSettings').style.display='flex';
    updateModuleBadges();
    populateAllMultiSelects();
    populatePeriodSelects();
    populatePeriodLists('a');
    populatePeriodLists('b');
    applyFilters();
    showNotif(`Загружено ${rows.length} записей`);
  } catch(e) {
    showNotif('Ошибка чтения файла: '+e.message, true);
    console.error(e);
  }
}

// ====== MULTI-SELECT WIDGET ======
function populateAllMultiSelects() {
  const uniq = (arr) => [...new Set(arr.filter(v=>v))].sort((a,b)=>a.localeCompare(b,'ru'));
  // Объединяем данные из обоих файлов для фильтров
  const combinedKE    = [...allData.map(r=>r.ke),          ...hungData.map(r=>r.ke)];
  const combinedCoord = [...allData.map(r=>r.coordinator), ...hungData.map(r=>r.coordinator)];
  const combinedCat   = [...allData.map(r=>r.category),    ...hungData.map(r=>r.category)];
  const combinedKind  = [...allData.map(r=>r.kind),        ...hungData.map(r=>r.kind)];
  buildMsOptions('KE', uniq(combinedKE));
  // SL и BD: включаем пустые значения как "(не указано)"
  const uniqWithBlank = (arr) => {
    const vals = arr.map(v => v || '(не указано)');
    return [...new Set(vals.filter(v=>v))].sort((a,b)=>a.localeCompare(b,'ru'));
  };
  const combinedSL = [...allData.map(r=>r.serviceLine), ...hungData.map(r=>r.sl)];
  const combinedBD = [...allData.map(r=>r.businessDir), ...hungData.map(r=>r.bd)];
  buildMsOptions('SL', uniqWithBlank(combinedSL));
  buildMsOptions('BD', uniqWithBlank(combinedBD));
  const yearVals = [...new Set(allData.map(r=>{
    if(!r.dateClose||!(r.dateClose instanceof Date)||isNaN(r.dateClose)) return null;
    return String(r.dateClose.getFullYear());
  }).filter(Boolean))].sort();
  const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
  buildMsOptions('YEAR', yearVals);
  // months: YYYY-MM compound key for unambiguous month+year selection
  const monthVals = [...new Set(allData.map(r=>{
    if(!r.dateClose||!(r.dateClose instanceof Date)||isNaN(r.dateClose)) return null;
    return `${r.dateClose.getFullYear()}-${String(r.dateClose.getMonth()+1).padStart(2,'0')}`;
  }).filter(Boolean))].sort();
  // Store display labels for months (keyed by "MM" for lookup from "YYYY-MM")
  msAllValues['_monthLabels'] = {};
  monthNames.forEach((n, i) => msAllValues['_monthLabels'][String(i+1).padStart(2,'0')] = n);
  buildMsOptions('MONTH', monthVals);

  // Год и месяц регистрации — из файла подвисших (dateReg = col N в hungData)
  const regSource = hungData.length ? hungData : allData;
  const regYearVals = [...new Set(regSource.map(r=>{
    if(!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
    return String(r.dateReg.getFullYear());
  }).filter(Boolean))].sort();
  buildMsOptions('REGYEAR', regYearVals);
  const regMonthVals = [...new Set(regSource.map(r=>{
    if(!r.dateReg||!(r.dateReg instanceof Date)||isNaN(r.dateReg)) return null;
    return `${r.dateReg.getFullYear()}-${String(r.dateReg.getMonth()+1).padStart(2,'0')}`;
  }).filter(Boolean))].sort();
  msAllValues['_regMonthLabels'] = {};
  monthNames.forEach((n, i) => msAllValues['_regMonthLabels'][String(i+1).padStart(2,'0')] = n);
  buildMsOptions('REGMONTH', regMonthVals);

  // Состояние координатора (активен / уволен) — из обоих источников
  const statusVals = [...new Set([
    ...allData.map(r => r.coordStatus),
    ...hungData.map(r => r.coordStatus)
  ].filter(v => v))].sort();
  buildMsOptions('STATUS', statusVals);
  const catVals = [...new Set(allData.map(r=>r.category).filter(Boolean))].sort((a,b)=>a.localeCompare(b,'ru'));
  buildMsOptions('CAT', uniq(combinedCat));
  buildMsOptions('KIND', uniq(combinedKind));
  buildMsOptions('COORD', uniq(combinedCoord));
}

function buildMsOptions(key, values) {
  msAllValues[key] = values;
  renderMsOptions(key, values);
}

function renderMsOptions(key, values) {
  const container = document.getElementById('msOptions'+key);
  if (!container) return;
  const monthLabels = msAllValues['_monthLabels'] || {};
  // Значение ячейки кладём ТОЛЬКО в data-val (атрибутный контекст), а не в JS-строку
  // инлайнового обработчика — это исключает инъекцию скрипта из содержимого файла.
  // id строим по индексу, чтобы не получить невалидный id из произвольного текста.
  container.innerHTML = values.map((v, i) => {
    const regMonthLabels = msAllValues['_regMonthLabels'] || {};
    let label;
    if (key==='MONTH'||key==='REGMONTH') {
      const [vy, vm] = v.split('-');
      const lmap = key==='REGMONTH' ? regMonthLabels : monthLabels;
      label = (lmap[vm] || vm) + ' ' + vy;
    } else if (key==='STATUS') {
      label = v ? v.charAt(0).toUpperCase() + v.slice(1) : v;
    } else if (key==='YEAR'||key==='REGYEAR') {
      label = v + ' год';
    } else {
      label = v;
    }
    const id = `msChk_${key}_${i}`;
    return `<div class="ms-option">
      <input type="checkbox" id="${id}" data-val="${escAttr(v)}" ${msSelected[key].has(v)?'checked':''}>
      <label for="${id}">${escHtml(label)}</label>
    </div>`;
  }).join('');
  // Делегированный обработчик. Присваивание onchange заменяет предыдущий —
  // повторные вызовы renderMsOptions не плодят дубликаты слушателей.
  container.onchange = (e) => {
    const cb = e.target;
    if (!cb || cb.type !== 'checkbox') return;
    onMsChange(key, cb.dataset.val, cb.checked, cb);
  };
}

function filterMsOptions(key, q) {
  const filtered = msAllValues[key].filter(v=>v.toLowerCase().includes(q.toLowerCase()));
  renderMsOptions(key, filtered);
}

function onMsChange(key, val, checked, el) {
  // Save scroll position of the open dropdown before any DOM changes
  const dropEl = document.getElementById('msDrop'+key);
  const savedDropScroll = dropEl ? dropEl.scrollTop : 0;
  const savedPageScroll = window.scrollY;

  if (checked) msSelected[key].add(val); else msSelected[key].delete(val);
  updateMsTrigger(key);
  if (['KE','SL','BD','COORD','YEAR','MONTH','CAT','KIND','REGYEAR','REGMONTH','STATUS'].includes(key)) { applyFilters(); }
