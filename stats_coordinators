// Parse Excel serial date to JS Date
function excelSerialToDate(v) {
  if (v instanceof Date) return v;
  if (v && typeof v === 'object' && v.result) v = v.result;
  if (typeof v === 'number') return new Date((v - 25569) * 86400 * 1000);
  if (typeof v === 'string') { const p = Date.parse(v); return isNaN(p) ? null : new Date(p); }
  return null;
}

function dateToYMD(d) {
  if (!d) return null;
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

// Count working days between two dates (exclusive start, inclusive end)
// Excludes weekends and holidays
function countWorkDays(from, to) {
  if (!from || !to) return 0;
  let count = 0;
  let d = new Date(from);
  d.setDate(d.getDate() + 1);
  while (d <= to) {
    const dow = d.getDay();
    const ymd = dateToYMD(d);
    if (dow !== 0 && dow !== 6 && !BUILT_IN_HOLIDAYS.has(ymd)) count++;
    d.setDate(d.getDate() + 1);
  }
  return count;
}

// Add N working days to a date
function addWorkDays(from, n) {
  if (!from) return null;
  let d = new Date(from);
  let added = 0;
  while (added < n) {
    d.setDate(d.getDate() + 1);
    const dow = d.getDay();
    const ymd = dateToYMD(d);
    if (dow !== 0 && dow !== 6 && !BUILT_IN_HOLIDAYS.has(ymd)) added++;
  }
  return d;
}

function processHungFile(wb) {
  hungData = [];

  // Columns: A=Номер B=Статус ЗИ C=Статус утверждения D=Дата закрытия
  //          E=КЕ F=Координатор G=СЛ H=БН I=Категория J=Вид
  //          K=Срок выполнения согласования L=Дата последнего согласования
  //          M=Дата закрытия последнего РЗ  N=Дата регистрации
  const ws = wb.getWorksheet('Изменение') || wb.getWorksheet(1);
  if (!ws) { throw new Error('Лист «Изменение» не найден в файле подвисших ЗИ'); }
