function applyColVisibility(tableId) {
  const cols = TABLE_COLS[tableId];
  if (!cols) return;
  const bodyEl = document.getElementById(tableId);
  if (!bodyEl) return;
  let tbl;
  if (bodyEl.tagName === 'TBODY') tbl = bodyEl.closest('table');
  else tbl = bodyEl.querySelector('table') || bodyEl.closest('table');
  if (!tbl) return;
  [...tbl.querySelectorAll('thead th')].forEach((th,i) => {
    th.style.display = (cols[i] && cols[i].v) ? '' : 'none';
  });
  [...tbl.querySelectorAll('tbody tr')].forEach(tr => {
    [...tr.querySelectorAll('td')].forEach((td,i) => {
      td.style.display = (cols[i] && cols[i].v) ? '' : 'none';
    });
  });
}

