function getTrendPeriodKey(r) {
  const d = r.dateClose;
  if (!d || !(d instanceof Date) || isNaN(d)) return null;
  const y = d.getFullYear(), m = d.getMonth()+1;
  if (trendXMode === 'year') return String(y);
  if (trendXMode === 'quarter') return `${y}-Q${Math.ceil(m/3)}`;
  return `${y}-${String(m).padStart(2,'0')}`;
}

function formatTrendKey(k) {
  if (/^\d{4}$/.test(k)) return k;
  if (k.includes('-Q')) { const [y,q]=k.split('-'); return `${q} ${String(y).slice(2)}`; }
  const [y,m] = k.split('-');
  const mn=['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
  return mn[parseInt(m)-1]+'.'+String(y).slice(2);
}

function getTrendGroupKey(r) {
  if (trendGroup==='ke') return r.ke || '(не указано)';
  if (trendGroup==='bd') return r.businessDir || '(не указано)';
  return r.serviceLine || '(не указано)';
}

function calcBucketValue(bucket) {
  if (!bucket) return null;
  if (trendMetric==='pct') return bucket.total>0?(bucket.overdue/bucket.total*100):0;
  if (trendMetric==='count') return bucket.overdue;
  // mean/median: база зависит от trendScope
  let arr = trendScope==='overdue'
    ? bucket.daysArr.filter(d=>d>params.days)
    : [...bucket.daysArr];
  arr.sort((a,b)=>a-b);
  if (!arr.length) return 0;
  if (trendMetric==='mean') return arr.reduce((s,d)=>s+d,0)/arr.length;
  const mid=Math.floor(arr.length/2);
  return arr.length%2?arr[mid]:(arr[mid-1]+arr[mid])/2;
}

function renderTrendChart() {
  const canvas = document.getElementById('trendChart');
  if (!canvas || !canvas.parentElement) return;

  // Use globally filtered data (same filters as statistics tab)
  const base = filteredData;

  if (!base.length) {
    const ctx = canvas.getContext('2d');
    const W = canvas.parentElement.offsetWidth || 800;
    canvas.style.width=W+'px'; canvas.style.height='300px';
    canvas.width=W; canvas.height=300;
    ctx.clearRect(0,0,W,300);
    ctx.fillStyle='#94a3b8'; ctx.font='14px PT Sans,Arial'; ctx.textAlign='center';
    ctx.fillText('Нет данных', W/2, 155);
    document.getElementById('trendChartLegend').innerHTML='';
    return;
  }

  // Build map: groupName → periodKey → bucket
  const seriesMap = {}; // { groupName: { periodKey: {total,overdue,daysArr} } }
  for (const r of base) {
    const pk = getTrendPeriodKey(r);
    if (!pk) continue;
    const gk = getTrendGroupKey(r);
    if (!seriesMap[gk]) seriesMap[gk] = {};
    if (!seriesMap[gk][pk]) seriesMap[gk][pk] = {total:0, overdue:0, daysArr:[]};
    const bk = seriesMap[gk][pk];
    bk.total++;
    if (r.days!==null && r.days>params.days) bk.overdue++;
    if (r.days!==null) bk.daysArr.push(r.days);
  }

  // All periods — full continuous range (no gaps for month mode)
  const existingPeriods = [...new Set(base.map(r=>getTrendPeriodKey(r)).filter(Boolean))].sort();
  let allPeriods;
  if (trendXMode === 'month' && existingPeriods.length >= 2) {
    const first = existingPeriods[0], last = existingPeriods[existingPeriods.length-1];
    let [cy,cm] = first.split('-').map(Number);
    const [ly,lm] = last.split('-').map(Number);
    allPeriods = [];
    while (cy < ly || (cy===ly && cm<=lm)) {
      allPeriods.push(`${cy}-${String(cm).padStart(2,'0')}`);
      cm++; if (cm>12) { cm=1; cy++; }
    }
  } else {
    allPeriods = existingPeriods;
  }
  const groupNames = Object.keys(seriesMap).sort((a,b)=>a.localeCompare(b,'ru'));
  const n = allPeriods.length;
  if (!n) return;

  // Canvas setup — use actual available width
  const ctx = canvas.getContext('2d');
  const DPR = window.devicePixelRatio || 1;
  const container = canvas.parentElement;
  const W = Math.max(300, container.clientWidth - 48); // subtract 24px padding each side
  const H = 320;
  canvas.style.width=W+'px'; canvas.style.height=H+'px';
  canvas.width=W*DPR; canvas.height=H*DPR;
  ctx.scale(DPR, DPR);
  ctx.clearRect(0,0,W,H);

  const padL=60, padR=20, padT=20, padB=30;
  const chartW=W-padL-padR, chartH=H-padT-padB;

  // Compute all values for Y scale
  const allVals = groupNames.flatMap(g =>
    allPeriods.map(p => calcBucketValue(seriesMap[g][p])).filter(v=>v!==null)
  );
  const maxVal = Math.max(...allVals, 1) * 1.15;

  function getX(i) { return n===1 ? padL+chartW/2 : padL + (chartW/(n-1))*i; }
  function getY(v) { return padT + chartH - (chartH*(v/maxVal)); }

  // Horizontal grid lines
  const gridCount = 5;
  for (let i=0; i<=gridCount; i++) {
    const y = padT + chartH - (chartH*i/gridCount);
    ctx.strokeStyle = i===0 ? '#cbd5e1' : '#e8ecf2';
    ctx.lineWidth = 1; ctx.setLineDash([]);
    ctx.beginPath(); ctx.moveTo(padL,y); ctx.lineTo(W-padR,y); ctx.stroke();
    const val = maxVal*i/gridCount;
    ctx.fillStyle='#94a3b8'; ctx.font='11px PT Sans,Arial,sans-serif'; ctx.textAlign='right';
    ctx.fillText(val.toFixed(trendMetric==='pct'?1:0)+(trendMetric==='pct'?'%':''), padL-6, y+4);
  }

  // Draw each series
  groupNames.forEach((gname, gi) => {
    const color = TREND_PALETTE[gi % TREND_PALETTE.length];
    const pts = allPeriods.map((p,i) => {
      const v = calcBucketValue(seriesMap[gname][p]);
      return v !== null ? {i, v} : null;
    }).filter(Boolean);
    if (!pts.length) return;

    // Line
    ctx.beginPath();
    pts.forEach((p, idx) => {
      const x=getX(p.i), y=getY(p.v);
      idx===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    });
    ctx.strokeStyle=color; ctx.lineWidth=2.5;
    ctx.lineJoin='round'; ctx.lineCap='round'; ctx.setLineDash([]);
    ctx.stroke();

    // Dots on every point
    pts.forEach(p => {
      const x=getX(p.i), y=getY(p.v);
      ctx.beginPath(); ctx.arc(x,y,3.5,0,2*Math.PI); ctx.fillStyle='#fff'; ctx.fill();
      ctx.beginPath(); ctx.arc(x,y,2.5,0,2*Math.PI); ctx.fillStyle=color; ctx.fill();
    });
  });

  // X axis line
  ctx.strokeStyle='#cbd5e1'; ctx.lineWidth=1.5; ctx.setLineDash([]);
  ctx.beginPath(); ctx.moveTo(padL,padT+chartH); ctx.lineTo(W-padR,padT+chartH); ctx.stroke();

  // X labels — straight horizontal, auto-skip if crowded
  ctx.fillStyle='#64748b'; ctx.font='11px PT Sans,Arial,sans-serif';
  ctx.textAlign='center'; ctx.textBaseline='top';
  const labelW = 44; // approx px per label
  const maxLabels = Math.max(1, Math.floor(chartW / labelW));
  const skipStep = Math.ceil(allPeriods.length / maxLabels);
  allPeriods.forEach((p,i) => {
    if (i % skipStep !== 0 && i !== allPeriods.length - 1) return;
    ctx.fillText(formatTrendKey(p), getX(i), padT + chartH + 8);
  });

  // Y label
  ctx.save();
  const metricLabels={pct:'Доля просрочек (%)',count:'Кол-во просрочек',mean:'Среднее (дн.)',median:'Медиана (дн.)'};
  ctx.fillStyle='#94a3b8'; ctx.font='11px PT Sans,Arial,sans-serif'; ctx.textAlign='center';
  ctx.translate(12, padT+chartH/2); ctx.rotate(-Math.PI/2);
  ctx.fillText(metricLabels[trendMetric], 0, 0);
  ctx.restore();

  // Store for tooltip
  canvas._trendData = { groupNames, allPeriods, seriesMap, padL, padR, padT, padB, chartW, chartH, W, H, maxVal, n };

  // Legend
  document.getElementById('trendChartLegend').innerHTML = groupNames.map((g,i) => {
    const color = TREND_PALETTE[i % TREND_PALETTE.length];
    return `<div class="legend-item">
      <svg width="28" height="10" style="flex-shrink:0;overflow:visible">
        <line x1="0" y1="5" x2="20" y2="5" stroke="${color}" stroke-width="2.5" stroke-linecap="round"/>
        <circle cx="10" cy="5" r="3" fill="${color}"/><circle cx="10" cy="5" r="1.5" fill="white"/>
      </svg>
      <span style="font-size:12px;color:#475569">${escHtml(g)}</span>
    </div>`;
  }).join('');
}

// Tooltip for trend chart
(function() {
  function attach() {
    const canvas = document.getElementById('trendChart');
    if (!canvas || canvas._ttAttached) return;
    canvas._ttAttached = true;
    canvas.addEventListener('mousemove', function(e) {
      const tooltip = document.getElementById('trendChartTooltip');
      const data = canvas._trendData;
      if (!data) { tooltip.style.display='none'; return; }
      const rect = canvas.getBoundingClientRect();
      const DPR = canvas.width / rect.width;
      const mx = (e.clientX - rect.left) * DPR;
      const my = (e.clientY - rect.top) * DPR;
      const { groupNames, allPeriods, seriesMap, padL, padR, padT, padB, chartW, chartH, W, H, maxVal, n } = data;
      function getX(i) { return (n===1 ? padL+chartW/2 : padL+(chartW/(n-1))*i)*DPR; }
      function getY(v) { return (padT+chartH-(chartH*(v/maxVal)))*DPR; }
      const RADIUS = 18*DPR;
      let best=null, bestDist=Infinity;
      groupNames.forEach((g,gi) => {
        const color = TREND_PALETTE[gi % TREND_PALETTE.length];
        allPeriods.forEach((p,i) => {
          const v = calcBucketValue(seriesMap[g][p]);
          if (v===null) return;
          const x=getX(i), y=getY(v);
          const d=Math.sqrt((mx-x)**2+(my-y)**2);
          if (d<RADIUS && d<bestDist) { bestDist=d; best={g,color,p,v,i}; }
        });
      });
      if (best) {
        const mn={pct:'%',count:'',mean:' дн.',median:' дн.'};
        const suffix=mn[trendMetric]||'';
        tooltip.innerHTML=`<div style="font-weight:700;color:${best.color};margin-bottom:3px">${escHtml(best.g)}</div><div style="color:#64748b;margin-bottom:2px">${escHtml(formatTrendKey(best.p))}</div><div style="font-size:15px;font-weight:800;color:${best.color}">${best.v.toFixed(1)}${suffix}</div>`;
        tooltip.style.display='block';
        // position:fixed → координаты вьюпорта, чтобы тултип не обрезался overflow родителей
        const tw = tooltip.offsetWidth || 180, th = tooltip.offsetHeight || 60;
        let tx = e.clientX + 14, ty = e.clientY - 60;
        if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 14;
        if (tx < 8) tx = 8;
        if (ty < 8) ty = 8;
        if (ty + th > window.innerHeight - 8) ty = window.innerHeight - th - 8;
        tooltip.style.left=tx+'px'; tooltip.style.top=ty+'px';
      } else { tooltip.style.display='none'; }
    });
    canvas.addEventListener('mouseleave', () => {
      const t=document.getElementById('trendChartTooltip'); if(t) t.style.display='none';
    });
  }
  // Attach on switchTab and after data load
  const _switchTab = window.switchTab;
  window.switchTab = function(tab, el) {
    if (typeof _switchTab === 'function') _switchTab(tab, el);
    if (tab==='compare') { setTimeout(()=>{ attach(); renderTrendChart(); }, 50); }
  };
  document.addEventListener('DOMContentLoaded', attach);
  setTimeout(attach, 500);
})();

