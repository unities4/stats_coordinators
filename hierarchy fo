  const rev=$('inspRevert'); if(rev)rev.onclick=()=>{f.pname=f.origPname;f.pid=f.origPid;f.level=levelInt(f.origLevelRaw);buildModel();renderStats();renderRoots();renderTree();state.selected=f.id;renderInspector();toast('ФО возвращена к исходному виду');};
}
function descendants(id){const out=new Set();const {children}=MODEL;(function go(x){(children.get(x)||[]).forEach(c=>{if(!out.has(c)){out.add(c);go(c);}});})(id);return out;}

/* ================= EDITS ================= */
function reparent(childId,newKey){
  const child=FOS.get(childId); if(!child)return;
  if(childId===newKey){toast('Нельзя назначить ФО собственным родителем');return;}
  if(newKey!==ROOT&&!String(newKey).startsWith('synth::')){ if(descendants(childId).has(newKey)){toast('Нельзя переместить под собственного потомка');return;} }
  if(newKey===ROOT){ child.pid=''; child.pname=''; }
  else if(String(newKey).startsWith('synth::')){ /* текущий внешний родитель — без изменений */ }
  else { const np=FOS.get(newKey); if(!np){toast('Родитель не найден');return;} child.pid=np.realId||''; child.pname=np.name; }
  buildModel(); renderStats(); renderRoots(); renderTree();
  state.selected=childId;
  // П.1: sync tree highlight and scroll
  setTimeout(()=>{
    const vp=$('treeViewport');
    vp.querySelectorAll('.fo.sel').forEach(r=>r.classList.remove('sel'));
    const el=vp.querySelector(`.fo[data-id="${cssEsc(childId)}"]`);
    if(el){el.classList.add('sel'); el.scrollIntoView({block:'nearest',behavior:'smooth'});}
  },10);
  renderInspector();
  toast('Родитель изменён');
}
function cssEsc(s){return String(s).replace(/["\\]/g,'\\$&');}
function doFix(kind,id){
  const f=FOS.get(id); if(!f)return;
  if(kind==='root'){reparent(id,ROOT);return;}
  if(kind==='syncname'){ if(f.resolvedParent){f.pname=f.resolvedParent.name;renderAll();toast('Имя синхронизировано');} return; }
  if(kind==='setlvl'){ state.selected=id; expandTo(id); renderTree(); renderInspector(); const sel=$('inspLevel'); if(sel)sel.focus(); toast('Выберите уровень в карточке ФО'); return; }
}

