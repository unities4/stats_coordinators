// Column validation for main FO file
const REQUIRED_FO_HEADERS=[
  {pat:/^id$/i, label:'ID'},
  {pat:/^уровень$/i, label:'Уровень'},
  {pat:/^название$/i, label:'Название'},
  {pat:/^родительская\s*фо$/i, label:'Родительская ФО'},
  {pat:/^id\s*родительской/i, label:'id родительской ФО'},
  {pat:/^уровень\s*родительской/i, label:'Уровень родительской ФО'},
  {pat:/^устаревшая\s*запись$/i, label:'Устаревшая запись'},
  {pat:/недоступна?\s*для\s*зи/i, label:'Недоступна для ЗИ'},
  {pat:/не\s*показывать\s*на\s*портале/i, label:'не показывать на портале'},
];
function validateFOHeaders(headers){
  const missing=REQUIRED_FO_HEADERS.filter(req=>!headers.some(h=>req.pat.test(norm(h))));
  return missing;
}

async function handleKEFile(file){
  overlay(true,'Чтение файла КЕ…');
  await new Promise(r=>setTimeout(r,30));
  try{
    const wb=await readWorkbook(file);
    const ws=wb.worksheets[0];
    if(!ws)throw new Error('В книге нет листов');
    let heads=[];
    ws.getRow(1).eachCell({includeEmpty:true},(c,col)=>{heads[col-1]=norm(cellStr(c.value));});
    // find КЕ and ФО columns
    const keIdx=heads.findIndex(h=>/^ке$/i.test(h)||/конфигурац/i.test(h));
    const foIdx=heads.findIndex(h=>/^фо$/i.test(h)||/^название$/i.test(h)||/функциональн.*обл/i.test(h));
    if(keIdx<0||foIdx<0) throw new Error('Не найдены столбцы КЕ и ФО. Ожидаются заголовки «КЕ» и «ФО».');
    KE_MAP=new Map();
    ws.eachRow({includeEmpty:false},(row,rn)=>{
      if(rn===1)return;
      const ke=norm(cellStr(row.getCell(keIdx+1).value));
      const fo=norm(cellStr(row.getCell(foIdx+1).value));
      if(ke&&fo) KE_MAP.set(fo,ke);
    });
    // apply to loaded FOS
    if(FOS.size) { FOS.forEach(f=>{ const ke=KE_MAP.get(norm(f.name))||KE_MAP.get(norm(f.realId)); if(ke) f.ke=ke; }); renderAll(); }
    const keStatus=$('keFileStatus'); if(keStatus){ keStatus.textContent=`✓ КЕ загружены: ${KE_MAP.size} записей`; keStatus.style.color='var(--green)'; }
    toast(`Файл КЕ загружен: ${KE_MAP.size} записей`);
  }catch(err){ alert('Ошибка файла КЕ: '+err.message); console.error(err); }
  finally{ overlay(false); }
}

async function handleFile(file){
  overlay(true,'Чтение файла…');
  await new Promise(r=>setTimeout(r,30));
  try{
    const wb=await readWorkbook(file);
    overlay(true,'Разбор и дедупликация…');
    await new Promise(r=>setTimeout(r,10));
    // Validate headers before parsing
    const ws=wb.worksheets[0];
    const testHeaders=[];
    if(ws) ws.getRow(1).eachCell({includeEmpty:true},(c,col)=>{testHeaders[col-1]=cellStr(c.value);});
    const missing=validateFOHeaders(testHeaders);
    if(missing.length){
      throw new Error(`Файл не содержит обязательных столбцов:\n${missing.map(m=>'• '+m.label).join('\n')}`);
    }
    parseWorkbook(wb);
    state={ke:'ALL',filter:'all',search:'',selected:null,expanded:new Set(),focusLevel:null};
    $('uploadView').classList.add('hidden');
    $('mainView').classList.remove('hidden');
    renderAll(); bindTree();
    $('filterTabs').querySelectorAll('button').forEach(b=>b.classList.toggle('act',b.getAttribute('data-f')==='all'));
    toast(`Загружено: ${FOS.size.toLocaleString('ru-RU')} ФО из ${META.rows.toLocaleString('ru-RU')} строк · авто-исправлено уровней: ${META.autoFixed.toLocaleString('ru-RU')}`);
  }catch(err){ alert('Не удалось обработать файл: '+err.message); console.error(err); }
  finally{ overlay(false); }
}

/* ================= WIRING ================= */
const dz=$('dropzone'),fi=$('fileInput');
dz.onclick=()=>fi.click();
fi.onchange=e=>{const f=e.target.files[0];if(f)handleFile(f);};
['dragenter','dragover'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.add('drag');}));
['dragleave','drop'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.remove('drag');}));
dz.addEventListener('drop',e=>{const f=e.dataTransfer.files[0];if(f)handleFile(f);});

const dzKE=$('dropzoneKE'),fiKE=$('fileInputKE');
if(dzKE){
  dzKE.onclick=()=>fiKE.click();
  fiKE.onchange=e=>{const f=e.target.files[0];if(f)handleKEFile(f);};
  ['dragenter','dragover'].forEach(ev=>dzKE.addEventListener(ev,e=>{e.preventDefault();dzKE.classList.add('drag');}));
  ['dragleave','drop'].forEach(ev=>dzKE.addEventListener(ev,e=>{e.preventDefault();dzKE.classList.remove('drag');}));
  dzKE.addEventListener('drop',e=>{const f=e.dataTransfer.files[0];if(f)handleKEFile(f);});
}

$('keFilter').onchange=e=>{state.ke=e.target.value;state.selected=null;buildModel();renderStats();renderRoots();renderTree();renderInspector();};
let searchT; $('searchInput').oninput=e=>{state.search=e.target.value.trim();clearTimeout(searchT);searchT=setTimeout(renderTree,180);};
$('filterTabs').querySelectorAll('button').forEach(b=>b.onclick=()=>{$('filterTabs').querySelectorAll('button').forEach(x=>x.classList.remove('act'));b.classList.add('act');state.filter=b.getAttribute('data-f');renderTree();});
$('btnExpand').onclick=()=>{ const n=MODEL.nodes.size; if(n>1500&&!confirm(`Узлов много (${n.toLocaleString('ru-RU')}). Полное разворачивание может замедлить отрисовку. Продолжить?`))return; MODEL.nodes.forEach(nd=>{if((MODEL.children.get(nd.id)||[]).length)state.expanded.add(nd.id);}); state.expanded.add('__virtual_root__'); renderTree(); };
$('btnCollapse').onclick=()=>{state.expanded.clear();renderTree();};
$('btnReset').onclick=()=>{ if(!ORIG)return; if(!confirm('Сбросить все правки к исходным данным файла?'))return; restore(ORIG); FOS.forEach(f=>{const c=canonLevel(f.level);if(c!=null)f.levelRaw=c;}); state.selected=null; renderAll(); toast('Правки сброшены'); };
$('btnNew').onclick=()=>{ $('mainView').classList.add('hidden'); $('uploadView').classList.remove('hidden'); fi.value=''; FOS=new Map(); MODEL=null; };
$('btnExport').onclick=exportExcel;
// KE file button in toolbar
const fiKE2=$('fileInputKE2');
$('btnLoadKE').onclick=()=>fiKE2.click();
fiKE2.onchange=e=>{const f=e.target.files[0];if(f)handleKEFile(f);};
</script>
