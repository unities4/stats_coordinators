/* ---- included set for current filter ---- */
function computeIncluded(){
  const {nodes,children}=MODEL;
  const keOk=f=>state.ke==='ALL'||f.ke===state.ke||f.synthetic;
  const inc=new Set();
  if(!state.search&&state.filter==='all'){
    nodes.forEach(f=>{ if(keOk(f)) inc.add(f.id); });
    return {inc,autoExpand:false};
  }
  const q=state.search.toLowerCase();
  const ms=f=>!state.search||(f.name||'').toLowerCase().includes(q)||String(f.realId||'').toLowerCase().includes(q);
  const mf=f=>{ if(state.filter==='err')return severity(f)!=='ok'; if(state.filter==='chg')return isChanged(f); if(state.filter==='root')return f.parentKey===ROOT||String(f.parentKey).startsWith('synth::'); return true; };
  nodes.forEach(f=>{
    if(f.synthetic)return;
    if(state.ke!=='ALL'&&f.ke!==state.ke)return;
    if(ms(f)&&mf(f)){ let cur=f,g=0; while(cur&&g++<60){ inc.add(cur.id); if(cur.parentKey===ROOT)break; cur=nodes.get(cur.parentKey); } }
  });
  return {inc,autoExpand:true};
}

function nodeBox(f,kids,expanded){
  const sev=severity(f);
  const changed=!f.synthetic&&isChanged(f);
  const cf=changed?changedFields(f):{};
  const tg=kids.length?`<span class="tg" data-tog="${esc(f.id)}">${expanded?'−':'+'}</span>`:'';
  let lvl='';
  if(!f.synthetic){
    if(f.level!=null)lvl=`<span class="lvlb ${cf.level?'chg':''}" title="${esc(canonLevel(f.level))}">Ур. ${f.level}</span>`;
    else lvl=`<span class="lvlb" style="background:var(--gray-bg);color:var(--muted)">Ур. ?</span>`;
  }
  const dot=f.synthetic?'':`<span class="dot ${changed?'chg':sev}" title="${changed?'есть изменения':sev}"></span>`;
  const tags=[];
  if(!f.synthetic){
    if(f.tzi)tags.push('<span class="atag tzi">ТЗИ</span>');
    if(f.obsolete)tags.push('<span class="atag old">устар.</span>');
    if(f.unavail)tags.push('<span class="atag una">недост.</span>');
    if(f.hidden)tags.push('<span class="atag hid">скрыта</span>');
  }
  const cnt=(!expanded&&kids.length)?`<span class="cnt">${kids.length}</span>`:'';
  const keTag=(state.ke==='ALL'&&f.ke&&!f.synthetic)?`<span class="ke-tag" title="${esc(f.ke)}">${esc(f.ke)}</span>`:'';
  const cls=['fo']; if(f.synthetic)cls.push('synthetic'); if(state.selected===f.id)cls.push('sel');
  const drag=f.synthetic?'':'draggable="true"';
  const title=esc(f.name)+(f.realId?'  ['+esc(f.realId)+']':'');
  return `<div class="${cls.join(' ')}" data-id="${esc(f.id)}" ${drag}>${tg}${dot}<span class="nm" title="${title}">${esc(f.name)||'(без названия)'}</span>${lvl}${tags.join('')}${cnt}${keTag}</div>`;
}

function renderTree(){
  if(!MODEL)return;
  const {nodes,children}=MODEL;
  const {inc,autoExpand}=computeIncluded();
  const sortKids=arr=>arr.sort((a,b)=>{const A=nodes.get(a),B=nodes.get(b);return (A.level??99)-(B.level??99)||(A.name||'').localeCompare(B.name||'','ru');});

  let rendered=0, MAX=4000; // safety cap on rendered DOM nodes
  let capped=false;
  function node(id){
    if(rendered>MAX){capped=true;return '';}
    const f=nodes.get(id); if(!f)return '';
    let kids=(children.get(id)||[]).filter(c=>inc.has(c));
    // skip empty synthetic
    if(f.synthetic&&kids.length===0)return '';
    rendered++;
    const expanded=autoExpand||state.expanded.has(id);
    sortKids(kids);
    let childHtml='';
    if(kids.length&&expanded){ childHtml='<ul>'+kids.map(node).join('')+'</ul>'; }
    return `<li><div class="liwrap">${nodeBox(f,kids,expanded)}</div>${childHtml}</li>`;
  }
  let roots=(children.get(ROOT)||[]).filter(id=>inc.has(id));
  sortKids(roots);
  const html=roots.map(node).filter(Boolean).join('');
  $('treeViewport').innerHTML=html?`<div class="tree"><ul class="roots">${html}</ul></div>`+(capped?`<div style="padding:14px;color:var(--muted);font-size:12px">Показаны не все узлы (ограничение ${MAX} для скорости). Используйте поиск или фильтр по КЕ, чтобы сузить вывод.</div>`:'')
    :`<div style="text-align:center;color:var(--muted);padding:40px">Нет ФО по текущему фильтру.</div>`;
  let cnt=0; nodes.forEach(n=>{if(!n.synthetic&&inc.has(n.id))cnt++;});
  $('treeCount').textContent=cnt.toLocaleString('ru-RU')+' ФО';
}

/* ---- tree events (delegated) ---- */
function bindTree(){
  const box=$('treeBox');
  const vp=$('treeViewport');

  /* --- zoom/pan state --- */
  let scale=1, panX=0, panY=0;
  let isPanning=false, startX=0, startY=0, startPanX=0, startPanY=0;
  const MIN_SCALE=0.15, MAX_SCALE=3;

  function applyTransform(){
    vp.style.transform=`translate(${panX}px,${panY}px) scale(${scale})`;
    $('zoomLabel').textContent=Math.round(scale*100)+'%';
  }

  /* wheel zoom */
  box.addEventListener('wheel',e=>{
    e.preventDefault();
    const rect=box.getBoundingClientRect();
    const mouseX=e.clientX-rect.left-panX;
    const mouseY=e.clientY-rect.top-panY;
    const delta=e.deltaY>0?0.9:1.1;
    const newScale=Math.min(MAX_SCALE,Math.max(MIN_SCALE,scale*delta));
    panX-=mouseX*(newScale-scale);
    panY-=mouseY*(newScale-scale);
    scale=newScale;
    applyTransform();
  },{passive:false});

  /* left-button pan (only when dragging on background, not on .fo nodes) */
  let didPan=false;
  box.addEventListener('mousedown',e=>{
    if(e.button===0&&!e.target.closest('.fo')&&!e.target.closest('[data-tog]')){
      e.preventDefault();
      isPanning=true; didPan=false;
      startX=e.clientX; startY=e.clientY; startPanX=panX; startPanY=panY;
      box.classList.add('panning');
    }
  });
  window.addEventListener('mousemove',e=>{
    if(!isPanning)return;
    const dx=e.clientX-startX, dy=e.clientY-startY;
    if(Math.abs(dx)>3||Math.abs(dy)>3) didPan=true;
    panX=startPanX+dx;
    panY=startPanY+dy;
    applyTransform();
  });
  window.addEventListener('mouseup',e=>{
    if(e.button===0&&isPanning){ isPanning=false; box.classList.remove('panning'); }
  });

  /* zoom buttons */
  $('zoomIn').onclick=()=>{scale=Math.min(MAX_SCALE,scale*1.2);applyTransform();};
  $('zoomOut').onclick=()=>{scale=Math.max(MIN_SCALE,scale/1.2);applyTransform();};
  $('zoomReset').onclick=()=>{scale=1;panX=0;panY=0;applyTransform();};

  /* click events on viewport */
  vp.onclick=e=>{
    const tg=e.target.closest('[data-tog]');
    if(tg){const id=tg.getAttribute('data-tog'); state.expanded.has(id)?state.expanded.delete(id):state.expanded.add(id); renderTree(); return;}
    const fo=e.target.closest('.fo');
    if(fo&&fo.dataset.id){ state.selected=fo.dataset.id; vp.querySelectorAll('.fo.sel').forEach(n=>n.classList.remove('sel')); fo.classList.add('sel'); renderInspector(); }
  };
  vp.addEventListener('dragstart',e=>{const fo=e.target.closest('.fo[draggable="true"]');if(!fo)return;DRAG=fo.dataset.id;e.dataTransfer.setData('text/plain',DRAG);e.dataTransfer.effectAllowed='move';fo.classList.add('dragging');});
  vp.addEventListener('dragend',e=>{const fo=e.target.closest('.fo');if(fo)fo.classList.remove('dragging');vp.querySelectorAll('.fo.drag-over').forEach(n=>n.classList.remove('drag-over'));});
  vp.addEventListener('dragover',e=>{const fo=e.target.closest('.fo');if(!fo)return;e.preventDefault();e.dataTransfer.dropEffect='move';if(!fo.classList.contains('drag-over')){vp.querySelectorAll('.fo.drag-over').forEach(n=>n.classList.remove('drag-over'));fo.classList.add('drag-over');}});
  vp.addEventListener('drop',e=>{const fo=e.target.closest('.fo');if(!fo)return;e.preventDefault();fo.classList.remove('drag-over');if(DRAG&&fo.dataset.id)reparent(DRAG,fo.dataset.id);DRAG=null;});
}

/* ================= PROBLEMS ================= */
const PROB_LABEL={self_parent:'Ссылка на себя',cycle:'Цикл в иерархии',dup_conflict:'Противоречивые дубли',level_unparsed:'Уровень не распознан',name_id_mismatch:'Имя ≠ ID родителя'};
function renderProblems(){
  const list=$('probList');
  const items=[];
  MODEL.nodes.forEach(f=>{ if(f.synthetic)return; if(state.ke!=='ALL'&&f.ke!==state.ke)return; (f.problems||[]).forEach(p=>items.push({f,p})); });
  const rank={err:0,warn:1,info:2};
  items.sort((a,b)=>rank[a.p.sev]-rank[b.p.sev]);
  $('probCount').textContent=items.length?items.length.toLocaleString('ru-RU')+' шт.':'';
  if(!items.length){ list.innerHTML=`<div class="empty-ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><div>Замечаний нет.</div></div>`; return; }
  const CAP=200; const shown=items.slice(0,CAP);
  list.innerHTML=shown.map(({f,p})=>{
    let fixes='';
    if(p.t==='self_parent'||p.t==='cycle') fixes+=`<button class="btn" data-fix="root" data-id="${esc(f.id)}">Сделать верхним</button>`;
    if(p.t==='name_id_mismatch'&&f.resolvedParent) fixes+=`<button class="btn" data-fix="syncname" data-id="${esc(f.id)}">Подставить имя по ID</button>`;
    if(p.t==='level_unparsed') fixes+=`<button class="btn primary" data-fix="setlvl" data-id="${esc(f.id)}">Указать уровень…</button>`;
    return `<div class="prob ${p.sev}"><div class="pt" data-go="${esc(f.id)}"><span class="badge ${p.sev}">${PROB_LABEL[p.t]||p.t}</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(f.name)}</span></div><div class="pd">${esc(p.msg)}</div>${fixes?`<div class="pfix">${fixes}</div>`:''}</div>`;
  }).join('')+(items.length>CAP?`<div style="color:var(--muted);font-size:12px;text-align:center;padding:6px">…и ещё ${(items.length-CAP).toLocaleString('ru-RU')}. Сузьте фильтром.</div>`:'');
  list.querySelectorAll('[data-go]').forEach(el=>el.onclick=()=>{state.selected=el.getAttribute('data-go');expandTo(state.selected);renderTree();renderInspector();});
  list.querySelectorAll('[data-fix]').forEach(el=>el.onclick=()=>doFix(el.getAttribute('data-fix'),el.getAttribute('data-id')));
}
function expandTo(id){let cur=MODEL.nodes.get(id),g=0;while(cur&&g++<60){const pk=cur.parentKey;if(pk===ROOT)break;state.expanded.add(pk);cur=MODEL.nodes.get(pk);}}

/* ================= INSPECTOR ================= */
function renderInspector(){
  const box=$('inspector');
  if(!state.selected||!FOS.has(state.selected)){ box.innerHTML=`<div class="insp-empty">Выберите узел в дереве, чтобы посмотреть атрибуты и изменить родителя / уровень.</div>`; return; }
  const f=FOS.get(state.selected);
  const cf=changedFields(f);
  // parent options: same KE, excluding self + descendants
  const desc=descendants(f.id);
  const opts=[...FOS.values()].filter(x=>x.id!==f.id&&x.ke===f.ke&&!desc.has(x.id)).sort((a,b)=>(a.name||'').localeCompare(b.name||'','ru'));
  const lvlChoices=LEVEL_CHOICES.slice();
  if(f.level!=null&&!lvlChoices.includes(f.level))lvlChoices.push(f.level);
  const synthParent=f.parentKey&&String(f.parentKey).startsWith('synth::');
  box.innerHTML=`
    <div class="row"><span class="k">Название</span><span class="val">${esc(f.name)||'—'}</span></div>
    <div class="row"><span class="k">ID ФО</span><span class="val" style="font-size:11px;color:var(--muted)">${esc(f.realId)||'—'}</span></div>
    <div class="row"><span class="k">КЕ</span><span class="val">${esc(f.ke)||'—'}</span></div>
    <div class="row"><span class="k">Родительская ФО ${cf.pname||cf.pid?'<span class="chg-flag">изменено</span>':''}</span>
      <select id="inspParent">
        <option value="${ROOT}" ${f.parentKey===ROOT?'selected':''}>— нет (верхний узел) —</option>
        ${synthParent?`<option value="${esc(f.parentKey)}" selected>(вне файла) ${esc(f.pname)}</option>`:''}
        ${opts.map(o=>`<option value="${esc(o.id)}" ${f.parentKey===o.id?'selected':''}>${esc(o.name)}${o.realId?' · '+o.realId.slice(0,8):''}</option>`).join('')}
      </select>
      ${synthParent?`<div class="hint">Текущий родитель «${esc(f.pname)}» отсутствует в файле — это допустимо.</div>`:''}
    </div>
    <div class="row"><span class="k">Уровень ${cf.level?'<span class="chg-flag">изменено</span>':''}</span>
      <select id="inspLevel">
        <option value="">— не задан —</option>
        ${lvlChoices.sort((a,b)=>a-b).map(n=>`<option value="${n}" ${f.level===n?'selected':''}>${esc(canonLevel(n))}</option>`).join('')}
      </select>
      <div class="hint">Исходно: «${esc(f.origLevelRaw)||'—'}»${cf.level?` → станет «${esc(canonLevel(f.level))}»`:''}</div>
    </div>
    <div class="row"><span class="k">Атрибуты</span><span class="val" style="font-weight:500">${[f.tzi?'ТЗИ: '+esc(f.tzi):'',f.obsolete?'устаревшая':'',f.unavail?'недоступна для ЗИ':'',f.hidden?'скрыта на портале':''].filter(Boolean).join('; ')||'—'}</span></div>
    <div class="row"><span class="k">Строк в исходном файле</span><span class="val">${f.srcRows.toLocaleString('ru-RU')}</span></div>
    ${f.problems&&f.problems.length?`<div class="row"><span class="k" style="color:var(--amber)">Замечания</span><span class="val" style="font-weight:500;color:var(--muted)">${f.problems.map(p=>esc(p.msg)).join('<br>')}</span></div>`:''}
    <div class="insp-actions"><button class="btn" id="inspRoot">Сделать верхним</button>${isChanged(f)?'<button class="btn ghost" id="inspRevert">Откатить ФО</button>':''}</div>`;
  $('inspParent').onchange=e=>reparent(f.id,e.target.value);
  $('inspLevel').onchange=e=>{const v=e.target.value;f.level=v===''?null:parseInt(v,10);renderAll();state.selected=f.id;renderInspector();toast('Уровень обновлён');};
  $('inspRoot').onclick=()=>reparent(f.id,ROOT);
  const rev=$('inspRevert'); if(rev)rev.onclick=()=>{f.pname=f.origPname;f.pid=f.origPid;f.level=levelInt(f.origLevelRaw);renderAll();state.selected=f.id;renderInspector();toast('ФО возвращена к исходному виду');};
}
function descendants(id){const out=new Set();const {children}=MODEL;(function go(x){(children.get(x)||[]).forEach(c=>{if(!out.has(c)){out.add(c);go(c);}});})(id);return out;}

/* ================= EDITS ================= */
function reparent(childId,newKey){
  const child=FOS.get(childId); if(!child)return;
  if(childId===newKey){toast('Нельзя назначить ФО собственным родителем');return;}
  if(newKey!==ROOT&&!String(newKey).startsWith('synth::')){ if(descendants(childId).has(newKey)){toast('Нельзя переместить под собственного потомка');return;} }
  if(newKey===ROOT){ child.pid=''; child.pname=''; }
  else if(String(newKey).startsWith('synth::')){ /* выбран текущий внешний родитель — без изменений */ }
  else { const np=FOS.get(newKey); if(!np){toast('Родитель не найден');return;} child.pid=np.realId||''; child.pname=np.name; }
  renderAll(); state.selected=childId;
  const vp=$('treeViewport'); const el=vp.querySelector(`.fo[data-id="${cssEsc(childId)}"]`); if(el)el.classList.add('sel');
  renderInspector(); toast('Родитель изменён');
}
function cssEsc(s){return String(s).replace(/["\\]/g,'\\$&');}
function doFix(kind,id){
  const f=FOS.get(id); if(!f)return;
  if(kind==='root'){reparent(id,ROOT);return;}
  if(kind==='syncname'){ if(f.resolvedParent){f.pname=f.resolvedParent.name;renderAll();toast('Имя синхронизировано');} return; }
  if(kind==='setlvl'){ state.selected=id; expandTo(id); renderTree(); renderInspector(); const sel=$('inspLevel'); if(sel)sel.focus(); toast('Выберите уровень в карточке ФО'); return; }
}

/* ================= EXPORT (only changed, yellow fills) ================= */
async function exportExcel(){
  const changed=[...FOS.values()].filter(isChanged);
  if(!changed.length){toast('Изменений нет — выгружать нечего');return;}
  overlay(true,'Формирование файла…');
  await new Promise(r=>setTimeout(r,30));
  try{
    const C=COLMAP;
    const wb=new ExcelJS.Workbook();
    const ws=wb.addWorksheet('ФО (изменения)');
    ws.addRow(HEADERS);
    ws.getRow(1).font={bold:true};
    ws.getRow(1).fill={type:'pattern',pattern:'solid',fgColor:{argb:'FFEEF2F7'}};
    changed.forEach(f=>{
      const vals=HEADERS.map((h,i)=>f.rawRow[i]!=null?f.rawRow[i]:'');
      if(C.level!=null)vals[C.level]=canonLevel(f.level)||f.rawRow[C.level]||'';
      if(C.pname!=null)vals[C.pname]=f.pname;
      if(C.pid!=null)vals[C.pid]=f.pid;
      const row=ws.addRow(vals);
      const cf=changedFields(f);
      const hl=idx=>{ if(idx!=null){ row.getCell(idx+1).fill={type:'pattern',pattern:'solid',fgColor:{argb:'FFFFFF00'}}; } };
      if(cf.level)hl(C.level);
      if(cf.pname)hl(C.pname);
      if(cf.pid)hl(C.pid);
    });
    ws.columns.forEach((c,i)=>{ const h=HEADERS[i]||''; c.width=Math.min(46,Math.max(12,h.length+3)); });
    ws.views=[{state:'frozen',ySplit:1}];
    const buf=await wb.xlsx.writeBuffer();
    const blob=new Blob([buf],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download='ФО_изменения.xlsx'; document.body.appendChild(a); a.click(); a.remove();
    setTimeout(()=>URL.revokeObjectURL(url),1500);
    toast('Выгружено изменённых ФО: '+changed.length);
  }catch(err){ alert('Ошибка выгрузки: '+err.message); console.error(err); }
  finally{ overlay(false); }
}

/* ================= FILE FLOW ================= */
async function handleFile(file){
  overlay(true,'Чтение файла…');
  await new Promise(r=>setTimeout(r,30));
  try{
    const wb=await readWorkbook(file);
    overlay(true,'Разбор и дедупликация…');
    await new Promise(r=>setTimeout(r,10));
    parseWorkbook(wb);
    state={ke:'ALL',filter:'all',search:'',selected:null,expanded:new Set()};
    $('uploadView').classList.add('hidden');
    $('mainView').classList.remove('hidden');
    renderAll(); bindTree();
    $('filterTabs').querySelectorAll('button').forEach(b=>b.classList.toggle('act',b.getAttribute('data-f')==='all'));
    toast(`Загружено: ${FOS.size.toLocaleString('ru-RU')} ФО из ${META.rows.toLocaleString('ru-RU')} строк · авто-исправлено уровней: ${META.autoFixed.toLocaleString('ru-RU')}`);
  }catch(err){ alert('Не удалось обработать файл: '+err.message); console.error(err); }
  finally{ overlay(false); }
}

/* ================= WIRING ================= */
const dz=$('dropzone'),fi=$('fileInput');
dz.onclick=()=>fi.click();
fi.onchange=e=>{const f=e.target.files[0];if(f)handleFile(f);};
['dragenter','dragover'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.add('drag');}));
['dragleave','drop'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.remove('drag');}));
dz.addEventListener('drop',e=>{const f=e.dataTransfer.files[0];if(f)handleFile(f);});

$('keFilter').onchange=e=>{state.ke=e.target.value;state.selected=null;renderStats();renderTree();renderProblems();renderInspector();};
let searchT; $('searchInput').oninput=e=>{state.search=e.target.value.trim();clearTimeout(searchT);searchT=setTimeout(renderTree,180);};
$('filterTabs').querySelectorAll('button').forEach(b=>b.onclick=()=>{$('filterTabs').querySelectorAll('button').forEach(x=>x.classList.remove('act'));b.classList.add('act');state.filter=b.getAttribute('data-f');renderTree();});
$('btnExpand').onclick=()=>{ const n=MODEL.nodes.size; if(n>1500&&!confirm(`Узлов много (${n.toLocaleString('ru-RU')}). Полное разворачивание может замедлить отрисовку. Продолжить?`))return; MODEL.nodes.forEach(nd=>{if((MODEL.children.get(nd.id)||[]).length)state.expanded.add(nd.id);}); renderTree(); };
$('btnCollapse').onclick=()=>{state.expanded.clear();renderTree();};
$('btnReset').onclick=()=>{ if(!ORIG)return; if(!confirm('Сбросить все правки к исходным данным файла?'))return; restore(ORIG); FOS.forEach(f=>{const c=canonLevel(f.level);if(c!=null)f.levelRaw=c;}); state.selected=null; renderAll(); toast('Правки сброшены'); };
$('btnNew').onclick=()=>{ $('mainView').classList.add('hidden'); $('uploadView').classList.remove('hidden'); fi.value=''; FOS=new Map(); MODEL=null; };
$('btnExport').onclick=exportExcel;
</script>
