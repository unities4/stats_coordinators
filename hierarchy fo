<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Иерархия функциональных областей (ФО)</title>
<!-- Локальная библиотека, без обращений в сеть. Должна лежать рядом с этим файлом. -->
<script src="./exceljs.min.js"></script>
<style>
  :root{
    --brand:#004C97; --brand-d:#003568; --brand-l:#2563eb;
    --bg:#eef1f5; --panel:#fff; --line:#e2e8f0; --line-2:#cbd5e1;
    --txt:#1e293b; --muted:#64748b; --muted-2:#94a3b8;
    --green:#16a34a; --amber:#d97706; --red:#dc2626; --violet:#7c3aed;
    --green-bg:#dcfce7; --amber-bg:#fef3c7; --red-bg:#fee2e2; --blue-bg:#dbeafe; --violet-bg:#ede9fe; --gray-bg:#f1f5f9;
    --yellow:#facc15;
    --radius:12px; --shadow:0 1px 3px rgba(15,23,42,.08),0 1px 2px rgba(15,23,42,.04);
    --shadow-lg:0 10px 30px rgba(15,23,42,.12);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI','Montserrat',Arial,sans-serif;background:var(--bg);color:var(--txt);font-size:14px;line-height:1.45}
  .header{background:linear-gradient(120deg,var(--brand-d),var(--brand));color:#fff;padding:18px 28px;position:relative;overflow:hidden}
  .header::after{content:'';position:absolute;right:-40px;top:-60px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.05)}
  .header h1{font-size:20px;font-weight:700;font-family:'Montserrat','Segoe UI',sans-serif;display:flex;align-items:center;gap:12px}
  .header p{opacity:.82;font-size:13px;margin-top:4px;max-width:820px}
  .wrap{max-width:100%;margin:0 auto;padding:20px 28px 60px;overflow-x:hidden}

  .toolbar{display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;box-shadow:var(--shadow);margin-bottom:16px}
  .btn{display:inline-flex;align-items:center;gap:7px;border:1px solid var(--line-2);background:#fff;color:var(--txt);padding:8px 14px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;white-space:nowrap}
  .btn:hover{border-color:var(--brand-l);color:var(--brand)}
  .btn.primary{background:var(--brand);border-color:var(--brand);color:#fff}
  .btn.primary:hover{background:var(--brand-d);color:#fff}
  .btn.green{background:var(--green);border-color:var(--green);color:#fff}
  .btn.green:hover{filter:brightness(.93);color:#fff}
  .btn.ghost{background:transparent;border-color:transparent;color:var(--muted)}
  .btn.ghost:hover{color:var(--brand);background:var(--gray-bg)}
  .btn:disabled{opacity:.45;cursor:not-allowed}
  .btn svg{width:16px;height:16px}
  .sep{width:1px;height:30px;background:var(--line);margin:0 4px;align-self:center}
  .spacer{flex:1}
  select,input[type=text]{font-family:inherit;font-size:13px;padding:7px 10px;border:1px solid var(--line-2);border-radius:8px;background:#fff;color:var(--txt)}
  select:focus,input:focus{outline:none;border-color:var(--brand-l);box-shadow:0 0 0 3px rgba(37,99,235,.12)}
  label.fld{display:flex;flex-direction:column;gap:3px;font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.03em}

  .dropzone{border:2px dashed var(--line-2);border-radius:16px;background:var(--panel);padding:54px 28px;text-align:center;cursor:pointer;transition:.18s;box-shadow:var(--shadow)}
  .dropzone:hover,.dropzone.drag{border-color:var(--brand-l);background:#f8fbff}
  .dropzone .dz-ic{width:56px;height:56px;margin:0 auto 14px;color:var(--brand);opacity:.85}
  .dropzone h2{font-size:17px;margin-bottom:6px}
  .dropzone p{color:var(--muted);font-size:13px}
  .note{font-size:12px;color:var(--muted);margin-top:14px;background:var(--gray-bg);border-radius:10px;padding:10px 14px;display:inline-block}

  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:16px}
  .stat{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:14px 16px;box-shadow:var(--shadow);position:relative;overflow:hidden}
  .stat .v{font-size:25px;font-weight:800;font-family:'Montserrat',sans-serif;line-height:1}
  .stat .l{font-size:12px;color:var(--muted);margin-top:5px;font-weight:600}
  .stat .bar{position:absolute;left:0;top:0;bottom:0;width:4px}
  .stat.ok .bar{background:var(--green)} .stat.warn .bar{background:var(--amber)} .stat.err .bar{background:var(--red)} .stat.info .bar{background:var(--brand-l)} .stat.chg .bar{background:var(--yellow)}

  .layout{display:flex;flex-direction:column;gap:16px}
  .inspector-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  @media(max-width:900px){.inspector-row{grid-template-columns:1fr}}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
  .card-h{display:flex;align-items:center;gap:10px;padding:13px 16px;border-bottom:1px solid var(--line);font-weight:700;font-size:14px}
  .card-h .count{margin-left:auto;font-size:12px;color:var(--muted);font-weight:600}
  .card-b{padding:14px 16px}

  /* roots panel */
  #rootsBox{overflow-x:hidden;overflow-y:auto;max-height:260px;padding:12px 14px;display:flex;flex-wrap:wrap;gap:6px;align-items:flex-start}
  .root-chip{display:inline-flex;align-items:center;gap:6px;background:var(--gray-bg);border:1px solid var(--line-2);border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;white-space:nowrap;cursor:pointer;transition:.15s}
  .root-chip:hover{border-color:var(--brand-l);color:var(--brand);background:var(--blue-bg)}
  .root-chip.sel{border-color:var(--brand);background:var(--blue-bg);color:var(--brand)}
  /* ===== LEVEL-BAND TREE (horizontal cards, wrap within level) ===== */
  #treeBox{padding:0;overflow:auto;max-height:74vh;position:relative;background:linear-gradient(var(--bg) 0 0) padding-box;background-color:#fafbfd}
  #treeViewport{padding:0;min-width:100%}

  /* a horizontal band = one hierarchy level */
  .lvl-band{position:relative;border-bottom:1px dashed var(--line-2);padding:10px 16px 14px 16px}
  .lvl-band:last-child{border-bottom:none}
  .lvl-band.dim{opacity:.4}
  .lvl-band .lvl-label{display:inline-flex;align-items:center;gap:7px;font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;cursor:pointer;user-select:none}
  .lvl-band .lvl-label .lvl-badge{display:inline-flex;align-items:center;justify-content:center;min-width:22px;height:22px;border-radius:7px;background:var(--brand);color:#fff;font-size:12px;font-weight:800;padding:0 6px}
  .lvl-band .lvl-label .lvl-cnt{font-weight:700;color:var(--muted-2);font-size:11px}
  .lvl-band .lvl-label:hover{color:var(--brand)}
  .lvl-band.active{background:rgba(0,76,151,.035)}
  .lvl-band.active>.lvl-label .lvl-badge{box-shadow:0 0 0 3px rgba(0,76,151,.18)}

  /* nodes row inside a band — wrap to new shelves */
  .lvl-nodes{display:flex;flex-wrap:wrap;gap:10px 12px;align-items:flex-start}

  /* node card */
  .fo{position:relative;display:inline-flex;align-items:center;gap:7px;border:1px solid var(--line-2);border-radius:10px;background:#fff;padding:7px 10px;cursor:pointer;transition:.1s;max-width:300px;white-space:nowrap;box-shadow:var(--shadow)}
  .fo:hover{border-color:var(--brand-l);box-shadow:0 2px 8px rgba(37,99,235,.12)}
  .fo.sel{border-color:var(--brand);box-shadow:0 0 0 3px rgba(0,76,151,.16)}
  .fo.drag-over{border-color:var(--green);box-shadow:0 0 0 3px rgba(22,163,74,.2);background:#f0fdf4}
  .fo.dragging{opacity:.4}
  .fo.synthetic{background:repeating-linear-gradient(45deg,#f8fafc,#f8fafc 7px,#f1f5f9 7px,#f1f5f9 14px);border-style:dashed;color:var(--muted)}
  .fo.parent-hl{border-color:var(--violet);box-shadow:0 0 0 3px rgba(124,58,237,.18)}
  .fo.child-hl{border-color:var(--green);box-shadow:0 0 0 2px rgba(22,163,74,.18)}
  .fo .tg{width:18px;height:18px;border-radius:5px;border:1px solid var(--line-2);background:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:12px;color:var(--muted);flex-shrink:0;font-weight:700;line-height:1;cursor:pointer}
  .fo .tg:hover{border-color:var(--brand-l);color:var(--brand)}
  .fo .nm{font-weight:600;overflow:hidden;text-overflow:ellipsis;max-width:170px}
  .fo .lvlb{font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;background:var(--blue-bg);color:var(--brand);flex-shrink:0}
  .fo .lvlb.chg{background:#fef9c3;color:#a16207}
  .fo .lvlb.err{background:var(--red-bg);color:var(--red)}
  .fo .dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
  .fo .dot.err{background:var(--red)} .fo .dot.warn{background:var(--amber)} .fo .dot.ok{background:var(--green)} .fo .dot.chg{background:var(--yellow);box-shadow:0 0 0 2px #fff,0 0 0 3px var(--yellow)}
  .fo .atag{font-size:9px;font-weight:700;padding:1px 5px;border-radius:4px}
  .atag.tzi{background:var(--violet-bg);color:var(--violet)} .atag.old{background:var(--gray-bg);color:var(--muted)} .atag.una{background:var(--red-bg);color:var(--red)} .atag.hid{background:var(--amber-bg);color:var(--amber)}
  .cnt{font-size:10px;font-weight:700;color:var(--muted-2);background:var(--gray-bg);border-radius:10px;padding:1px 6px;flex-shrink:0}
  .ke-tag{font-size:10px;color:var(--muted-2);font-weight:600;flex-shrink:0;max-width:90px;overflow:hidden;text-overflow:ellipsis}
  /* parent breadcrumb shown on a focused node */
  .fo .parent-crumb{font-size:9.5px;color:var(--muted-2);font-weight:500;max-width:110px;overflow:hidden;text-overflow:ellipsis;border-left:1px solid var(--line);padding-left:6px}

  /* sticky level rail on the left */
  .lvl-rail{display:flex;gap:6px;padding:8px 16px;background:var(--panel);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:5;flex-wrap:wrap;align-items:center}
  .lvl-rail .rail-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.03em;margin-right:4px}
  .lvl-chip{display:inline-flex;align-items:center;gap:5px;border:1px solid var(--line-2);background:#fff;border-radius:8px;padding:4px 10px;font-size:12px;font-weight:700;cursor:pointer;transition:.12s;color:var(--muted)}
  .lvl-chip:hover{border-color:var(--brand-l);color:var(--brand)}
  .lvl-chip.active{background:var(--brand);border-color:var(--brand);color:#fff}
  .lvl-chip .num{display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:18px;border-radius:5px;background:var(--blue-bg);color:var(--brand);font-size:11px;font-weight:800}
  .lvl-chip.active .num{background:rgba(255,255,255,.25);color:#fff}
  .lvl-chip .ct{font-size:10px;font-weight:600;color:var(--muted-2)}
  .lvl-chip.active .ct{color:rgba(255,255,255,.8)}

  /* ---- nested node structure ---- */
  .tree-body{padding:14px 16px 24px}
  .fo-node{position:relative}
  /* children block: indented, with a left guide line */
  .fo-children{margin:8px 0 4px 22px;padding-left:18px;border-left:2px solid var(--line-2);position:relative}
  .child-lvl-tag{display:flex;align-items:center;gap:8px;margin:4px 0 8px;position:relative}
  .child-lvl-tag::before{content:'';position:absolute;left:-20px;top:50%;width:18px;height:2px;background:var(--line-2)}
  .clt-badge{font-size:10px;font-weight:800;letter-spacing:.03em;text-transform:uppercase;color:#fff;background:var(--brand-l);border-radius:6px;padding:2px 9px}
  .clt-cnt{font-size:10px;font-weight:600;color:var(--muted-2)}
  /* the wrapping shelf — nodes flow and wrap onto new lines */
  .fo-shelf{display:flex;flex-wrap:wrap;gap:9px 10px;align-items:flex-start}

  /* level focus highlighting (rail click) */
  .fo.lvl-focus{outline:2px solid var(--brand);outline-offset:1px;box-shadow:0 2px 10px rgba(0,76,151,.18)}
  .fo.lvl-faded{opacity:.34}
  .fo.lvl-faded:hover{opacity:.7}

  .legend{display:flex;flex-wrap:wrap;gap:14px;font-size:11.5px;color:var(--muted);padding:10px 16px;border-top:1px solid var(--line)}
  .legend span{display:inline-flex;align-items:center;gap:5px}
  .legend i{width:10px;height:10px;border-radius:50%;display:inline-block}

  #probList{display:flex;flex-direction:column;gap:9px;max-height:380px;overflow-y:auto}
  .prob{border:1px solid var(--line);border-left-width:4px;border-radius:9px;padding:10px 12px;font-size:12.5px;background:#fff}
  .prob.err{border-left-color:var(--red)} .prob.warn{border-left-color:var(--amber)} .prob.info{border-left-color:var(--brand-l)}
  .prob .pt{font-weight:700;display:flex;align-items:center;gap:6px;cursor:pointer}
  .prob .pt:hover{color:var(--brand)}
  .prob .pd{color:var(--muted);margin-top:3px;line-height:1.4}
  .prob .pfix{margin-top:8px;display:flex;gap:6px;flex-wrap:wrap}
  .prob .pfix .btn{padding:5px 10px;font-size:11.5px}
  .badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px}
  .badge.err{background:var(--red-bg);color:var(--red)} .badge.warn{background:var(--amber-bg);color:var(--amber)} .badge.info{background:var(--blue-bg);color:var(--brand)}
  .empty-ok{text-align:center;color:var(--green);padding:24px 10px;font-weight:600}
  .empty-ok svg{width:38px;height:38px;margin-bottom:8px}

  #inspector .row{display:flex;flex-direction:column;gap:4px;margin-bottom:12px}
  #inspector .row .k{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.03em}
  #inspector .row .val{font-size:13px;font-weight:600;word-break:break-word}
  #inspector select,#inspector input{width:100%}
  #inspector .hint{font-size:11.5px;color:var(--muted);margin-top:4px}
  .insp-empty{color:var(--muted);text-align:center;padding:40px 14px;font-size:13px}
  .insp-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px}
  .chg-flag{display:inline-block;font-size:10px;font-weight:700;color:#a16207;background:#fef9c3;border-radius:4px;padding:1px 6px;margin-left:6px}

  /* Searchable dropdown */
  .sdrop{position:relative;width:100%}
  .sdrop-btn{display:flex;align-items:center;justify-content:space-between;width:100%;padding:7px 10px;border:1px solid var(--line-2);border-radius:8px;background:#fff;cursor:pointer;font-size:13px;font-family:inherit;color:var(--txt);text-align:left;gap:6px}
  .sdrop-btn:hover{border-color:var(--brand-l)}
  .sdrop-btn.open{border-color:var(--brand-l);box-shadow:0 0 0 3px rgba(37,99,235,.12)}
  .sdrop-btn .sdrop-val{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .sdrop-btn svg{flex-shrink:0;width:14px;height:14px;color:var(--muted-2);transition:transform .15s}
  .sdrop-btn.open svg{transform:rotate(180deg)}
  .sdrop-panel{position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:100;background:#fff;border:1px solid var(--line-2);border-radius:10px;box-shadow:var(--shadow-lg);overflow:hidden}
  .sdrop-search{padding:8px 10px;border-bottom:1px solid var(--line)}
  .sdrop-search input{width:100%;border:1px solid var(--line-2);border-radius:7px;padding:6px 10px;font-size:12px;font-family:inherit}
  .sdrop-search input:focus{outline:none;border-color:var(--brand-l)}
  .sdrop-list{max-height:220px;overflow-y:auto}
  .sdrop-opt{padding:7px 12px;font-size:12.5px;cursor:pointer;transition:background .08s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .sdrop-opt:hover{background:var(--gray-bg)}
  .sdrop-opt.sel{background:var(--blue-bg);color:var(--brand);font-weight:600}
  .sdrop-opt.none{color:var(--muted);font-style:italic}
  .sdrop-empty{padding:14px 12px;font-size:12px;color:var(--muted);text-align:center}

  .pill-tabs{display:inline-flex;background:var(--gray-bg);border-radius:9px;padding:3px;gap:2px}
  .pill-tabs button{border:none;background:transparent;padding:7px 13px;border-radius:7px;font-size:12.5px;font-weight:600;color:var(--muted);cursor:pointer;font-family:inherit}
  .pill-tabs button.act{background:#fff;color:var(--brand);box-shadow:var(--shadow)}

  .toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(40px);background:var(--brand-d);color:#fff;padding:11px 20px;border-radius:10px;font-size:13px;font-weight:600;box-shadow:var(--shadow-lg);opacity:0;transition:.25s;z-index:200;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .overlay{position:fixed;inset:0;background:rgba(238,241,245,.86);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:300;gap:14px}
  .spin{width:42px;height:42px;border:4px solid var(--line-2);border-top-color:var(--brand);border-radius:50%;animation:sp 0.8s linear infinite}
  @keyframes sp{to{transform:rotate(360deg)}}
  .hidden{display:none!important}
</style>
</head>
<body>
<div class="header">
  <h1>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/><path d="M6 9v3a3 3 0 003 3h0M15 18h-3a3 3 0 01-3-3"/></svg>
    Иерархия функциональных областей
  </h1>
</div>

<div class="wrap">
  <div id="uploadView">
    <div class="dropzone" id="dropzone">
      <svg class="dz-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      <h2>Загрузить файл ФО (.xlsx)</h2>
      <p>Перетащите или нажмите для выбора</p>
      <input type="file" id="fileInput" accept=".xlsx" class="hidden">
    </div>
    <div id="keFileZone" style="margin-top:14px">
      <div class="dropzone" id="dropzoneKE" style="padding:28px 28px">
        <svg style="width:32px;height:32px;margin:0 auto 10px;color:var(--brand);opacity:.75;display:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>
        <p style="font-size:13px;color:var(--muted)">Загрузить файл КЕ → ФО <span style="color:var(--muted-2);font-size:11px">(необязательно)</span></p>
        <input type="file" id="fileInputKE" accept=".xlsx" class="hidden">
      </div>
      <div id="keFileStatus" style="font-size:12px;color:var(--muted);margin-top:8px;text-align:center"></div>
    </div>
  </div>

  <div id="mainView" class="hidden">
    <div class="toolbar">
      <label class="fld">Конфигурационная единица (КЕ)<select id="keFilter"></select></label>
      <label class="fld">Поиск ФО<input type="text" id="searchInput" placeholder="название или ID…" style="min-width:220px"></label>
      <div class="pill-tabs" id="filterTabs">
        <button data-f="all" class="act">Все</button>
        <button data-f="chg">Изменённые</button>
        <button data-f="root">Без родителя</button>
      </div>
      <div class="spacer"></div>
      <button class="btn" id="btnExpand"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>Развернуть</button>
      <button class="btn" id="btnCollapse"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 11 12 6 7 11"/><polyline points="17 18 12 13 7 18"/></svg>Свернуть</button>
      <div class="sep"></div>
      <button class="btn ghost" id="btnReset"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 109-9 9 9 0 00-6.36 2.64L3 8"/><path d="M3 3v5h5"/></svg>Сбросить правки</button>
      <button class="btn ghost" id="btnNew"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Другой файл</button>
