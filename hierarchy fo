<div class="overlay hidden" id="overlay"><div class="spin"></div><div id="overlayMsg" style="font-weight:600;color:var(--brand-d)">Обработка файла…</div></div>
<div class="toast" id="toast"></div>

<script>
"use strict";
/* ================= CONST ================= */
const ROOT='__ROOT__';
const ROOT_FO_NAME='Функциональные области бизнес-приложения';
const LEVEL_CANON={0:'0-й уровень',1:'1-ый уровень',2:'2-й уровень',3:'3-ий уровень',4:'4-ый уровень'};
function canonLevel(n){ if(n==null||isNaN(n))return null; return LEVEL_CANON[n]!=null?LEVEL_CANON[n]:(n+'-й уровень'); }
const LEVEL_CHOICES=[0,1,2,3,4];

/* ================= STATE ================= */
let HEADERS=[];      // original header strings
let COLMAP={};       // semantic -> 0-based index
let FOS=new Map();   // id(key) -> record
let MODEL=null;      // {nodes, children}
let ORIG=null;       // snapshot for reset
let META={rows:0, autoFixed:0};
let KE_MAP=new Map(); // foName/foId -> ke (from second file)
let state={ke:'ALL', filter:'all', search:'', selected:null, expanded:new Set(), focusLevel:null};
let DRAG=null;

/* ================= HELPERS ================= */
const $=id=>document.getElementById(id);
const esc=s=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const norm=s=>String(s==null?'':s).trim();
const eq=(a,b)=>norm(a)===norm(b);
function toast(m){const t=$('toast');t.textContent=m;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2300);}
function overlay(on,msg){const o=$('overlay');if(msg)$('overlayMsg').textContent=msg;o.classList.toggle('hidden',!on);}
const isYes=v=>{const s=norm(v).toLowerCase();return s==='да'||s==='yes'||s==='true'||s==='1';};
function levelInt(raw){const m=String(raw==null?'':raw).match(/-?\d+/);return m?parseInt(m[0],10):null;}
function tokens(s){return new Set(String(s==null?'':s).toLowerCase().replace(/[()\[\]«»",.;:]/g,' ').split(/\s+/).filter(w=>w.length>1));}
function jaccard(a,b){const A=tokens(a),B=tokens(b);if(!A.size||!B.size)return 0;let i=0;A.forEach(x=>{if(B.has(x))i++;});return i/(A.size+B.size-i);}
// ExcelJS cell value -> string
function cellStr(v){
  if(v==null)return '';
  if(typeof v==='object'){
    if(Array.isArray(v.richText))return v.richText.map(t=>t.text).join('');
    if(v.text!=null)return String(v.text);
    if(v.result!=null)return String(v.result);
    if(v.hyperlink&&v.text)return String(v.text);
    if(v instanceof Date)return v.toLocaleDateString('ru-RU');
    if(v.value!=null)return String(v.value);
    return '';
  }
  return String(v);
}

/* ================= COLUMN DETECTION ================= */
const COLDEFS=[
  {key:'ke',pats:[/^ке$/i,/конфигурац/i]},
  {key:'name',pats:[/^название$/i,/^фо$/i,/функциональн.*обл/i]},
  {key:'id',pats:[/^id$/i,/id\s*фо/i,/^ид\s*фо/i]},
  {key:'level',pats:[/^уровень$/i,/^level$/i]},
  {key:'pname',pats:[/^родительская\s*фо$/i,/родительск.*фо/i]},
  {key:'pid',pats:[/^id\s*родительской/i,/^ид\s*родительской/i,/id\s*родительск/i]},
  {key:'plevel',pats:[/уровень\s*родительской/i,/уровень.*родит/i]},
  {key:'obsolete',pats:[/^устаревшая\s*запись$/i,/устаревш/i]},
  {key:'unavail',pats:[/^недоступна?\s*для\s*зи$/i,/недоступн/i]},
  {key:'hidden',pats:[/^не\s*показывать\s*на\s*портале$/i,/не показывать/i,/портал/i]},
  {key:'tzi',pats:[/тзи/i]},
  {key:'relname',pats:[/связанн.*фо.*релиз/i]},
  {key:'relid',pats:[/id\s*связанн/i]},
];
function detectColumns(headers){
  const map={};
  headers.forEach((h,i)=>{const hh=norm(h);COLDEFS.forEach(d=>{if(map[d.key]===undefined&&d.pats.some(p=>p.test(hh)))map[d.key]=i;});});
  // Fallback по позиции: ID(0), Уровень(1), Название(2), Родительская ФО(3), id родительской ФО(4), Уровень родительской ФО(5), Устаревшая запись(6), Недоступна для ЗИ(7), не показывать на портале(8)
  if(map.id===undefined)map.id=0;
  if(map.level===undefined)map.level=1;
  if(map.name===undefined)map.name=2;
  if(map.pname===undefined)map.pname=3;
  if(map.pid===undefined)map.pid=4;
  if(map.plevel===undefined)map.plevel=5;
  if(map.obsolete===undefined)map.obsolete=6;
  if(map.unavail===undefined)map.unavail=7;
  if(map.hidden===undefined)map.hidden=8;
  return map;
}

/* ================= PARSE ================= */
async function readWorkbook(file){
  if(!window.ExcelJS)throw new Error('Библиотека ExcelJS не загружена. Поместите exceljs.min.js рядом с этим файлом.');
  const buf=await file.arrayBuffer();
  const sig=new Uint8Array(buf.slice(0,4));
  const isZip=sig[0]===0x50&&sig[1]===0x4B&&sig[2]===0x03&&sig[3]===0x04;
  if(!isZip){
    if(sig[0]===0xD0&&sig[1]===0xCF)throw new Error('Старый формат .xls или файл под паролем. Сохраните как .xlsx.');
    throw new Error('Файл не является корректным .xlsx.');
  }
  const wb=new ExcelJS.Workbook();
  await wb.xlsx.load(buf);
  return wb;
}

function parseWorkbook(wb){
  const ws=wb.worksheets[0];
  if(!ws)throw new Error('В книге нет листов');
  // header row = first non-empty row
  let headerRowIdx=1;
  HEADERS=[];
  ws.getRow(1).eachCell({includeEmpty:true},(c,col)=>{HEADERS[col-1]=norm(cellStr(c.value));});
  // trim trailing empties
  while(HEADERS.length&&!HEADERS[HEADERS.length-1])HEADERS.pop();
  COLMAP=detectColumns(HEADERS);
  const C=COLMAP, ncol=Math.max(HEADERS.length,(Math.max(...Object.values(C))+1));
  FOS=new Map();
  const counts=new Map(), conflicts=new Map();
  let dataRows=0;
  ws.eachRow({includeEmpty:false},(row,rn)=>{
    if(rn===headerRowIdx)return;
    const raw=new Array(ncol).fill('');
    let empty=true;
    for(let i=0;i<ncol;i++){const s=cellStr(row.getCell(i+1).value);raw[i]=s;if(s!=='')empty=false;}
    if(empty)return;
    dataRows++;
    const id=norm(raw[C.id]), name=norm(raw[C.name]);
    if(!id&&!name)return;
    const key=id||('name::'+name);
    const lvlRaw=norm(raw[C.level]);
    const rec={
      id:key, realId:id, ke:norm(raw[C.ke]), name,
      unavail:isYes(raw[C.unavail]), hidden:isYes(raw[C.hidden]), obsolete:isYes(raw[C.obsolete]), tzi:norm(raw[C.tzi]),
      pname:norm(raw[C.pname]), pid:norm(raw[C.pid]),
      relname:norm(raw[C.relname]), relid:norm(raw[C.relid]),
      levelRaw:lvlRaw, level:levelInt(lvlRaw),
      origPname:norm(raw[C.pname]), origPid:norm(raw[C.pid]), origLevelRaw:lvlRaw,
      rawRow:raw, srcRows:1
    };
    if(counts.has(key)){
      counts.set(key,counts.get(key)+1);
      const prev=FOS.get(key);
      if(!eq(prev.origPid,rec.origPid)||!eq(prev.origPname,rec.origPname)||prev.level!==rec.level)conflicts.set(key,true);
      if(!prev.pid&&rec.pid){prev.pid=rec.pid;prev.pname=rec.pname;prev.origPid=rec.origPid;prev.origPname=rec.origPname;}
      if(prev.level==null&&rec.level!=null){prev.level=rec.level;prev.origLevelRaw=rec.origLevelRaw;prev.levelRaw=rec.levelRaw;}
    }else{
      counts.set(key,1); FOS.set(key,rec);
    }
  });
  // finalize: dedupe meta + AUTO-NORMALIZE levels to canonical
  META.autoFixed=0;
  FOS.forEach((f,k)=>{
    f.srcRows=counts.get(k); f.dupConflict=!!conflicts.get(k);
    const canon=canonLevel(f.level);
    if(canon!=null){ f.levelRaw=canon; if(!eq(canon,f.origLevelRaw))META.autoFixed++; }
  });
  META.rows=dataRows;
  ORIG=snapshot();
}
function snapshot(){return JSON.stringify([...FOS.values()]);}
function restore(json){FOS=new Map(JSON.parse(json).map(f=>[f.id,f]));}

/* ================= MODEL (O(n)) ================= */
function buildModel(){
  const byRealId=new Map();
  FOS.forEach(f=>{if(f.realId)byRealId.set(f.realId,f);});
  const nodes=new Map(FOS);
  const synth=new Map();

  FOS.forEach(f=>{
    f.problems=[]; f.resolvedParent=null; f.suggest=null;
    const hasRef=f.pid||f.pname;
    if(!hasRef){ f.parentKey=ROOT; return; }
    let p=f.pid?byRealId.get(f.pid):null;
    if(p){
      f.resolvedParent=p; f.parentKey=p.id;
      if(f.pname&&jaccard(f.pname,p.name)<0.34)
        f.problems.push({t:'name_id_mismatch',sev:'info',msg:`Имя родителя в файле («${f.pname}») не похоже на ФО с этим ID («${p.name}»).`});
    }else{
      // parent not in file — это НОРМА (не ошибка). Группируем под нейтральным узлом-заглушкой.
      const skey='synth::'+(f.pid||('name::'+f.pname));
      if(!synth.has(skey)){
        synth.set(skey,{id:skey,realId:f.pid||'',name:f.pname||'(родитель не указан)',ke:f.ke,synthetic:true,
          level:null,levelRaw:'',problems:[],parentKey:ROOT,childCount:0,
          unavail:false,hidden:false,obsolete:false,tzi:'',pname:'',pid:'',srcRows:0});
      }
      f.parentKey=skey;
    }
  });
  synth.forEach((v,k)=>nodes.set(k,v));

  // self-parent
  nodes.forEach(f=>{ if(!f.synthetic&&f.parentKey===f.id){ f.problems.push({t:'self_parent',sev:'err',msg:'ФО ссылается сама на себя.'}); f.parentKey=ROOT; } });

  // children map
  const children=new Map();
  nodes.forEach(f=>{const pk=f.parentKey||ROOT; (children.get(pk)||children.set(pk,[]).get(pk)).push(f.id);});

  // cycle detection (iterative-ish DFS)
  const color=new Map();
  function dfs(start){
    const stack=[[start,0]]; const path=new Set();
    // simple recursive guarded
  }
  const visiting=new Set(), done=new Set();
  function visit(id){
    if(done.has(id))return; visiting.add(id);
    for(const c of (children.get(id)||[])){
      if(visiting.has(c)){ const cn=nodes.get(c); if(cn&&!cn.synthetic){cn.problems.push({t:'cycle',sev:'err',msg:'Цикл в иерархии (потомок оказался предком).'});} const arr=children.get(id); /*break link*/ if(cn)cn.parentKey=ROOT; }
      else if(!done.has(c)) visit(c);
    }
    visiting.delete(id); done.add(id);
  }
  (children.get(ROOT)||[]).slice().forEach(visit);
  // rebuild children after possible cycle breaks
  const children2=new Map();
  nodes.forEach(f=>{const pk=f.parentKey||ROOT;(children2.get(pk)||children2.set(pk,[]).get(pk)).push(f.id);});

  // per-node checks (level)
  nodes.forEach(f=>{
    if(f.synthetic)return;
    if(f.level==null) f.problems.push({t:'level_unparsed',sev:'warn',msg:`Уровень не распознан: «${f.origLevelRaw||'—'}».`});
    if(f.dupConflict) f.problems.push({t:'dup_conflict',sev:'warn',msg:'В исходных строках у этого ID разные родитель/уровень — данные противоречивы.'});
    // Apply KE from second file if available
    if(KE_MAP.size){
      const keVal=KE_MAP.get(norm(f.name))||KE_MAP.get(norm(f.realId))||'';
      if(keVal) f.ke=keVal;
    }
  });
  // Level sequence validation: parent level N → child must be N+1
  nodes.forEach(f=>{
    if(f.synthetic||f.parentKey===ROOT)return;
    const parent=nodes.get(f.parentKey);
    if(!parent||parent.synthetic)return;
    if(f.level!=null&&parent.level!=null){
      if(f.level!==parent.level+1){
        f.problems.push({t:'level_gap',sev:'err',
          msg:`Ошибка уровней: родительская ФО «${parent.name}» имеет уровень ${parent.level}, а дочерняя «${f.name}» — уровень ${f.level}. Ожидается уровень ${parent.level+1}.`});
      }
    }
  });
  // child counts on synthetic
  synth.forEach(s=>{s.childCount=(children2.get(s.id)||[]).length;});

  MODEL={nodes,children:children2};
  return MODEL;
}

/* ================= CHANGE TRACKING ================= */
function changedFields(f){
  const lvl = f.level!=null && !eq(canonLevel(f.level),f.origLevelRaw);
  return { level:lvl, pname:!eq(f.pname,f.origPname), pid:!eq(f.pid,f.origPid) };
}
function isChanged(f){const c=changedFields(f);return c.level||c.pname||c.pid;}

/* ================= SEVERITY ================= */
function severity(f){ if(!f.problems||!f.problems.length)return 'ok'; if(f.problems.some(p=>p.sev==='err'))return 'err'; if(f.problems.some(p=>p.sev==='warn'))return 'warn'; return 'ok'; }

/* ================= RENDER ROOT ================= */
function renderAll(){ buildModel(); renderKE(); renderStats(); renderRoots(); renderTree(); renderInspector(); }

function renderKE(){
  const sel=$('keFilter');
  const kes=[...new Set([...FOS.values()].map(f=>f.ke).filter(Boolean))].sort((a,b)=>a.localeCompare(b,'ru'));
  if(!(kes.includes(state.ke)||state.ke==='ALL'))state.ke='ALL';
  sel.innerHTML=`<option value="ALL">Все КЕ (${kes.length})</option>`+kes.map(k=>`<option value="${esc(k)}" ${state.ke===k?'selected':''}>${esc(k)}</option>`).join('');
  sel.value=state.ke;
}

function renderStats(){
  const all=[...FOS.values()].filter(f=>state.ke==='ALL'||f.ke===state.ke);
  const changed=all.filter(isChanged).length;
  const roots=all.filter(f=>f.parentKey===ROOT).length;
  const kes=new Set(all.map(f=>f.ke).filter(Boolean)).size;
  $('statsRow').innerHTML=`
    <div class="stat info"><div class="bar"></div><div class="v">${all.length.toLocaleString('ru-RU')}</div><div class="l">Функциональных областей</div></div>
    <div class="stat info"><div class="bar"></div><div class="v">${kes}</div><div class="l">Конфигурационных единиц</div></div>
    <div class="stat info"><div class="bar"></div><div class="v">${roots.toLocaleString('ru-RU')}</div><div class="l">Верхних узлов</div></div>
    <div class="stat chg"><div class="bar"></div><div class="v">${changed.toLocaleString('ru-RU')}</div><div class="l">Изменённых ФО (к выгрузке)</div></div>`;
}

/* ---- roots panel (П.4 — filtered by KE) ---- */
function renderRoots(){
  const box=$('rootsBox');
  const roots=[...FOS.values()].filter(f=>{
    if(!f.pname&&!f.pid){ // no parent columns
      if(state.ke==='ALL') return true;
      // include if this FO or any of its descendants belongs to selected KE
      if(f.ke===state.ke) return true;
      if(!MODEL) return false;
      const desc=descendants(f.id);
      for(const dId of desc){ const d=FOS.get(dId); if(d&&d.ke===state.ke) return true; }
      return false;
    }
    return false;
  }).sort((a,b)=>(a.name||'').localeCompare(b.name||'','ru'));
  $('rootsCount').textContent=roots.length?roots.length.toLocaleString('ru-RU')+' шт.':'';
  if(!roots.length){box.innerHTML=`<div style="color:var(--muted);font-size:13px">Нет ФО без родителя.</div>`;return;}
  box.innerHTML=roots.map(f=>`<span class="root-chip${state.selected===f.id?' sel':''}" data-id="${esc(f.id)}" title="${esc(f.realId||'')}">
    <span style="width:8px;height:8px;border-radius:50%;background:${isChanged(f)?'var(--yellow)':'var(--green)'};flex-shrink:0;display:inline-block"></span>
    ${esc(f.name)}${f.realId?`<span style="color:var(--muted-2);font-weight:400;font-size:11px"> ${esc(f.realId.slice(0,8))}</span>`:''}
  </span>`).join('');
  box.querySelectorAll('.root-chip').forEach(el=>el.onclick=()=>{
    state.selected=el.dataset.id;
    expandTo(state.selected);
    renderTree();
    renderInspector();
    renderRoots();
    setTimeout(scrollToSelected,30);
  });
}

/* ---- included set for current filter — П.3: KE filter includes connected FOs ---- */
function computeIncluded(){
  const {nodes,children}=MODEL;

  // Build "connected" set for KE filter: FOs of selected KE + their ancestors + their descendants
  function keIncluded(f){
    if(state.ke==='ALL') return true;
    if(f.synthetic) return true;
    if(f.ke===state.ke) return true;
    // Check if any descendant belongs to selected KE
    const desc=descendants(f.id);
    for(const dId of desc){ const d=nodes.get(dId); if(d&&!d.synthetic&&d.ke===state.ke) return true; }
    return false;
  }

  const inc=new Set();
  if(!state.search&&state.filter==='all'){
    nodes.forEach(f=>{ if(keIncluded(f)) inc.add(f.id); });
    return {inc,autoExpand:false};
  }
  const q=state.search.toLowerCase();
  const ms=f=>!state.search||(f.name||'').toLowerCase().includes(q)||String(f.realId||'').toLowerCase().includes(q);
  const mf=f=>{ if(state.filter==='err')return severity(f)!=='ok'; if(state.filter==='chg')return isChanged(f); if(state.filter==='root')return !f.pname&&!f.pid; return true; };
  nodes.forEach(f=>{
    if(f.synthetic)return;
    if(!keIncluded(f))return;
    if(ms(f)&&mf(f)){ let cur=f,g=0; while(cur&&g++<60){ inc.add(cur.id); if(cur.parentKey===ROOT)break; cur=nodes.get(cur.parentKey); } }
  });
  return {inc,autoExpand:true};
}

/* ---- node card (returns .fo HTML) ---- */
function nodeCard(f,kids,expanded,isVRoot){
  const sev=severity(f);
  const changed=!f.synthetic&&!isVRoot&&isChanged(f);
  const cf=changed?changedFields(f):{};
  const tg=(kids.length||isVRoot)?`<span class="tg" data-tog="${esc(f.id)}">${expanded?'−':'+'}</span>`:'';
  let lvl='';
  if(isVRoot){
    lvl=`<span class="lvlb" style="background:var(--brand);color:#fff">Ур. 0</span>`;
  } else if(!f.synthetic){
    const lvlCls=cf.level?'chg':(f.problems&&f.problems.some(p=>p.t==='level_gap')?'err':'');
    if(f.level!=null)lvl=`<span class="lvlb ${lvlCls}" title="${esc(canonLevel(f.level))}">Ур. ${f.level}</span>`;
    else lvl=`<span class="lvlb" style="background:var(--gray-bg);color:var(--muted)">Ур. ?</span>`;
  }
  const dot=(f.synthetic||isVRoot)?'':`<span class="dot ${changed?'chg':sev}" title="${changed?'есть изменения':sev}"></span>`;
  const tags=[];
  if(!f.synthetic&&!isVRoot){
    if(f.tzi)tags.push('<span class="atag tzi">ТЗИ</span>');
    if(f.obsolete)tags.push('<span class="atag old">устар.</span>');
    if(f.unavail)tags.push('<span class="atag una">недост.</span>');
    if(f.hidden)tags.push('<span class="atag hid">скрыта</span>');
  }
  const cnt=(!expanded&&kids.length)?`<span class="cnt">${kids.length}</span>`:'';
  const keTag=(state.ke==='ALL'&&f.ke&&!f.synthetic&&!isVRoot)?`<span class="ke-tag" title="${esc(f.ke)}">${esc(f.ke)}</span>`:'';
  const cls=['fo'];
  if(f.synthetic)cls.push('synthetic');
  if(isVRoot)cls.push('vroot-card');
  if(state.selected===f.id)cls.push('sel');
  const drag=(f.synthetic||isVRoot)?'':'draggable="true"';
  const title=esc(f.name)+(f.realId?'  ['+esc(f.realId)+']':'');
  const nmStyle=isVRoot?'style="color:var(--brand);font-weight:800"':'';
  const vrootStyle=isVRoot?'style="background:linear-gradient(135deg,var(--blue-bg),#fff);border-color:var(--brand)"':'';
  return `<div class="${cls.join(' ')}" data-id="${esc(f.id)}" ${drag} ${vrootStyle}>${tg}${dot}<span class="nm" title="${title}" ${nmStyle}>${esc(f.name)||'(без названия)'}</span>${lvl}${tags.join('')}${cnt}${keTag}</div>`;
}

/* ---- render level-band wrapping org-chart ---- */
function renderTree(){
  if(!MODEL)return;
  const {nodes,children}=MODEL;
  const {inc,autoExpand}=computeIncluded();

  const sortKids=arr=>arr.slice().sort((a,b)=>{
    const A=nodes.get(a),B=nodes.get(b);
    return (A.level??99)-(B.level??99)||(A.name||'').localeCompare(B.name||'','ru');
  });

  // Virtual root setup
  const VROOT_ID='__virtual_root__';
  const vroots=sortKids((children.get(ROOT)||[]).filter(id=>inc.has(id)));
  if(vroots.length){
    const vf={id:VROOT_ID,name:ROOT_FO_NAME,level:0,synthetic:false,ke:'',realId:'',pname:'',pid:'',problems:[],parentKey:null,obsolete:false,unavail:false,hidden:false,tzi:''};
    nodes.set(VROOT_ID,vf);
    children.set(VROOT_ID,vroots);
  }

  // Count nodes per displayed level (for the rail)
  const levelCounts=new Map();
  nodes.forEach(n=>{
    if(n.synthetic||n.id===VROOT_ID)return;
    if(!inc.has(n.id))return;
    const L=n.level==null?'?':n.level;
    levelCounts.set(L,(levelCounts.get(L)||0)+1);
  });

  let rendered=0; const MAX=5000; let capped=false;

  // recursive: render a node + its children as a wrapping shelf below
  function renderNode(id,isVRoot){
    if(rendered>MAX){capped=true;return '';}
    const f=nodes.get(id); if(!f)return '';
    let kids=sortKids((children.get(id)||[]).filter(c=>inc.has(c)));
    if(f.synthetic&&kids.length===0)return '';
    rendered++;
    const expanded=isVRoot?(autoExpand||state.expanded.has(id)||state.expanded.size===0):(autoExpand||state.expanded.has(id));
    const card=nodeCard(f,kids,expanded,isVRoot);

    let childrenHtml='';
    if(kids.length&&expanded){
      // children level label
      const childLvl=(()=>{ const c=nodes.get(kids[0]); return c&&c.level!=null?c.level:null; })();
      const lblBadge=childLvl!=null?childLvl:'?';
      childrenHtml=`<div class="fo-children">
        <div class="child-lvl-tag"><span class="clt-badge">Уровень ${lblBadge}</span><span class="clt-cnt">${kids.length} ФО</span></div>
        <div class="fo-shelf">${kids.map(k=>renderNode(k,false)).join('')}</div>
      </div>`;
    }
    return `<div class="fo-node" data-node="${esc(id)}">${card}${childrenHtml}</div>`;
  }

  // Level rail (sticky)
  const sortedLevels=[...levelCounts.keys()].sort((a,b)=>{
    if(a==='?')return 1; if(b==='?')return -1; return a-b;
  });
  const railHtml=`<div class="lvl-rail">
    <span class="rail-title">Уровни:</span>
    <span class="lvl-chip${state.focusLevel===0?' active':''}" data-lvl="0"><span class="num">0</span>Корень</span>
    ${sortedLevels.map(L=>`<span class="lvl-chip${state.focusLevel===L?' active':''}" data-lvl="${L}"><span class="num">${L}</span><span class="ct">${levelCounts.get(L)}</span></span>`).join('')}
  </div>`;

  // Body
  let bodyHtml='';
  if(vroots.length){
    bodyHtml=renderNode(VROOT_ID,true);
  } else {
    bodyHtml=`<div style="text-align:center;color:var(--muted);padding:40px">Нет ФО по текущему фильтру.</div>`;
  }

  $('treeViewport').innerHTML=railHtml+`<div class="tree-body">${bodyHtml}</div>`+(capped?`<div style="padding:12px;color:var(--muted);font-size:12px;text-align:center">Показаны не все узлы (>${MAX}). Используйте поиск или фильтр по КЕ.</div>`:'');

  let cnt=0; nodes.forEach(n=>{if(!n.synthetic&&n.id!==VROOT_ID&&inc.has(n.id))cnt++;});
  $('treeCount').textContent=cnt.toLocaleString('ru-RU')+' ФО';

  applyFocusLevel();
}

/* highlight the level currently focused via the rail */
function applyFocusLevel(){
  const vp=$('treeViewport');
  if(state.focusLevel==null)return;
  vp.querySelectorAll('.fo').forEach(el=>{
    el.classList.remove('lvl-focus','lvl-faded');
    const id=el.dataset.id;
    const f=id==='__virtual_root__'?{level:0}:MODEL.nodes.get(id);
    if(!f)return;
    const L=(id==='__virtual_root__')?0:f.level;
    if(L===state.focusLevel) el.classList.add('lvl-focus');
    else el.classList.add('lvl-faded');
  });
}

/* ---- tree events (delegated) ---- */
function bindTree(){
  const box=$('treeBox');
  const vp=$('treeViewport');

  vp.addEventListener('click',e=>{
    // level rail chip
    const chip=e.target.closest('.lvl-chip');
    if(chip){
      const L=chip.dataset.lvl==='?'?'?':parseInt(chip.dataset.lvl,10);
      state.focusLevel=(state.focusLevel===L)?null:L;
      renderTree();
      return;
    }
    // toggle expand/collapse
    const tog=e.target.closest('[data-tog]');
    if(tog){
      e.stopPropagation();
      const id=tog.getAttribute('data-tog');
      if(state.expanded.has(id)) state.expanded.delete(id);
      else state.expanded.add(id);
      renderTree();
      return;
    }
    // select node
    const fo=e.target.closest('.fo');
    if(fo&&fo.dataset.id&&fo.dataset.id!=='__virtual_root__'){
      state.selected=fo.dataset.id;
      vp.querySelectorAll('.fo.sel').forEach(n=>n.classList.remove('sel'));
      fo.classList.add('sel');
      renderInspector();
    }
  });

  // Drag & drop
  let dragId=null;
  vp.addEventListener('dragstart',e=>{
    const fo=e.target.closest('.fo[draggable="true"]');
    if(!fo)return;
    dragId=fo.dataset.id;
    e.dataTransfer.setData('text/plain',dragId);
    e.dataTransfer.effectAllowed='move';
    fo.classList.add('dragging');
  });
  vp.addEventListener('dragend',()=>{
    vp.querySelectorAll('.fo.dragging,.fo.drag-over').forEach(n=>n.classList.remove('dragging','drag-over'));
  });
  vp.addEventListener('dragover',e=>{
    const fo=e.target.closest('.fo');
    if(!fo||fo.dataset.id===dragId)return;
    e.preventDefault();
    e.dataTransfer.dropEffect='move';
    vp.querySelectorAll('.fo.drag-over').forEach(n=>n.classList.remove('drag-over'));
    fo.classList.add('drag-over');
  });
  vp.addEventListener('drop',e=>{
    const fo=e.target.closest('.fo');
    if(!fo)return;
    e.preventDefault();
    fo.classList.remove('drag-over');
    if(dragId&&fo.dataset.id&&dragId!==fo.dataset.id&&fo.dataset.id!=='__virtual_root__') reparent(dragId,fo.dataset.id);
    dragId=null;
  });
}

function expandTo(id){
  let cur=MODEL.nodes.get(id),g=0;
  while(cur&&g++<60){const pk=cur.parentKey;if(pk===ROOT||pk==null)break;state.expanded.add(pk);cur=MODEL.nodes.get(pk);}
  state.expanded.add('__virtual_root__');
}
function scrollToSelected(){
  const vp=$('treeViewport');
  const el=vp.querySelector(`.fo[data-id="${cssEsc(state.selected||'')}"]`);
  if(el) el.scrollIntoView({block:'center',behavior:'smooth'});
}

