// П.2: Searchable dropdown helper
function buildSearchableDropdown(containerId,options,currentValue,placeholder,onSelect){
  const container=document.getElementById(containerId);
  if(!container)return;
  let open=false;
  let filterQ='';

  function getLabel(val){
    if(val===ROOT||val===''||val===null)return '— нет (верхний узел) —';
    const opt=options.find(o=>o.value===val);
    return opt?opt.label:(placeholder||val);
  }

  function render(){
    const filtered=options.filter(o=>!filterQ||o.label.toLowerCase().includes(filterQ.toLowerCase()));
    container.innerHTML=`
      <div class="sdrop" id="sd_${containerId}">
        <button class="sdrop-btn${open?' open':''}" id="sd_btn_${containerId}" type="button">
          <span class="sdrop-val">${esc(getLabel(currentValue))}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        ${open?`<div class="sdrop-panel" id="sd_panel_${containerId}">
          <div class="sdrop-search"><input id="sd_inp_${containerId}" placeholder="Поиск…" value="${esc(filterQ)}" autocomplete="off"></div>
          <div class="sdrop-list">
            <div class="sdrop-opt none${currentValue===ROOT||!currentValue?' sel':''}" data-val="${ROOT}">— нет (верхний узел) —</div>
            ${filtered.length?filtered.map(o=>`<div class="sdrop-opt${o.value===currentValue?' sel':''}" data-val="${esc(o.value)}">${esc(o.label)}</div>`).join('')
              :'<div class="sdrop-empty">Ничего не найдено</div>'}
          </div>
        </div>`:''}
      </div>`;

    document.getElementById(`sd_btn_${containerId}`).onclick=(e)=>{e.stopPropagation();open=!open;filterQ='';render();if(open){const inp=document.getElementById(`sd_inp_${containerId}`);if(inp)setTimeout(()=>inp.focus(),10);}};

    if(open){
      const inp=document.getElementById(`sd_inp_${containerId}`);
      if(inp) inp.oninput=(e)=>{filterQ=e.target.value;render();};
      const panel=document.getElementById(`sd_panel_${containerId}`);
      if(panel) panel.querySelectorAll('.sdrop-opt').forEach(el=>{
        el.onclick=(e)=>{e.stopPropagation();currentValue=el.dataset.val;open=false;filterQ='';render();onSelect(currentValue);};
      });
    }
  }
  render();
  // close on outside click
  if(!window._sdropListener){
    window._sdropListener=true;
    document.addEventListener('click',()=>{
      if(open){open=false;filterQ='';render();}
    });
  }
}

function renderInspector(){
